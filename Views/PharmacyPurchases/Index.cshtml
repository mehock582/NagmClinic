@{
    ViewData["Title"] = "مشتريات الصيدلية";
}

<div class="card border-0 shadow-sm rounded-3">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0 text-primary">
                <i class="bi bi-cart-plus-fill me-2"></i> مشتريات الصيدلية
            </h5>
            <a asp-action="Create" class="btn btn-primary btn-sm rounded-pill px-3">
                <i class="bi bi-plus-lg me-1"></i> فاتورة شراء جديدة
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle text-center small w-100 nowrap">
                <thead class="bg-light">
                    <tr>
                        <th class="border-0">رقم الفاتورة</th>
                        <th class="border-0">التاريخ</th>
                        <th class="border-0">المورد</th>
                        <th class="border-0">عدد البنود</th>
                        <th class="border-0">الإجمالي</th>
                        <th class="border-0">الإجراءات</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    
    
    
    <script>
        $(function () {
            var columns = [
                { "data": "invoiceNumber", "render": function(d) { return `<span class="fw-bold">${d}</span>`; } },
                { "data": "purchaseDate" },
                { "data": "supplierName" },
                { "data": "linesCount", "render": function(d) { return `<span class="badge bg-light text-dark border">${d}</span>`; } },
                { "data": "totalAmount", "render": function(d) { return `<span class="fw-bold text-primary">${parseFloat(d).toFixed(2)}</span>`; } },
                { "data": "id", "orderable": false, "render": function(d) { return renderPharmacyActionButtons(d, '/PharmacyPurchases', 'purchases'); } }
            ];
            initDataTable('.table', '/PharmacyPurchases/GetPurchasesData', columns);
        });
    </script>
}


