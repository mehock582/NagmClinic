@model NagmClinic.Models.PharmacyPurchase

@{
    ViewData["Title"] = "تفاصيل فاتورة الشراء";
}

<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4 mb-3">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0 text-primary"><i class="bi bi-receipt me-2"></i> فاتورة شراء</h5>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3">العودة</a>
                </div>
                <div class="row g-3">
                    <div class="col-md-3"><div class="small text-muted">رقم الفاتورة</div><div class="fw-bold">@(string.IsNullOrWhiteSpace(Model.InvoiceNumber) ? $"PO-{Model.Id:D5}" : Model.InvoiceNumber)</div></div>
                    <div class="col-md-3"><div class="small text-muted">تاريخ الشراء</div><div class="fw-bold">@Model.PurchaseDate.ToString("yyyy-MM-dd HH:mm")</div></div>
                    <div class="col-md-3"><div class="small text-muted">المورد</div><div class="fw-bold">@Model.Supplier?.Name</div></div>
                    <div class="col-md-3"><div class="small text-muted">الإجمالي</div><div class="fw-bold text-primary">@Model.TotalAmount.ToString("N2") ج.س</div></div>
                    <div class="col-12"><div class="small text-muted">ملاحظات</div><div class="fw-bold">@(string.IsNullOrWhiteSpace(Model.Notes) ? "-" : Model.Notes)</div></div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-3">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-box-seam me-2"></i>بنود الفاتورة</h6>
                <div class="table-responsive">
                    <table class="table table-hover align-middle text-center small w-100">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-0">الصنف</th>
                                <th class="border-0">الوحدة</th>
                                <th class="border-0">رقم الباتش</th>
                                <th class="border-0">الباركود</th>
                                <th class="border-0">الانتهاء</th>
                                <th class="border-0">الكمية</th>
                                <th class="border-0">البونص</th>
                                <th class="border-0">شراء</th>
                                <th class="border-0">بيع</th>
                                <th class="border-0">الإجمالي</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in Model.Lines.OrderBy(l => l.ExpiryDate))
                            {
                                <tr>
                                    <td class="fw-bold">@line.Item?.Name</td>
                                    <td>@line.Item?.Unit?.Name</td>
                                    <td><span class="badge bg-light text-dark border">@line.BatchNumber</span></td>
                                    <td><span class="text-primary small fw-bold">@line.Barcode</span></td>
                                    <td>@line.ExpiryDate.ToString("yyyy-MM-dd")</td>
                                    <td>@line.Quantity.ToString("N2")</td>
                                    <td>@line.BonusQuantity.ToString("N2")</td>
                                    <td>@line.PurchasePrice.ToString("N2")</td>
                                    <td>@line.SellingPrice.ToString("N2")</td>
                                    <td class="fw-bold text-primary">@line.LineTotal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
