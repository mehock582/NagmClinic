@{
    ViewData["Title"] = "مخزون الصيدلية";
}

<div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-body p-2">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <h5 class="fw-bold mb-0 text-primary"><i class="bi bi-boxes me-2"></i>مخزون الصيدلية</h5>
            
            <div class="btn-group shadow-sm" role="group" aria-label="Inventory View Toggle">
                <input type="radio" class="btn-check" name="viewMode" id="viewCategory" autocomplete="off" checked>
                <label class="btn btn-outline-primary px-4 border-2 fw-bold" for="viewCategory">
                    <i class="bi bi-grid-3x3-gap-fill me-2"></i>عرض حسب الصنف
                </label>

                <input type="radio" class="btn-check" name="viewMode" id="viewBatch" autocomplete="off">
                <label class="btn btn-outline-primary px-4 border-2 fw-bold" for="viewBatch">
                    <i class="bi bi-layers-half me-2"></i>عرض حسب الباتش
                </label>
            </div>
        </div>
    </div>
</div>

<!-- Category View Section -->
<div id="categoryViewSection" class="view-section">
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-3">
            <div class="table-responsive">
                <table id="itemsTable" class="table table-hover align-middle text-center small w-100 nowrap">
                    <thead class="bg-light">
                        <tr>
                            <th class="border-0">الصنف</th>
                            <th class="border-0">التصنيف</th>
                            <th class="border-0">الوحدة</th>
                            <th class="border-0">المتاح</th>
                            <th class="border-0">حد الطلب</th>
                            <th class="border-0">الموقع</th>
                            <th class="border-0">الحالة</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Batch View Section -->
<div id="batchViewSection" class="view-section" style="display: none;">
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-3">
            <div class="table-responsive">
                <table id="batchesTable" class="table table-hover align-middle text-center small w-100 nowrap">
                    <thead class="bg-light">
                        <tr>
                            <th class="border-0">الصنف</th>
                            <th class="border-0">الباتش</th>
                            <th class="border-0">الباركود</th>
                            <th class="border-0">الانتهاء</th>
                            <th class="border-0">الكمية</th>
                            <th class="border-0">شراء</th>
                            <th class="border-0">المورد</th>
                            <th class="border-0">الحالة</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    
    
    
    <script>
        $(function () {
            // View switching logic
            $('input[name="viewMode"]').change(function() {
                $('.view-section').hide();
                if (this.id === 'viewCategory') {
                    $('#categoryViewSection').fadeIn(200);
                    $('#itemsTable').DataTable().ajax.reload();
                } else {
                    $('#batchViewSection').fadeIn(200);
                    $('#batchesTable').DataTable().ajax.reload();
                }
            });

            // Initialize Category Table
            var itemCols = [
                { "data": "name", "render": function(d) { return `<span class="fw-bold text-dark">${d}</span>`; } },
                { "data": "categoryName" },
                { "data": "unitName" },
                { "data": "availableQuantity", "render": function(d) { return `<span class="fw-bold">${parseFloat(d).toFixed(2)}</span>`; } },
                { "data": "reorderLevel", "render": function(d) { return parseFloat(d).toFixed(2); } },
                { "data": "location", "render": function(d) { return `<span class="badge bg-light text-dark border">${d}</span>`; } },
                { "data": "stockStatus", "render": function(d) { 
                    return d === 'Low' ? `<span class="badge bg-danger-subtle text-danger border border-danger">نقص مخزون</span>` : `<span class="badge bg-success-subtle text-success border border-success">متوفر</span>`; 
                }}
            ];
            initDataTable('#itemsTable', '/PharmacyInventory/GetInventoryItemsData', itemCols);

            // Initialize Batch Table
            var batchCols = [
                { "data": "itemName", "render": function(d) { return `<span class="fw-bold text-dark">${d}</span>`; } },
                { "data": "batchNumber", "render": function(d) { return `<span class="badge bg-info-subtle text-info border border-info">${d}</span>`; } },
                { "data": "barcode", "render": function(d) { return `<span class="text-primary fw-bold small">${d}</span>`; } },
                { "data": "expiryDate", "render": function(d) { return new Date(d).toLocaleDateString('ar-EG'); } },
                { "data": "quantity", "render": function(d) { return `<span class="fw-bold">${parseFloat(d).toFixed(2)}</span>`; } },
                { "data": "purchasePrice", "render": function(d) { return parseFloat(d).toFixed(2); } },
                { "data": "supplier" },
                { "data": "status", "render": function(d) {
                    if (d === 'Expired') return `<span class="badge bg-danger text-white">منتهي</span>`;
                    if (d === 'Near Expiry') return `<span class="badge bg-warning text-dark">قريب الانتهاء</span>`;
                    return `<span class="badge bg-success text-white">سليم</span>`;
                }}
            ];
            initDataTable('#batchesTable', '/PharmacyInventory/GetInventoryBatchesData', batchCols);
        });
    </script>
}


