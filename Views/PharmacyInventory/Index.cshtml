@{
    ViewData["Title"] = "مخزون الصيدلية";
}

<div class="card border-0 shadow-sm rounded-3 mb-3">
    <div class="card-body p-3">
        <h5 class="fw-bold mb-0 text-primary"><i class="bi bi-boxes me-2"></i>ملخص المخزون الحالي</h5>
    </div>
</div>

<div class="row g-3">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-3">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-capsule-pill me-2"></i>المخزون حسب الصنف (نظرة عامة)</h6>
                <div class="table-responsive">
                    <table id="itemsTable" class="table table-hover align-middle text-center small w-100">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-0">الصنف</th>
                                <th class="border-0">الوحدة</th>
                                <th class="border-0">التصنيف</th>
                                <th class="border-0">الموقع</th>
                                <th class="border-0">المتاح</th>
                                <th class="border-0">حد إعادة الطلب</th>
                                <th class="border-0">المؤشر</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-3">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-stack me-2"></i>تفاصيل المخزون بالباتش والباركود</h6>
                <div class="table-responsive">
                    <table id="batchesTable" class="table table-hover align-middle text-center small w-100">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-0">الصنف</th>
                                <th class="border-0">الباتش</th>
                                <th class="border-0">الباركود</th>
                                <th class="border-0">الانتهاء</th>
                                <th class="border-0">الكمية</th>
                                <th class="border-0">شراء</th>
                                <th class="border-0">بيع</th>
                                <th class="border-0">المورد</th>
                                <th class="border-0">الحالة</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(function () {
            var itemCols = [
                { "data": "name", "render": function(d) { return `<span class="fw-bold">${d}</span>`; } },
                { "data": "unitName" },
                { "data": "categoryName" },
                { "data": "slotCode", "render": function(d) { return `<span class="badge bg-light text-dark border">${d}</span>`; } },
                { "data": "availableQuantity", "render": function(d) { return parseFloat(d).toFixed(2); } },
                { "data": "reorderLevel", "render": function(d) { return parseFloat(d).toFixed(2); } },
                { "data": "availableQuantity", "render": function(d, t, row) { var low = parseFloat(d) <= parseFloat(row.reorderLevel); return low ? `<span class="badge bg-warning text-dark">نقص مخزون</span>` : `<span class="badge bg-success">متوفر</span>`; } }
            ];
            initDataTable('#itemsTable', '/PharmacyInventory/GetInventoryItemsData', itemCols, { "pageLength": 10 });

            var batchCols = [
                { "data": "itemName", "render": function(d) { return `<span class="fw-bold">${d}</span>`; } },
                { "data": "batchNumber", "render": function(d) { return `<span class="badge bg-light text-dark border">${d}</span>`; } },
                { "data": "barcode", "render": function(d) { return `<span class="text-primary fw-bold small">${d}</span>`; } },
                { "data": "expiryDate" },
                { "data": "quantityRemaining", "render": function(d) { return parseFloat(d).toFixed(2); } },
                { "data": "purchasePrice", "render": function(d) { return parseFloat(d).toFixed(2); } },
                { "data": "sellingPrice", "render": function(d) { return parseFloat(d).toFixed(2); } },
                { "data": "supplierName" },
                { "data": "isExpired", "render": function(d, t, row) {
                    if (d) return `<span class="badge bg-danger">منتهي</span>`;
                    if (row.nearExpiry) return `<span class="badge bg-warning text-dark">قريب الانتهاء</span>`;
                    return `<span class="badge bg-success">سليم</span>`;
                }}
            ];
            initDataTable('#batchesTable', '/PharmacyInventory/GetInventoryBatchesData', batchCols, { "pageLength": 10 });
        });
    </script>
}
