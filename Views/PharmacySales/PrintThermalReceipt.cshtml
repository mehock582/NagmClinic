@using NagmClinic.Services.Branding
@model NagmClinic.Models.PharmacySale
@inject IClinicBrandingService BrandingService

@{
    Layout = null;
    var branding = BrandingService.GetBranding();
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>إيصال صرف - @Model.Id</title>
    <link href="~/css/cairo-font.css" rel="stylesheet" />
    <link href="~/css/thermal-receipt.css" rel="stylesheet" />
</head>
<body onload="window.print()">
    <button class="btn-print-overlay no-print" onclick="window.print()"><i class="bi bi-printer"></i> طباعة</button>
    
    <div class="thermal-receipt">
        <header class="receipt-header">
            @if (!string.IsNullOrWhiteSpace(branding.LogoUrl))
            {
                <img src="@branding.LogoUrl" alt="Logo" class="receipt-logo" />
            }
            <h2>@branding.CenterNameAr</h2>
            <p dir="ltr">@branding.Phone</p>
            <p>@branding.AddressAr</p>
            <p><strong>إيصال صرف</strong></p>
            <p><strong>SL-@Model.Id.ToString("D5")</strong></p>
        </header>

        <section class="receipt-info">
            <div>
                <span class="label">التاريخ:</span>
                <span class="value">@Model.SaleDate.ToString("yyyy-MM-dd HH:mm")</span>
            </div>
            <div>
                <span class="label">العميل:</span>
                <span class="value">@(string.IsNullOrWhiteSpace(Model.CustomerName) ? "عميل نقدي" : Model.CustomerName)</span>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Notes))
            {
                <div>
                    <span class="label">ملاحظات:</span>
                    <span class="value">@Model.Notes</span>
                </div>
            }
        </section>

        <table class="receipt-table">
            <thead>
                <tr>
                    <th class="col-item">الصنف</th>
                    <th class="col-qty">ق</th>
                    <th class="col-price">س</th>
                    <th class="col-total">ج</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var line in Model.Lines)
                {
                    <tr>
                        <td class="col-item">@line.Item?.Name</td>
                        <td class="col-qty">@line.Quantity.ToString("G29")</td>
                        <td class="col-price">@line.UnitPrice.ToString("N2")</td>
                        <td class="col-total" dir="ltr">@line.LineTotal.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>

        <section class="receipt-total">
            <div>
                <span>عدد الأصناف:</span>
                <span>@Model.Lines.Count</span>
            </div>
            <div class="grand-total">
                <span>الإجمالي:</span>
                <span dir="ltr">@Model.TotalAmount.ToString("N2") ج.س</span>
            </div>
        </section>

        <footer class="receipt-footer">
            <p>شكراً لزيارتكم</p>
            <p>@branding.CenterNameEn</p>
            <p style="font-size: 7pt; margin-top: 2mm; opacity: 0.7;">
                @DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")
            </p>
        </footer>
    </div>
</body>
</html>
