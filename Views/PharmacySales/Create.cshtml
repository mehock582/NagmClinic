@model NagmClinic.ViewModels.PharmacySaleCreateViewModel

@{
    ViewData["Title"] = "إضافة فاتورة صرف POS";
    <link href="~/css/pharmacy-transaction.css" rel="stylesheet" />
}

<div class="container-fluid px-1 pb-5 mb-5 pharmacy-pos-page">
    <form asp-action="Create" id="saleForm" novalidate>
        @Html.AntiForgeryToken()
        <div class="row g-3 mt-2">
            @* ── Left Side: Scanner & Line Items ── *@
            <div class="col-12 col-lg-8 col-xl-9 col-xxl-10">
                <div class="card shadow-sm border-0 rounded-4 mb-3">
                    <div class="card-body p-3 p-md-4">
                        
                        @* ── POS Header: Scanner & Fixed Controls ── *@
                        <div class="pos-header-container sticky-top py-3 px-2 px-md-4 bg-white rounded-4 shadow-sm mb-4">
                            <div class="row g-2 align-items-center">
                                <div class="col-12 col-md">
                                    <div class="pos-scanner-zone" id="scannerZone">
                                        <div class="pos-scanner-icon-btn d-none d-md-flex">
                                            <i class="bi bi-upc-scan"></i>
                                        </div>
                                        <div class="pos-scanner-input-wrap w-100">
                                            <input type="text" id="barcodeInput"
                                                   class="pos-scanner-input main-barcode-search w-100"
                                                   placeholder="امسح الباركود أو أدخله يدوياً ثم اضغط Enter"
                                                   autocomplete="off"
                                                   onkeypress="return event.keyCode != 13;" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-auto">
                                    <button type="button" class="btn btn-primary rounded-pill px-4 fw-bold w-100" onclick="lookupBarcodeForSale($('#barcodeInput').val())">بحث</button>
                                </div>
                                <div class="col-12 col-md-auto">
                                    <button type="button" class="btn btn-outline-primary btn-sm rounded-pill px-3 w-100" onclick="PharmacyTransaction.addRow()">
                                        <i class="bi bi-plus-lg me-1"></i> إضافة صنف يدوي
                                    </button>
                                </div>
                                <div class="col-12 col-md-auto ms-md-auto d-none d-md-flex align-items-center gap-2">
                                    <div class="pos-status-badge" id="scanStatus">
                                        <i class="bi bi-wifi"></i> جاهز
                                    </div>
                                    <div class="badge bg-primary-subtle text-primary border border-primary px-3 py-2 rounded-pill fw-bold">
                                        <i class="bi bi-cart4 me-2"></i>عدد البنود: <span id="scanCount">0</span>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-2 text-muted ps-2 d-none d-md-block text-center" style="font-size: 0.75rem;">
                                <i class="bi bi-info-circle me-1 text-primary"></i> يدعم: ماسح USB، بلوتوث، لاسلكي، هاتف كماسح — أي جهاز يرسل النص يدوياً.
                            </div>
                        </div>

                        @* ── POS Sales Lines ── *@
                        <div class="container-fluid px-0">


                            <div class="pos-line-header pos-line-header--sale row d-none d-lg-flex align-items-center g-1 mb-1 px-3 text-muted small text-nowrap">
                                <div class="pos-col-item col-lg-3">الصنف</div>
                                <div class="pos-col-qty col-lg-2 text-center">الكمية</div>
                                <div class="pos-col-price col-lg-2 text-center">سعر البيع</div>
                                <div class="pos-col-details col-lg-2 text-center">الباركود</div>
                                <div class="pos-col-total col-lg-2 text-center">الإجمالي</div>
                                <div class="pos-col-actions col-lg-1 text-end">الإجراءات</div>
                            </div>

                            <div id="linesBody" class="pos-lines-container">
                                <!-- Lines will be injected here as pos-line-card -->
                            </div>

                            <div id="emptyContainer" class="erp-empty pos-fade-in py-5 rounded-5 border-2 shadow-inner" style="display:none; background: #fff;">
                                <i class="bi bi-basket-fill fs-1 d-block mb-3 text-primary opacity-25"></i>
                                <h5 class="fw-bold text-muted">لم يتم إضافة أي أصناف بعد</h5>
                                <p class="small text-secondary">ابدأ بمسح الباركود أو الضغط على "إضافة صنف يدوي"</p>
                                <div id="linesClientValidation" class="text-danger mt-3 fw-bold"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* ── Right Side: Metadata & Actions ── *@
            <div class="col-12 col-lg-4 col-xl-3 col-xxl-2 pos-details-panel">
                <div class="card shadow-sm border-0 rounded-4 pos-details-card" style="position: sticky; top: 20px;">
                    <div class="card-body p-2 p-md-3">
                        <h6 class="text-primary fw-bolder mb-3 small"><i class="bi bi-info-circle me-2"></i>تفاصيل الفاتورة</h6>
                        
                        <div class="mb-2 pos-details-field">
                            <label asp-for="SaleDate" class="form-label small mb-1">تاريخ البيع</label>
                            <input asp-for="SaleDate" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local" class="form-control form-control-sm" />
                            <span asp-validation-for="SaleDate" class="text-danger small"></span>
                        </div>
                        <div class="mb-2 pos-details-field">
                            <label asp-for="CustomerName" class="form-label small mb-1">اسم العميل</label>
                            <input asp-for="CustomerName" class="form-control form-control-sm" placeholder="أدخل اسم العميل..." />
                            <span asp-validation-for="CustomerName" class="text-danger small"></span>
                        </div>
                        <input type="hidden" asp-for="Notes" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-4 p-2 mt-2 small shadow-sm"></div>

                        <div class="bg-light rounded-3 p-2 text-center mt-3 mb-2 pos-total-compact">
                            <span class="text-muted d-block mb-0" style="font-size:0.75rem;">الإجمالي التقديري</span>
                            <h4 class="text-primary fw-bold mb-0" id="estimatedTotal">
                                0.00 <span class="fs-6 text-muted">ج.س</span>
                            </h4>
                        </div>

                        <div class="d-grid gap-2 pos-actions-compact">
                            <button type="submit" class="btn btn-primary btn-sm shadow-sm fw-bold">
                                <i class="bi bi-check2-all"></i> حفظ وصرف
                            </button>
                            <a class="btn btn-outline-secondary btn-sm" href="/PharmacySales">
                                <i class="bi bi-arrow-right"></i> رجوع
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@* ── Multi-Match Modal ── *@
<div class="modal fade" id="batchSelectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-primary text-white border-0 py-3">
                <h6 class="modal-title fw-bold">
                    <i class="bi bi-layers me-2"></i> تكرار باركود — اختر الباتش المطلوب
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4" id="batchSelectBody" style="background: #f8fafc;">
                <!-- populated dynamically -->
            </div>
        </div>
    </div>
</div>

<template id="rowTemplate">
    <partial name="_PharmacyLineItem" view-data='@new ViewDataDictionary(ViewData) { { "Mode", "sale" } }' />
</template>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pharmacy-transaction.js"></script>
    <script src="~/js/barcode-scanner.js"></script>
    <script src="~/js/erp-barcode-scanner.js"></script>
    <script>
        var itemLookup = @Html.Raw(Json.Serialize(Model.ItemLookup));
        var totalScans = 0;

        // Initialize Global Interceptor
        $(function() {
            initializeGlobalScanner(function(barcode, unlock) {
                processGlobalScan(barcode, unlock);
            });
        });

        function setStatus(type, text) {
            var el = $('#scanStatus');
            var zone = $('#scannerZone');
            el.removeClass('success error');
            zone.removeClass('pos-flash-success pos-flash-error');

            if (type === 'ready') el.html('<i class="bi bi-wifi"></i> ' + (text || 'جاهز'));
            else if (type === 'success') {
                el.addClass('success').html('<i class="bi bi-check-circle-fill"></i> ' + (text || 'تمت الإضافة'));
                zone.addClass('pos-flash-success');
            } else if (type === 'error') {
                el.addClass('error').html('<i class="bi bi-exclamation-triangle-fill"></i> ' + (text || 'غير موجود'));
                zone.addClass('pos-flash-error');
            }

            if (type !== 'ready') {
                setTimeout(() => {
                    setStatus('ready');
                    zone.removeClass('pos-flash-success pos-flash-error');
                }, 2000);
            }
        }

        function updateScanCount() {
            var count = PharmacyTransaction.getLineCount();
            $('#scanCount').text(count);
        }



        function normalizeDate(dateStr) {
            if (!dateStr) return '-';
            if (dateStr.length >= 10) return dateStr.substring(0, 10);
            return dateStr;
        }

        function updateEstimatedTotalQuick() {
            var total = 0;
            $('#linesBody .line-est-total').each(function () {
                var numeric = parseFloat(($(this).text() || '0').replace(/,/g, ''));
                if (!isNaN(numeric)) total += numeric;
            });
            $('#estimatedTotal').text(formatNumber(total));
        }

        function getItemDefaultPrice(itemId) {
            var id = parseInt(itemId);
            if (!id) return 0;
            var found = itemLookup.find(i => parseInt(i.id) === id);
            return found ? (parseFloat(found.defaultSellingPrice || found.DefaultSellingPrice) || 0) : 0;
        }

        function updateLineEstimatedTotal($row) {
            var qty = parseFloat($row.find('.qty-input').val()) || 0;
            var price = parseFloat($row.find('.sale-price-input').val()) || 0;
            var lineTotal = qty * price;
            $row.find('.line-est-total').text(formatNumber(lineTotal));
            updateEstimatedTotalQuick();
        }

        function highlightLine($row, type) {
            $row.addClass('is-scan-hit');
            setTimeout(() => $row.removeClass('is-scan-hit'), 800);
        }

        $(function () {
            PharmacyTransaction.init({
                mode: 'sale',
                formId: '#saleForm',
                tableBodyId: '#linesBody',
                rowTemplateId: '#rowTemplate',
                emptyContainerId: '#emptyContainer',
                grandTotalId: '#estimatedTotal',
                callbacks: {
                    calculateLineTotal: function ($row) {
                        refreshFefo($row);
                    },
                    onRowAdded: function ($newRow, prefillData) {
                        // DOM manipulation: inject options directly into the select element
                        // (cannot use string replacement — browser strips text nodes from <select>)
                        var $select = $newRow.find('.item-select');
                        var optionsHtml = itemLookup.map(i => `<option value="${i.id || i.Id}">${i.name || i.Name}</option>`).join('');
                        $select.append(optionsHtml);
                        
                        // Support both camelCase and PascalCase
                        var itemId = prefillData?.itemId || prefillData?.ItemId;
                        var batchId = prefillData?.itemBatchId || prefillData?.ItemBatchId;
                        var barcode = prefillData?.barcode || prefillData?.Barcode;
                        var qty = prefillData?.quantity || prefillData?.Quantity || 1;
                        var price = prefillData?.sellingPrice || prefillData?.SellingPrice || prefillData?.defaultSellingPrice || prefillData?.DefaultSellingPrice;

                        if (barcode) {
                            $newRow.attr('data-barcode', barcode);
                            $newRow.find('[data-field="Barcode"]').val(barcode);
                        }
                        if (batchId) {
                            $newRow.attr('data-batch-id', batchId);
                            $newRow.find('[data-field="ItemBatchId"]').val(batchId);
                        }

                        if (itemId) {
                            $select.val(itemId).trigger('change');
                        }
                        $newRow.find('.qty-input').val(qty);
                        if (price) {
                            $newRow.find('.sale-price-input').val(Number(parseFloat(price).toFixed(2)));
                        } else if (itemId) {
                            $newRow.find('.sale-price-input').val(Number(getItemDefaultPrice(itemId).toFixed(2)));
                        }

                        if (prefillData?.barcode || prefillData?.Barcode) {
                            var bc = prefillData?.barcode || prefillData?.Barcode;
                            $newRow.attr('data-barcode', bc);
                            $newRow.find('[data-field="Barcode"]').val(bc);
                        }

                        refreshFefo($newRow);
                        highlightLine($newRow);
                        updateScanCount();

                        setTimeout(() => $('#barcodeInput').focus(), 50);
                    },
                    onRowRemoved: function() {
                        updateScanCount();
                        updateEstimatedTotalQuick();
                    }
                }
            });

            if ($('#linesBody .pos-line-card').length === 0) {
                PharmacyTransaction.addRow({ quantity: 1 });
            }

            // Sticky focus for scanner
            $(document).on('click', function (e) {
                if (!$(e.target).is('input, select, textarea, .select2-search__field, button')) {
                    $('#barcodeInput').focus();
                }
            });

            // Zero-Mouse POS hotkeys
            $(document)
                .off('keydown.posHotkeys')
                .on('keydown.posHotkeys', function (e) {
                    const isEditable =
                        $(e.target).is('input, textarea, select') ||
                        $(e.target).hasClass('select2-search__field') ||
                        $(e.target).closest('.modal.show').length > 0;

                    if (isEditable) return;

                    if (e.key === 'F2' || e.key === 'F4' || e.key === 'F10') {
                        e.preventDefault();
                    }

                    switch (e.key) {
                        case 'F2':
                            $('#barcodeInput').focus().select();
                            break;
                        case 'F4':
                            PharmacyTransaction.addRow();
                            break;
                        case 'F10':
                            var $saveBtn = $('button[type="submit"]');
                            if ($saveBtn.length && !$saveBtn.prop('disabled')) {
                                $saveBtn.trigger('click');
                            }
                            break;
                    }
                });

            $('#linesBody').on('change', '.item-select', function() {
                var $row = $(this).closest('.erp-line-row');
                $row.find('.sale-price-input').val(Number(getItemDefaultPrice($(this).val()).toFixed(2)));
                refreshFefo($row);
            });
        });

        function refreshFefo($row) {
            const itemId = parseInt($row.find('.item-select').val());
            const qty = parseFloat($row.find('.qty-input').val()) || 0;
            const barcode = $row.attr('data-barcode');

            if (!itemId || qty <= 0) {
                $row.find('.specific-batch-text').empty();
                updateLineEstimatedTotal($row);
                return;
            }

            // UI Label behavior
            const $batchLabel = $row.find('.batch-label-text');
            if (barcode) {
                const barcodeLabel = `الباركود: ${barcode}`;
                $batchLabel.text(barcodeLabel).attr('title', barcodeLabel);
            } else {
                const autoLabel = 'تلقائي (FEFO)';
                $batchLabel.text(autoLabel).attr('title', autoLabel);
            }

            var fefoKey = itemId + '|' + qty;
            if ($row.data('fefoKey') === fefoKey) {
                updateLineEstimatedTotal($row);
                return;
            }
            $row.data('fefoKey', fefoKey);

            $row.find('.specific-batch-text').html('<div class="spinner-border spinner-border-sm text-primary" role="status"></div>');

            $.get('/PharmacySales/PreviewFefo', { itemId: itemId, quantity: qty }, function (res) {
                const chips = PharmacyTransaction.renderFefoChips(res.allocations);
                $row.find('.specific-batch-text').html(chips);
                
                // Update data-max for validation
                const available = parseFloat(res.available || 0);
                $row.find('.pos-qty-input').attr('data-max', available);
                
                updateLineEstimatedTotal($row);
            });
        }

        var isProcessingScan = false;

        function processGlobalScan(barcode, unlock) {
            // Highlight the scanner box for visual feedback
            $('#barcodeInput').val(barcode).addClass('pos-flash-success');
            setTimeout(() => $('#barcodeInput').removeClass('pos-flash-success'), 500);
            
            lookupBarcodeForSale(barcode, unlock);
        }

        function lookupBarcodeForSale(barcode, unlock) {
            const finalBarcode = (barcode || "").trim();
            if (!finalBarcode) {
                if (unlock) unlock();
                return;
            }

            if (finalBarcode.length < 3) {
                setStatus('error', 'باركود قصير جداً');
                if (unlock) unlock();
                return;
            }

            if (isProcessingScan) {
                return;
            }
            isProcessingScan = true;

            // Clear input immediately
            $('#barcodeInput').val('').blur(); 
            setStatus('ready', 'جاري البحث...');

            // ── DIRECT AJAX CALL ──
            // We call the server FIRST, before touching any grid rows.
            // This guarantees OUT_OF_STOCK is caught before row contamination.
            $.get('/PharmacySales/LookupByBarcode', { barcode: finalBarcode })
                .done(function(res) {
                    console.log('[PharmacySales] Server Response:', res);

                    var success = res.success ?? res.Success;
                    var status = (res.status || res.Status || "").toUpperCase();

                    // ── OUT OF STOCK: Block immediately ──
                    if (success === false && status === 'OUT_OF_STOCK') {
                        isProcessingScan = false;
                        var msg = res.message || res.Message || "عفواً، لا توجد كمية متاحة من هذا الصنف";
                        setStatus('error', 'نفدت الكمية');
                        BarcodeScanner.beepError();

                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'warning',
                                title: 'تنبيه المخزون',
                                text: msg,
                                confirmButtonText: 'حسناً',
                                confirmButtonColor: '#6c5ce7'
                            }).then(() => {
                                setTimeout(() => $('#barcodeInput').val('').focus(), 50);
                            });
                        } else if (typeof toastr !== 'undefined') {
                            toastr.error(msg, "تنبيه المخزون");
                            setTimeout(() => $('#barcodeInput').val('').focus(), 50);
                        } else {
                            alert(msg);
                            setTimeout(() => $('#barcodeInput').val('').focus(), 50);
                        }

                        if (unlock) unlock();
                        return;
                    }

                    // ── NOT FOUND: Block immediately ──
                    if (success === false) {
                        isProcessingScan = false;
                        var msg = res.message || res.Message || "الباركود غير موجود";
                        setStatus('error', 'الباركود غير موجود');
                        BarcodeScanner.beepError();
                        
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'info',
                                title: 'تنبيه',
                                text: msg,
                                confirmButtonText: 'حسناً',
                                confirmButtonColor: '#6c5ce7'
                            }).then(() => {
                                setTimeout(() => $('#barcodeInput').val('').focus(), 50);
                            });
                        } else {
                            setTimeout(() => $('#barcodeInput').val('').focus(), 50);
                        }
                        
                        if (unlock) unlock();
                        return;
                    }

                    // ── MULTI-MATCH: Open batch selection modal ──
                    var multiMatch = res.multiMatch ?? res.MultiMatch;
                    if (multiMatch) {
                        isProcessingScan = false;
                        showBatchSelectionModal(res.matches || res.Matches, finalBarcode, unlock);
                        return;
                    }

                    // ── SINGLE MATCH: Populate the grid row ──
                    var data = res.data || res.Data;
                    if (data) {
                        // Check if row already exists for this barcode (increment qty)
                        var $existingRow = null;
                        $('#linesBody .erp-line-row').each(function() {
                            if (($(this).attr('data-barcode') || '').toLowerCase() === finalBarcode.toLowerCase()) {
                                $existingRow = $(this); return false;
                            }
                        });

                        if ($existingRow) {
                            var $qty = $existingRow.find('.qty-input');
                            $qty.val((parseFloat($qty.val()) || 0) + 1).trigger('change');
                            highlightLine($existingRow);
                            BarcodeScanner.beepIncrement();
                        } else {
                            // Claim a row and fill it
                            var $targetRow = PharmacyTransaction.getActiveRow();
                            if (!$targetRow || !$targetRow.length) {
                                $targetRow = PharmacyTransaction.addRow();
                            }

                            var itemId = data.itemId || data.ItemId;
                            var batchId = data.batchId || data.BatchId;
                            var price = data.sellingPrice || data.SellingPrice || data.defaultSellingPrice || data.DefaultSellingPrice;
                            var available = data.availableQuantity || data.AvailableQuantity || 0;

                            $targetRow.attr('data-barcode', finalBarcode);
                            $targetRow.attr('data-item-id', itemId);
                            $targetRow.find('.pos-qty-input').attr('data-max', available);
                            if (batchId) {
                                $targetRow.attr('data-batch-id', batchId);
                                $targetRow.find('[data-field="ItemBatchId"]').val(batchId);
                            }
                            $targetRow.find('[data-field="Barcode"]').val(finalBarcode);

                            if (itemId) {
                                $targetRow.find('.item-select').val(itemId).trigger('change');
                            }
                            $targetRow.find('.qty-input').val(1);
                            if (price) {
                                $targetRow.find('.sale-price-input').val(Number(parseFloat(price).toFixed(2)));
                            } else if (itemId) {
                                $targetRow.find('.sale-price-input').val(Number(getItemDefaultPrice(itemId).toFixed(2)));
                            }

                            setTimeout(() => refreshFefo($targetRow), 50);
                            highlightLine($targetRow);
                            BarcodeScanner.beepSuccess();
                        }

                        isProcessingScan = false;
                        setStatus('success', data.itemName || data.ItemName || 'تم بنجاح');
                        updateScanCount();
                        setTimeout(() => $('#barcodeInput').val('').focus(), 50);
                        if (unlock) unlock();
                    }
                })
                .fail(function(xhr) {
                    isProcessingScan = false;
                    console.error('[PharmacySales] AJAX Error:', xhr.status, xhr.responseText);
                    
                    // Try to parse response even on non-200 errors
                    var res = null;
                    try { res = JSON.parse(xhr.responseText); } catch(e) {}
                    
                    var status = res ? (res.status || res.Status || "").toUpperCase() : "";
                    if (status === 'OUT_OF_STOCK') {
                        var msg = res.message || "عفواً، لا توجد كمية متاحة";
                        setStatus('error', 'نفدت الكمية');
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'warning',
                                title: 'تنبيه المخزون',
                                text: msg,
                                confirmButtonText: 'حسناً',
                                confirmButtonColor: '#6c5ce7'
                            }).then(() => {
                                setTimeout(() => $('#barcodeInput').val('').focus(), 50);
                            });
                        } else if (typeof toastr !== 'undefined') {
                            toastr.error(msg, "تنبيه المخزون");
                            setTimeout(() => $('#barcodeInput').val('').focus(), 50);
                        }
                    } else {
                        setStatus('error', 'الباركود غير موجود');
                        setTimeout(() => $('#barcodeInput').val('').focus(), 50);
                    }
                    
                    BarcodeScanner.beepError();
                    setTimeout(() => $('#barcodeInput').val('').focus(), 50);
                    if (unlock) unlock();
                });
        }

        function showBatchSelectionModal(matches, barcode, unlock) {
            var body = $('#batchSelectBody').empty();

            // Ensure we unlock when modal is closed
            $('#batchSelectModal').on('hidden.bs.modal', function () {
               if (unlock) unlock();
               $(this).off('hidden.bs.modal'); // Cleanup
            });
            matches.forEach(m => {
                var row = $(`<div class="card border-0 shadow-sm mb-2 p-3 batch-select-card" style="cursor:pointer; border-radius: 1rem; transition: transform 0.2s;">
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="badge bg-primary-subtle text-primary border border-primary px-3">صنف: ${m.itemName}</span>
                            <span class="text-muted small"><i class="bi bi-upc"></i> ${barcode}</span>
                        </div>
                        <div class="row align-items-center g-2 text-center bg-light rounded-3 py-2 mx-0">
                            <div class="col-4 border-end">
                                <div class="text-muted small">رقم الباتش</div>
                                <div class="fw-bold text-dark">${m.batchNumber}</div>
                            </div>
                            <div class="col-4 border-end">
                                <div class="text-muted small">تاريخ الانتهاء</div>
                                <div class="fw-bold text-danger">${m.expiryDateFormatted}</div>
                            </div>
                            <div class="col-4">
                                <div class="text-muted small">المخزون المتاح</div>
                                <div class="fw-bold text-success">${m.availableQuantity}</div>
                            </div>
                        </div>
                    </div>
                </div>`);

                row.hover(
                    function() { $(this).css('transform', 'scale(1.02)').addClass('shadow'); },
                    function() { $(this).css('transform', 'scale(1)').removeClass('shadow'); }
                );

                row.click(() => {
                    // 1. Precise Batch Aggregation: Check if this specific batch is already in the grid
                    var $existingBatchRow = null;
                    $('#linesBody .erp-line-row').each(function() {
                        if (parseInt($(this).attr('data-batch-id')) === m.batchId) {
                            $existingBatchRow = $(this); return false;
                        }
                    });

                    if ($existingBatchRow) {
                        // Increment quantity, preserve price
                        var $qty = $existingBatchRow.find('.qty-input');
                        $qty.val((parseFloat($qty.val()) || 0) + 1).trigger('change');
                        highlightLine($existingBatchRow);
                        bootstrap.Modal.getInstance(document.getElementById('batchSelectModal')).hide();
                        return;
                    }

                    // 2. Smart "Find or Create" logic for new entries
                    var $targetRow = null; 
                    $('#linesBody .erp-line-row').each(function() {
                        var rowBc = ($(this).attr('data-barcode') || '').trim();
                        var hasItem = $(this).find('.item-select').val();
                        if (rowBc === barcode && !hasItem) {
                            $targetRow = $(this); return false;
                        }
                    });

                    if (!$targetRow) $targetRow = PharmacyTransaction.getActiveRow();

                    var fillData = { 
                        itemId: m.itemId, 
                        itemBatchId: m.batchId,
                        quantity: 1, 
                        barcode: barcode, 
                        sellingPrice: m.defaultSellingPrice 
                    };

                    if ($targetRow) {
                        // Populate existing row
                        $targetRow.attr('data-barcode', barcode);
                        $targetRow.attr('data-item-id', m.itemId);
                        $targetRow.attr('data-batch-id', m.batchId);
                        $targetRow.find('[data-field="Barcode"]').val(barcode);
                        $targetRow.find('[data-field="ItemBatchId"]').val(m.batchId);
                        
                        $targetRow.find('.item-select').val(m.itemId).trigger('change');
                        $targetRow.find('.qty-input').val(1);
                        $targetRow.find('.sale-price-input').val(Number(m.defaultSellingPrice.toFixed(2)));
                        
                        setTimeout(() => refreshFefo($targetRow), 50);
                        highlightLine($targetRow);
                    } else {
                        // Append new row
                        var $newRow = PharmacyTransaction.addRow(fillData);
                        $newRow.attr('data-item-id', m.itemId);
                        $newRow.attr('data-batch-id', m.batchId);
                        $newRow.find('[data-field="ItemBatchId"]').val(m.batchId);
                    }

                    bootstrap.Modal.getInstance(document.getElementById('batchSelectModal')).hide();
                });
                body.append(row);
            });
            var modalEl = document.getElementById('batchSelectModal');
            $(modalEl).find('.modal-dialog').addClass('modal-lg'); // Wider modal for grid
            new bootstrap.Modal(modalEl).show();
        }
    </script>
}
