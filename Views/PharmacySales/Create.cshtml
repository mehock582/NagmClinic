@model NagmClinic.ViewModels.PharmacySaleCreateViewModel

@{
    ViewData["Title"] = "إضافة فاتورة صرف";
    <link href="~/css/pharmacy-transaction.css" rel="stylesheet" />
}

<div class="container-fluid erp-transaction-page py-2">
    <div class="row justify-content-center">
        <div class="col-12">
            <form asp-action="Create" id="saleForm">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 p-2 small border-0 mb-3"></div>

            @* ── Barcode Scanner Zone ── *@
            <div class="barcode-scanner-zone mb-3" id="scannerZone">
                <div class="d-flex align-items-center gap-3">
                    <div class="barcode-scanner-icon">
                        <i class="bi bi-upc-scan"></i>
                    </div>
                    <div class="barcode-input-wrapper">
                        <input type="text" id="barcodeInput"
                               class="form-control"
                               placeholder="امسح الباركود أو أدخله يدوياً ثم اضغط Enter"
                               autocomplete="off" autofocus />
                    </div>
                    <button type="button" class="btn btn-primary rounded-pill px-3" onclick="lookupBarcodeForSale()" title="بحث">
                        <i class="bi bi-search me-1"></i> بحث
                    </button>
                    <div class="d-flex flex-column align-items-center gap-1">
                        <span class="barcode-scan-count" id="scanCount">0</span>
                        <span class="barcode-status-indicator status-ready" id="scanStatus">
                            <i class="bi bi-wifi"></i> جاهز
                        </span>
                    </div>
                </div>
                <div class="mt-2 d-flex align-items-center gap-3">
                    <small class="text-muted"><i class="bi bi-info-circle me-1"></i>يدعم: ماسح USB، بلوتوث، لاسلكي، هاتف كماسح — أي جهاز يرسل النص تلقائياً</small>
                </div>
            </div>

            @* ── Sale Header ── *@
            <div class="card erp-section shadow-sm mb-3">
                <div class="card-body p-3">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-3">
                            <label asp-for="SaleDate" class="erp-label"></label>
                            <input asp-for="SaleDate" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local" class="form-control form-control-sm erp-input" step="60" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="CustomerName" class="erp-label"></label>
                            <input asp-for="CustomerName" class="form-control form-control-sm erp-input" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Notes" class="erp-label"></label>
                            <input asp-for="Notes" class="form-control form-control-sm erp-input" placeholder="ملاحظات اختيارية" />
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn btn-outline-primary btn-sm rounded-pill w-100 mt-2" onclick="PharmacyTransaction.addRow()">
                                <i class="bi bi-plus-lg me-1"></i> إضافة صنف يدوي
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            @* ── Sale Lines ── *@
            <div class="card erp-section shadow-sm mb-3">
                <div class="card-header bg-transparent d-flex justify-content-between align-items-center border-0 pb-0">
                    <h6 class="text-primary fw-bold mb-2"><i class="bi bi-list-check me-2"></i>بنود الصرف (FEFO)</h6>
                </div>
                <div class="card-body p-2" id="linesContainer">
                    <div class="sales-lines-head px-2 py-1 mb-2 rounded-2 d-none d-xl-grid">
                        <span class="head-item">الصنف</span>
                        <span class="head-qty">الكمية</span>
                        <span class="head-price">سعر البيع</span>
                        <span class="head-fefo">المتاح / الباتش / الانتهاء / الموقع</span>
                        <span class="head-total text-end">التقديري</span>
                        <span class="head-action text-center">حذف</span>
                    </div>
                    <div id="linesBody" class="p-1 sales-lines-body"></div>
                    <div id="emptyContainer" class="erp-empty" style="display:none;">
                        <i class="bi bi-basket3 fs-3 d-block mb-2 text-muted"></i>
                        لم يتم إضافة أصناف للصرف بعد.
                        <div id="linesClientValidation" class="text-danger mt-1 fw-bold"></div>
                    </div>
                </div>
            </div>

            @* ── Total ── *@
            <div class="row g-2 mb-3">
                <div class="col-lg-7"></div>
                <div class="col-lg-5">
                    <div class="card border-0 shadow-sm rounded-3 total-box text-white h-100">
                        <div class="card-body p-3 d-flex justify-content-between align-items-center">
                            <div class="text-white-50 fw-bold small"><i class="bi bi-cash-coin me-2"></i>الإجمالي التقديري</div>
                            <div class="text-end">
                                <h2 class="mb-0 fw-bolder"><span id="estimatedTotal">0.00</span> <small class="fs-6 fw-normal op-70">ج.س</small></h2>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-success btn-lg rounded-pill fw-bold px-5 shadow-sm">
                    <i class="bi bi-cloud-arrow-up me-2"></i> حفظ فاتورة الصرف
                </button>
            </div>
        </form>
    </div>
</div>

@* ── Multi-Match Selection Modal ── *@
<div class="modal fade" id="batchSelectModal" tabindex="-1" aria-labelledby="batchSelectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title fw-bold" id="batchSelectModalLabel">
                    <i class="bi bi-boxes me-2 text-primary"></i>تم العثور على أكثر من باتش — اختر الباتش المطلوب
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body p-3" id="batchSelectBody">
                <!-- populated dynamically -->
            </div>
        </div>
    </div>
</div>

<template id="rowTemplate">
    <div class="erp-line-row service-row sale-service-row" id="line_row_{idx}" data-line-index="{idx}">
        <div class="sale-line-grid">
            <div class="sale-line-item">
                <label class="line-field-label line-micro-label">الصنف <span class="text-danger">*</span></label>
                <select id="Lines_{idx}__ItemId" name="Lines[{idx}].ItemId" data-field="ItemId" class="form-select form-select-sm erp-input item-select sale-item-select" required data-val="true" data-val-range="يرجى اختيار الصنف" data-val-range-min="1" data-val-range-max="2147483647">
                    <option value="">-- اختر الصنف --</option>
                    {options}
                </select>
                <span class="text-danger small field-validation-valid field-validation-inline" data-valmsg-for="Lines[{idx}].ItemId" data-valmsg-replace="true" data-valmsg-field="ItemId"></span>
            </div>
            <div class="sale-line-qty">
                <label class="line-field-label line-micro-label">الكمية <span class="text-danger">*</span></label>
                <input id="Lines_{idx}__Quantity" name="Lines[{idx}].Quantity" data-field="Quantity" type="number" class="form-control form-control-sm erp-input qty-input sale-qty-input text-center" value="1" min="0.01" step="0.01" required data-val="true" data-val-number="قيمة الكمية غير صحيحة" data-val-required="الكمية مطلوبة" data-val-range="الكمية يجب أن تكون أكبر من صفر" data-val-range-min="0.01" data-val-range-max="999999" />
                <span class="text-danger small field-validation-valid field-validation-inline" data-valmsg-for="Lines[{idx}].Quantity" data-valmsg-replace="true" data-valmsg-field="Quantity"></span>
            </div>
            <div class="sale-line-price">
                <label class="line-field-label line-micro-label">سعر البيع <span class="text-danger">*</span></label>
                <input id="Lines_{idx}__SellingPrice" name="Lines[{idx}].SellingPrice" data-field="SellingPrice" type="number" class="form-control form-control-sm erp-input sale-price-input text-center" value="0.00" min="0.01" step="0.01" required data-val="true" data-val-number="قيمة سعر البيع غير صحيحة" data-val-required="سعر البيع مطلوب" data-val-range="سعر البيع يجب أن يكون أكبر من صفر" data-val-range-min="0.01" data-val-range-max="999999" />
                <span class="text-danger small field-validation-valid field-validation-inline" data-valmsg-for="Lines[{idx}].SellingPrice" data-valmsg-replace="true" data-valmsg-field="SellingPrice"></span>
            </div>
            <div class="sale-line-fefo">
                <span class="line-field-label line-micro-label">تفاصيل FEFO</span>
                <div class="sale-fefo-badges">
                    <div class="fefo-chip fefo-chip-stock">
                        <span class="fefo-chip-label"><i class="bi bi-box-seam"></i> المتاح</span>
                        <span class="available-info">-</span>
                    </div>
                    <div class="fefo-chip fefo-chip-batch">
                        <span class="fefo-chip-label"><i class="bi bi-upc"></i> الباتش</span>
                        <span class="batch-info">-</span>
                    </div>
                </div>
                <div class="sale-fefo-meta">
                    <div class="sale-fefo-meta-item">
                        <span class="meta-label"><i class="bi bi-calendar3"></i> الانتهاء</span>
                        <span class="expiry-info">-</span>
                    </div>
                    <div class="sale-fefo-meta-item">
                        <span class="meta-label"><i class="bi bi-geo-alt"></i> الموقع</span>
                        <span class="slot-info">-</span>
                    </div>
                </div>
            </div>
            <div class="sale-line-total text-end">
                <span class="line-field-label line-micro-label">التقديري</span>
                <div class="line-est-total-wrap">
                    <span class="line-est-total line-total-display">0.00</span>
                    <small class="line-currency">ج.س</small>
                </div>
            </div>
            <div class="sale-line-actions">
                <button type="button" class="btn btn-sm btn-outline-secondary rounded-circle btn-remove-line line-delete-btn" title="حذف الصنف">
                    <i class="bi bi-trash3"></i>
                </button>
            </div>
        </div>
    </div>
</template>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pharmacy-transaction.js"></script>
    <script src="~/js/barcode-scanner.js"></script>
    <script>
        var itemLookup = @Html.Raw(Json.Serialize(Model.ItemLookup));
        var totalScans = 0;

        // ── Status indicator helpers ──
        function setStatus(type, text) {
            var el = $('#scanStatus');
            el.removeClass('status-ready status-success status-error');
            el.addClass('status-' + type);
            if (type === 'ready') el.html('<i class="bi bi-wifi"></i> ' + (text || 'جاهز'));
            else if (type === 'success') el.html('<i class="bi bi-check-circle-fill"></i> ' + (text || 'تمت الإضافة'));
            else if (type === 'error') el.html('<i class="bi bi-exclamation-triangle-fill"></i> ' + (text || 'غير موجود'));

            if (type !== 'ready') {
                setTimeout(() => setStatus('ready'), 2500);
            }
        }

        function flashZone(type) {
            var zone = $('#scannerZone');
            zone.addClass('barcode-flash-' + type);
            setTimeout(() => zone.removeClass('barcode-flash-success barcode-flash-error'), 600);
        }

        function updateScanCount() {
            var el = $('#scanCount');
            var count = PharmacyTransaction.getLineCount();
            el.text(count);
            if (count > 0) el.addClass('has-items'); else el.removeClass('has-items');
        }

        function formatNumber(val, digits) {
            var num = parseFloat(val);
            if (isNaN(num)) return '0.00';
            return num.toLocaleString('en-US', { minimumFractionDigits: digits || 2, maximumFractionDigits: digits || 2 });
        }

        function normalizeDate(dateStr) {
            if (!dateStr) return '-';
            if (typeof dateStr === 'string' && dateStr.length >= 10) return dateStr.substring(0, 10);
            var d = new Date(dateStr);
            if (isNaN(d.getTime())) return '-';
            return d.toISOString().substring(0, 10);
        }

        function daysUntil(dateStr) {
            if (!dateStr) return null;
            var d = new Date(dateStr);
            if (isNaN(d.getTime())) return null;
            var today = new Date();
            today.setHours(0, 0, 0, 0);
            d.setHours(0, 0, 0, 0);
            return Math.ceil((d - today) / 86400000);
        }

        function updateEstimatedTotalQuick() {
            var total = 0;
            $('#linesBody .line-est-total').each(function () {
                var numeric = parseFloat(($(this).text() || '0').replace(/,/g, ''));
                if (!isNaN(numeric)) total += numeric;
            });
            $('#estimatedTotal').text(formatNumber(total));
        }

        function getItemDefaultPrice(itemId) {
            var id = parseInt(itemId);
            if (!id) return 0;
            var found = itemLookup.find(function (i) { return parseInt(i.id) === id; });
            if (!found) return 0;
            var parsed = parseFloat(found.defaultSellingPrice || found.DefaultSellingPrice || 0);
            return isNaN(parsed) ? 0 : parsed;
        }

        function updateLineEstimatedTotal($row) {
            var qty = parseFloat($row.find('.qty-input').val()) || 0;
            var price = parseFloat($row.find('.sale-price-input').val()) || 0;
            var lineTotal = qty > 0 && price > 0 ? qty * price : 0;
            $row.find('.line-est-total').text(formatNumber(lineTotal));
            return lineTotal;
        }

        function ensureSellingPrice($row, fallbackPrice) {
            var current = parseFloat($row.find('.sale-price-input').val()) || 0;
            var price = parseFloat(fallbackPrice) || 0;
            if (current <= 0 && price > 0) {
                $row.find('.sale-price-input').val(price.toFixed(2));
            }
        }

        function resetFefoDisplay($row) {
            $row.removeClass('is-low-stock is-near-expiry is-no-batch');
            $row.removeData('fefoKey');
            $row.find('.available-info').text('-');
            $row.find('.batch-info').html('-');
            $row.find('.expiry-info').text('-');
            $row.find('.slot-info').text('-');
            updateLineEstimatedTotal($row);
            updateEstimatedTotalQuick();
        }

        function highlightLine($row, className) {
            if (!$row || !$row.length) return;
            $row.removeClass('line-added-highlight line-scan-highlight');
            $row.addClass(className || 'line-added-highlight');
            setTimeout(function () {
                $row.removeClass('line-added-highlight line-scan-highlight');
            }, 1200);
        }

        // ── Init ──
        $(function () {
            // Setup generic pharmacy transaction
            PharmacyTransaction.init({
                mode: 'sale',
                formId: '#saleForm',
                tableBodyId: '#linesBody',
                emptyContainerId: '#emptyContainer',
                subTotalId: null, // Subtotal is essentially Estimated total
                grandTotalId: '#estimatedTotal',
                emptyValidationMessage: 'يجب اختيار صنف واحد على الأقل للصرف',
                callbacks: {
                    calculateLineTotal: function ($row) {
                        refreshFefo($row);
                    },
                    onRowAdded: function ($newRow, prefillData, idx) {
                        const options = itemLookup.map(i => `<option value="${i.id}">${i.name}</option>`).join('');
                        $newRow.html($newRow.html().replace('{options}', options));
                        
                        if (prefillData && prefillData.itemId) {
                            $newRow.find('.item-select').val(prefillData.itemId);
                        }
                        if (prefillData && prefillData.quantity) {
                            $newRow.find('.qty-input').val(prefillData.quantity);
                        }
                        if (prefillData && prefillData.sellingPrice) {
                            $newRow.find('.sale-price-input').val(parseFloat(prefillData.sellingPrice).toFixed(2));
                        }
                        if (prefillData && prefillData.barcode) {
                            $newRow.attr('data-barcode', prefillData.barcode);
                        }

                        ensureSellingPrice($newRow, getItemDefaultPrice($newRow.find('.item-select').val()));

                        refreshFefo($newRow);
                        highlightLine($newRow, 'line-added-highlight');
                        
                        updateScanCount();
                    },
                    onRowRemoved: function() {
                        updateScanCount();
                        updateEstimatedTotalQuick();
                    }
                }
            });

            if ($('#linesBody .erp-line-row').length === 0) {
                PharmacyTransaction.addRow({ quantity: 1 });
            }

            setTimeout(() => $('#barcodeInput').focus(), 200);

            $('#barcodeInput').on('keydown', function (e) {
                if (e.key === 'Enter' || e.which === 13) {
                    e.preventDefault();
                    e.stopPropagation();
                    lookupBarcodeForSale();
                }
            });

            $('#saleForm').on('keydown', function (e) {
                if ((e.key === 'Enter' || e.which === 13) && e.target.id === 'barcodeInput') {
                    e.preventDefault();
                }
            });

            $('#linesBody').on('change', '.item-select', function () {
                var $row = $(this).closest('.erp-line-row');
                ensureSellingPrice($row, getItemDefaultPrice($(this).val()));
                updateLineEstimatedTotal($row);
                updateEstimatedTotalQuick();
            });
        });

        function resolveSaleRow(rowOrIndex) {
            if (!rowOrIndex && rowOrIndex !== 0) return $();
            if (rowOrIndex.jquery) return rowOrIndex;
            if (typeof rowOrIndex === 'number' || /^\d+$/.test(rowOrIndex)) {
                return $('#line_row_' + rowOrIndex);
            }
            return $(rowOrIndex).closest('.erp-line-row');
        }

        // ── FEFO preview ──
        function refreshFefo(rowOrIndex) {
            var $row = resolveSaleRow(rowOrIndex);
            if (!$row.length) return;

            const itemId = parseInt($row.find('.item-select').val());
            const qty = parseFloat($row.find('.qty-input').val()) || 0;

            if (!itemId || qty <= 0) {
                resetFefoDisplay($row);
                return;
            }

            var fefoKey = itemId + '|' + qty.toFixed(2);
            if ($row.data('fefoKey') === fefoKey) {
                updateLineEstimatedTotal($row);
                updateEstimatedTotalQuick();
                return;
            }
            $row.data('fefoKey', fefoKey);

            $.get('/PharmacySales/PreviewFefo', { itemId: itemId, quantity: qty }, function (res) {
                $row.removeClass('is-low-stock is-near-expiry is-no-batch');

                var available = parseFloat(res.available || 0) || 0;
                $row.find('.available-info').text(formatNumber(available));
                if (available < qty) {
                    $row.addClass('is-low-stock');
                }

                if (!res.success || !res.allocations || res.allocations.length === 0) {
                    $row.addClass('is-no-batch');
                    $row.find('.batch-info').html('<span class="fefo-empty">غير متاح</span>');
                    $row.find('.expiry-info').text('-');
                    $row.find('.slot-info').text('-');
                } else {
                    var batchHtml = [];
                    var exps = [];
                    var slots = [];
                    var nearExpiry = false;

                    res.allocations.forEach(function (a) {
                        if (a.batchNumber && !batchHtml.includes(a.batchNumber)) {
                            batchHtml.push(a.batchNumber);
                        }
                        var expiry = normalizeDate(a.expiryDate);
                        if (expiry !== '-' && !exps.includes(expiry)) {
                            exps.push(expiry);
                            var d = daysUntil(expiry);
                            if (d !== null && d <= 60) nearExpiry = true;
                        }
                        if (a.slotCode && !slots.includes(a.slotCode)) slots.push(a.slotCode);
                    });

                    if (nearExpiry) {
                        $row.addClass('is-near-expiry');
                    }

                    var batchesMarkup = batchHtml.length
                        ? batchHtml.map(function (b) { return `<span class="fefo-badge fefo-badge-primary">${b}</span>`; }).join('')
                        : '<span class="fefo-empty">-</span>';

                    $row.find('.batch-info').html(batchesMarkup);
                    $row.find('.expiry-info').html(exps.length ? exps.join(' / ') : '-');
                    $row.find('.slot-info').html(slots.length ? slots.join(' / ') : '-');
                }
                updateLineEstimatedTotal($row);
                updateEstimatedTotalQuick();
            }).fail(function () {
                resetFefoDisplay($row);
            });
        }

        // ── Barcode Lookup (Main Scanner Logic) ──
        function lookupBarcodeForSale() {
            const barcode = ($('#barcodeInput').val() || '').trim();
            if (!barcode) return;

            BarcodeScanner.processScan(barcode, {
                lookupUrl: '/PharmacySales/LookupByBarcode',
                findRowByBarcode: function(bc) {
                    var $found = null;
                    $('#linesBody > .erp-line-row').each(function () {
                        var rowBc = ($(this).attr('data-barcode') || '').trim();
                        if (rowBc.toLowerCase() === bc.toLowerCase() && rowBc !== '') {
                            $found = $(this);
                            return false;
                        }
                    });
                    return $found;
                },
                findActiveOrEmptyRow: function () {
                    var active = $('.sale-service-row :focus').closest('.sale-service-row');
                    if (active.length) return active;

                    var empty = null;
                    $('#linesBody > .erp-line-row').each(function () {
                        if (!$(this).find('.item-select').val()) {
                            empty = $(this);
                            return false;
                        }
                    });
                    return empty;
                },
                fillRow: function ($row, data, bc) {
                    $row.attr('data-barcode', bc);
                    $row.find('.item-select').val(data.itemId);
                    $row.find('.qty-input').val(1);
                    ensureSellingPrice($row, data.defaultSellingPrice || getItemDefaultPrice(data.itemId));
                    refreshFefo($row);
                    highlightLine($row, 'line-scan-highlight');
                },
                incrementQuantity: incrementLineQuantity,
                addRowWithData: function(data, bc) {
                    PharmacyTransaction.addRow({
                        itemId: data.itemId,
                        quantity: 1,
                        barcode: bc,
                        sellingPrice: data.defaultSellingPrice || getItemDefaultPrice(data.itemId)
                    });
                },
                onMultiMatch: function(matches, bc) {
                    showBatchSelectionModal(matches, bc);
                },
                onSuccess: function(type, $row, bc, data) {
                    if (type === 'increment') {
                        var select = $row.find('.item-select');
                        var itemName = select.find('option:selected').text();
                        setStatus('success', '+1 ' + itemName);
                    } else if (data) {
                        setStatus('success', data.itemName);
                    }
                    flashZone('success');
                    totalScans++;
                    clearAndRefocusBarcode();
                },
                onError: function(type, bc) {
                    if (type === 'not_found') {
                        setStatus('error', 'غير موجود');
                        flashZone('error');
                    }
                    clearAndRefocusBarcode();
                }
            });
        }

        // ── Find existing line by ItemId ──
        function findExistingLineByItemId(itemId) {
            var found = null;
            $('#linesBody > .erp-line-row').each(function () {
                var select = $(this).find('.item-select');
                if (parseInt(select.val()) === itemId) {
                    found = $(this);
                    return false;
                }
            });
            return found;
        }

        // ── Increment quantity on existing line ──
        function incrementLineQuantity(row) {
            var qtyInput = row.find('.qty-input');
            var currentQty = parseFloat(qtyInput.val()) || 0;
            qtyInput.val((currentQty + 1).toFixed(2));
            qtyInput.trigger('change');
            highlightLine(row, 'line-scan-highlight');

            // Refresh FEFO for updated qty
            refreshFefo(row);
            updateScanCount();
        }

        // Compatibility helper for legacy calls like refreshFefo(index)
        function refreshFefoByIndex(index) {
            var $row = resolveSaleRow(index);
            if ($row.length) {
                refreshFefo($row);
            }
        }

        // Compatibility helper for legacy removeLine(index) usage
        function removeLine(index) {
            var $row = $('#line_row_' + index);
            if ($row.length) {
                $row.find('.btn-remove-line').trigger('click');
            }
        }

        // ── Multi-match batch selection modal ──
        function showBatchSelectionModal(matches, barcodeScanned) {
            var body = $('#batchSelectBody');
            body.empty();

            matches.forEach(function (m) {
                var expiryStr = m.suggestedBatch ? m.suggestedBatch.expiryDate.substring(0, 10) : '-';
                var remaining = m.suggestedBatch ? m.suggestedBatch.quantity : 0;
                var card = $(`
                    <div class="batch-match-card mb-2" data-item-id="${m.itemId}">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="batch-match-name">${m.itemName}</div>
                                <div class="batch-match-meta">
                                    <i class="bi bi-box-seam me-1"></i>باتش: ${m.batchNumber}
                                    · <i class="bi bi-calendar3 me-1"></i>الانتهاء: ${expiryStr}
                                    · <i class="bi bi-archive me-1"></i>المتبقي: ${remaining}
                                </div>
                            </div>
                            <div class="text-end">
                                <div class="fw-bold text-primary">${m.defaultSellingPrice.toFixed(2)}</div>
                                <div class="small text-muted">${m.slotCode}</div>
                            </div>
                        </div>
                    </div>
                `);

                card.on('click', function () {
                    var existingRow = findExistingLineByItemId(m.itemId);
                    if (existingRow) {
                        incrementLineQuantity(existingRow);
                        BarcodeScanner.beepIncrement();
                        setStatus('success', '+1 ' + m.itemName);
                    } else {
                        PharmacyTransaction.addRow({
                            itemId: m.itemId,
                            quantity: 1,
                            barcode: barcodeScanned,
                            sellingPrice: m.defaultSellingPrice || getItemDefaultPrice(m.itemId)
                        });
                        BarcodeScanner.beepSuccess();
                        setStatus('success', m.itemName);
                    }
                    flashZone('success');
                    totalScans++;
                    bootstrap.Modal.getInstance(document.getElementById('batchSelectModal')).hide();
                    setTimeout(() => $('#barcodeInput').focus(), 200);
                });

                body.append(card);
            });

            var modal = new bootstrap.Modal(document.getElementById('batchSelectModal'));
            modal.show();

            // When modal closes, refocus barcode
            document.getElementById('batchSelectModal').addEventListener('hidden.bs.modal', function () {
                $('#barcodeInput').focus();
            }, { once: true });
        }

        // ── Clear barcode input and return focus ──
        function clearAndRefocusBarcode() {
            $('#barcodeInput').val('');
            setTimeout(() => $('#barcodeInput').focus(), 50);
        }

    </script>
}
