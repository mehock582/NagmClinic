@model NagmClinic.ViewModels.PharmacySaleCreateViewModel

@{
    ViewData["Title"] = "إضافة فاتورة صرف";
}

<div class="row justify-content-center">
    <div class="col-12 reception-container">
        <form asp-action="Create" id="saleForm">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 p-2 small border-0 mb-3"></div>

            @* ── Barcode Scanner Zone ── *@
            <div class="barcode-scanner-zone mb-3" id="scannerZone">
                <div class="d-flex align-items-center gap-3">
                    <div class="barcode-scanner-icon">
                        <i class="bi bi-upc-scan"></i>
                    </div>
                    <div class="barcode-input-wrapper">
                        <input type="text" id="barcodeInput"
                               class="form-control"
                               placeholder="امسح الباركود أو أدخله يدوياً ثم اضغط Enter"
                               autocomplete="off" autofocus />
                    </div>
                    <button type="button" class="btn btn-primary rounded-pill px-3" onclick="lookupBarcodeForSale()" title="بحث">
                        <i class="bi bi-search me-1"></i> بحث
                    </button>
                    <div class="d-flex flex-column align-items-center gap-1">
                        <span class="barcode-scan-count" id="scanCount">0</span>
                        <span class="barcode-status-indicator status-ready" id="scanStatus">
                            <i class="bi bi-wifi"></i> جاهز
                        </span>
                    </div>
                </div>
                <div class="mt-2 d-flex align-items-center gap-3">
                    <small class="text-muted"><i class="bi bi-info-circle me-1"></i>يدعم: ماسح USB، بلوتوث، لاسلكي، هاتف كماسح — أي جهاز يرسل النص تلقائياً</small>
                </div>
            </div>

            @* ── Sale Header ── *@
            <div class="card border-0 shadow-sm rounded-3 mb-3">
                <div class="card-body p-3">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-3">
                            <label asp-for="SaleDate" class="form-label small fw-bold"></label>
                            <input asp-for="SaleDate" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local" class="form-control form-control-sm" step="60" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="CustomerName" class="form-label small fw-bold"></label>
                            <input asp-for="CustomerName" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Notes" class="form-label small fw-bold"></label>
                            <input asp-for="Notes" class="form-control form-control-sm" placeholder="ملاحظات اختيارية" />
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn btn-outline-primary btn-sm rounded-pill w-100" onclick="addLine()">
                                <i class="bi bi-plus-lg me-1"></i> إضافة بند يدوي
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            @* ── Sale Lines (FEFO) ── *@
            <div class="card border-0 shadow-sm rounded-3 mb-3">
                <div class="card-body p-3">
                    <h6 class="text-primary fw-bold mb-2"><i class="bi bi-list-check me-2"></i>بنود الصرف (FEFO)</h6>
                    <div id="linesBody"></div>
                </div>
            </div>

            @* ── Total ── *@
            <div class="row g-2 mb-3">
                <div class="col-lg-7"></div>
                <div class="col-lg-5">
                    <div class="card border-0 shadow-sm rounded-3 total-box text-white h-100">
                        <div class="card-body p-3 d-flex justify-content-between align-items-center">
                            <div class="text-white-50 fw-bold small"><i class="bi bi-cash-coin me-2"></i>الإجمالي التقديري</div>
                            <div class="text-end">
                                <h2 class="mb-0 fw-bolder"><span id="estimatedTotal">0.00</span> <small class="fs-6 fw-normal op-70">ج.س</small></h2>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-success btn-lg rounded-pill fw-bold px-5 shadow-sm">
                    <i class="bi bi-cloud-arrow-up me-2"></i> حفظ فاتورة الصرف
                </button>
            </div>
        </form>
    </div>
</div>

@* ── Multi-Match Selection Modal ── *@
<div class="modal fade" id="batchSelectModal" tabindex="-1" aria-labelledby="batchSelectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title fw-bold" id="batchSelectModalLabel">
                    <i class="bi bi-boxes me-2 text-primary"></i>تم العثور على أكثر من باتش — اختر الباتش المطلوب
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body p-3" id="batchSelectBody">
                <!-- populated dynamically -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var itemLookup = @Html.Raw(Json.Serialize(Model.ItemLookup));
        var lineCount = 0;
        var totalScans = 0;

        // ── Audio feedback (Web Audio API — no external files) ──
        var audioCtx = null;
        function playBeep(freq, duration, type) {
            try {
                if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                var osc = audioCtx.createOscillator();
                var gain = audioCtx.createGain();
                osc.connect(gain);
                gain.connect(audioCtx.destination);
                osc.type = type || 'sine';
                osc.frequency.value = freq || 800;
                gain.gain.value = 0.12;
                osc.start();
                osc.stop(audioCtx.currentTime + (duration || 0.12));
            } catch (e) { /* audio not supported */ }
        }
        function beepSuccess() { playBeep(880, 0.1, 'sine'); setTimeout(() => playBeep(1100, 0.12, 'sine'), 110); }
        function beepError() { playBeep(300, 0.25, 'square'); }
        function beepIncrement() { playBeep(660, 0.08, 'sine'); }

        // ── Status indicator helpers ──
        function setStatus(type, text) {
            var el = $('#scanStatus');
            el.removeClass('status-ready status-success status-error');
            el.addClass('status-' + type);
            if (type === 'ready') el.html('<i class="bi bi-wifi"></i> ' + (text || 'جاهز'));
            else if (type === 'success') el.html('<i class="bi bi-check-circle-fill"></i> ' + (text || 'تمت الإضافة'));
            else if (type === 'error') el.html('<i class="bi bi-exclamation-triangle-fill"></i> ' + (text || 'غير موجود'));

            if (type !== 'ready') {
                setTimeout(() => setStatus('ready'), 2500);
            }
        }

        function flashZone(type) {
            var zone = $('#scannerZone');
            zone.addClass('barcode-flash-' + type);
            setTimeout(() => zone.removeClass('barcode-flash-success barcode-flash-error'), 600);
        }

        function updateScanCount() {
            var el = $('#scanCount');
            var count = $('#linesBody > .row').length;
            el.text(count);
            if (count > 0) el.addClass('has-items'); else el.removeClass('has-items');
        }

        // ── Init ──
        $(function () {
            // Focus barcode input on page load
            setTimeout(() => $('#barcodeInput').focus(), 200);

            // Listen for barcode input (Enter key = scanner suffix or manual submit)
            $('#barcodeInput').on('keydown', function (e) {
                if (e.key === 'Enter' || e.which === 13) {
                    e.preventDefault();
                    e.stopPropagation();
                    lookupBarcodeForSale();
                }
            });

            // Prevent form submit when barcode input is focused and Enter is pressed
            $('#saleForm').on('keydown', function (e) {
                if ((e.key === 'Enter' || e.which === 13) && e.target.id === 'barcodeInput') {
                    e.preventDefault();
                }
            });
        });

        // ── Add a sale line ──
        function addLine(prefill) {
            const idx = lineCount;
            const options = itemLookup.map(i => `<option value="${i.id}">${i.name}</option>`).join('');
            const row = `
                <div class="row g-2 p-2 align-items-end bg-light rounded-2 border service-row mb-1" id="line_${idx}">
                    <div class="col-lg-4 col-md-6">
                        <label class="form-label small fw-bold">الصنف</label>
                        <select name="Lines[${idx}].ItemId" data-field="ItemId" class="form-select form-select-sm item-select" onchange="refreshFefo(${idx})" required>
                            <option value="">-- اختر الصنف --</option>
                            ${options}
                        </select>
                    </div>
                    <div class="col-lg-1 col-md-3">
                        <label class="form-label small fw-bold">الكمية</label>
                        <input type="number" name="Lines[${idx}].Quantity" data-field="Quantity" class="form-control form-control-sm qty-input text-center" value="1" min="0.01" step="0.01" onchange="refreshFefo(${idx})" />
                    </div>
                    <div class="col-lg-2 col-md-3">
                        <label class="form-label small fw-bold">المتاح</label>
                        <div class="fw-bold text-dark available-info">-</div>
                    </div>
                    <div class="col-lg-2 col-md-3">
                        <label class="form-label small fw-bold">الباتش المقترح</label>
                        <div class="fw-bold text-primary batch-info">-</div>
                    </div>
                    <div class="col-lg-1 col-md-3">
                        <label class="form-label small fw-bold">الانتهاء</label>
                        <div class="small expiry-info">-</div>
                    </div>
                    <div class="col-lg-1 col-md-3">
                        <label class="form-label small fw-bold">الموقع</label>
                        <div class="small slot-info">-</div>
                    </div>
                    <div class="col-lg-1 col-md-3">
                        <label class="form-label small fw-bold">تقديري</label>
                        <div class="fw-bold text-success line-est-total">0.00</div>
                    </div>
                    <div class="col-lg-1 col-md-3 text-end">
                        <button type="button" class="btn btn-link link-danger p-0 border-0" onclick="removeLine(${idx})"><i class="bi bi-x-circle-fill fs-5"></i></button>
                    </div>
                </div>`;

            $('#linesBody').append(row);
            if (prefill && prefill.itemId) {
                $(`#line_${idx} .item-select`).val(prefill.itemId);
                if (prefill.quantity) $(`#line_${idx} .qty-input`).val(prefill.quantity);
            }
            lineCount++;
            refreshFefo(idx);
            updateScanCount();
            return idx;
        }

        function removeLine(idx) {
            $(`#line_${idx}`).fadeOut(120, function () {
                $(this).remove();
                recalcEstimatedTotal();
                updateScanCount();
            });
        }

        // ── FEFO preview ──
        function refreshFefo(idx) {
            const row = $(`#line_${idx}`);
            const itemId = parseInt(row.find('.item-select').val());
            const qty = parseFloat(row.find('.qty-input').val()) || 0;

            row.find('.line-est-total').text('0.00');
            if (!itemId || qty <= 0) {
                row.find('.available-info,.batch-info,.expiry-info,.slot-info').text('-');
                recalcEstimatedTotal();
                return;
            }

            $.get('/PharmacySales/PreviewFefo', { itemId: itemId, quantity: qty }, function (res) {
                row.find('.available-info').text((res.available || 0).toFixed ? res.available.toFixed(2) : res.available);
                if (!res.success || !res.allocations || res.allocations.length === 0) {
                    row.find('.batch-info').html('<span class="text-danger">غير متاح</span>');
                    row.find('.expiry-info').text('-');
                    row.find('.slot-info').text('-');
                    row.find('.line-est-total').text('0.00');
                    recalcEstimatedTotal();
                    return;
                }

                const first = res.allocations[0];
                row.find('.batch-info').text(first.batchNumber);
                row.find('.expiry-info').text(first.expiryDate.substring(0, 10));
                row.find('.slot-info').text(first.slotCode);

                let lineTotal = 0;
                res.allocations.forEach(a => lineTotal += (parseFloat(a.quantity) || 0) * (parseFloat(a.unitPrice) || 0));
                row.find('.line-est-total').text(lineTotal.toFixed(2));
                recalcEstimatedTotal();
            });
        }

        function recalcEstimatedTotal() {
            let total = 0;
            $('.line-est-total').each(function () {
                total += parseFloat($(this).text()) || 0;
            });
            $('#estimatedTotal').text(total.toFixed(2));
        }

        // ── Barcode Lookup (Main Scanner Logic) ──
        function lookupBarcodeForSale() {
            const barcode = ($('#barcodeInput').val() || '').trim();
            if (!barcode) return;

            // Check if this item already exists in the cart — auto-increment quantity
            var existingLine = findExistingLineByItemBarcode(barcode);

            $.get('/PharmacySales/LookupByBarcode', { barcode: barcode }, function (res) {
                if (!res.success) {
                    // Not found
                    beepError();
                    setStatus('error', 'غير موجود');
                    flashZone('error');
                    Swal.fire({
                        icon: 'warning',
                        title: 'لم يتم العثور على دواء بهذا الباركود',
                        text: barcode,
                        timer: 2000,
                        showConfirmButton: false
                    });
                    clearAndRefocusBarcode();
                    return;
                }

                if (res.multiMatch) {
                    // Multiple batches found — show selection modal
                    showBatchSelectionModal(res.matches);
                    clearAndRefocusBarcode();
                    return;
                }

                // Single match — check if already in cart
                var existingRow = findExistingLineByItemId(res.data.itemId);
                if (existingRow) {
                    // Increment quantity
                    incrementLineQuantity(existingRow);
                    beepIncrement();
                    setStatus('success', '+1 ' + res.data.itemName);
                    flashZone('success');
                } else {
                    // Add new line
                    addLine({ itemId: res.data.itemId, quantity: 1 });
                    beepSuccess();
                    setStatus('success', res.data.itemName);
                    flashZone('success');
                }

                totalScans++;
                clearAndRefocusBarcode();

                // Quick toast confirmation
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'success',
                    title: res.data.itemName,
                    html: `<span class="small text-muted">${res.data.unitName} · المتاح: ${res.data.availableQuantity} · ${res.data.slotCode}</span>`,
                    timer: 1200,
                    showConfirmButton: false,
                    timerProgressBar: true
                });
            }).fail(function () {
                beepError();
                setStatus('error', 'خطأ في الاتصال');
                flashZone('error');
                clearAndRefocusBarcode();
            });
        }

        // ── Find existing line by ItemId (for auto-increment) ──
        function findExistingLineByItemId(itemId) {
            var found = null;
            $('#linesBody > .row').each(function () {
                var select = $(this).find('.item-select');
                if (parseInt(select.val()) === itemId) {
                    found = $(this);
                    return false; // break
                }
            });
            return found;
        }

        function findExistingLineByItemBarcode(barcode) {
            // This is resolved server-side; we only use findExistingLineByItemId after lookup
            return null;
        }

        // ── Increment quantity on existing line ──
        function incrementLineQuantity(row) {
            var qtyInput = row.find('.qty-input');
            var currentQty = parseFloat(qtyInput.val()) || 0;
            qtyInput.val((currentQty + 1).toFixed(2));

            // Flash the row
            row.css('background-color', '#dcfce7');
            setTimeout(() => row.css('background-color', ''), 400);

            // Refresh FEFO for updated qty
            var lineId = row.attr('id').replace('line_', '');
            refreshFefo(parseInt(lineId));
            updateScanCount();
        }

        // ── Multi-match batch selection modal ──
        function showBatchSelectionModal(matches) {
            var body = $('#batchSelectBody');
            body.empty();

            matches.forEach(function (m) {
                var expiryStr = m.suggestedBatch ? m.suggestedBatch.expiryDate.substring(0, 10) : '-';
                var remaining = m.suggestedBatch ? m.suggestedBatch.quantity : 0;
                var card = $(`
                    <div class="batch-match-card mb-2" data-item-id="${m.itemId}">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="batch-match-name">${m.itemName}</div>
                                <div class="batch-match-meta">
                                    <i class="bi bi-box-seam me-1"></i>باتش: ${m.batchNumber}
                                    · <i class="bi bi-calendar3 me-1"></i>الانتهاء: ${expiryStr}
                                    · <i class="bi bi-archive me-1"></i>المتبقي: ${remaining}
                                </div>
                            </div>
                            <div class="text-end">
                                <div class="fw-bold text-primary">${m.defaultSellingPrice.toFixed(2)}</div>
                                <div class="small text-muted">${m.slotCode}</div>
                            </div>
                        </div>
                    </div>
                `);

                card.on('click', function () {
                    var existingRow = findExistingLineByItemId(m.itemId);
                    if (existingRow) {
                        incrementLineQuantity(existingRow);
                        beepIncrement();
                        setStatus('success', '+1 ' + m.itemName);
                    } else {
                        addLine({ itemId: m.itemId, quantity: 1 });
                        beepSuccess();
                        setStatus('success', m.itemName);
                    }
                    flashZone('success');
                    totalScans++;
                    bootstrap.Modal.getInstance(document.getElementById('batchSelectModal')).hide();
                    setTimeout(() => $('#barcodeInput').focus(), 200);
                });

                body.append(card);
            });

            var modal = new bootstrap.Modal(document.getElementById('batchSelectModal'));
            modal.show();

            // When modal closes, refocus barcode
            document.getElementById('batchSelectModal').addEventListener('hidden.bs.modal', function () {
                $('#barcodeInput').focus();
            }, { once: true });
        }

        // ── Clear barcode input and return focus ──
        function clearAndRefocusBarcode() {
            $('#barcodeInput').val('');
            setTimeout(() => $('#barcodeInput').focus(), 50);
        }

        // ── Reindex lines before submit ──
        function reindexSaleLines() {
            $('#linesBody > .row').each(function (rowIndex) {
                $(this).find('[data-field]').each(function () {
                    const field = $(this).data('field');
                    $(this).attr('name', `Lines[${rowIndex}].${field}`);
                });
            });
        }

        $('#saleForm').on('submit', function () {
            reindexSaleLines();
        });
    </script>
}
