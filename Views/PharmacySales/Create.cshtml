@model NagmClinic.ViewModels.PharmacySaleCreateViewModel

@{
    ViewData["Title"] = "إضافة فاتورة صرف POS";
    <link href="~/css/pharmacy-transaction.css" rel="stylesheet" />
}

<div class="container-fluid erp-transaction-page px-0">
    <form asp-action="Create" id="saleForm" novalidate>
        @Html.AntiForgeryToken()
        
        @* ── POS Header: Scanner & Fixed Controls ── *@
        <div class="pos-header-container sticky-top py-3 px-4 mb-4">
            <div class="row align-items-center g-3">
                <div class="col-xl-7">
                    <div class="pos-scanner-zone" id="scannerZone">
                        <div class="pos-scanner-icon-btn">
                            <i class="bi bi-upc-scan"></i>
                        </div>
                        <div class="pos-scanner-input-wrap">
                            <input type="text" id="barcodeInput"
                                   class="pos-scanner-input"
                                   placeholder="امسح الباركود أو أدخله يدوياً ثم اضغط Enter"
                                   autocomplete="off" />
                        </div>
                        <button type="button" class="btn btn-primary rounded-pill px-4 fw-bold" onclick="lookupBarcodeForSale()">بحث</button>
                        <div class="pos-status-badge ms-2" id="scanStatus">
                            <i class="bi bi-wifi"></i> جاهز
                        </div>
                    </div>
                    <div class="mt-2 text-muted ps-2 d-none d-md-block" style="font-size: 0.75rem;">
                        <i class="bi bi-info-circle me-1 text-primary"></i> يدعم: ماسح USB، بلوتوث، لاسلكي، هاتف كماسح — أي جهاز يرسل النص يدوياً.
                    </div>
                </div>
                <div class="col-xl-5 text-end">
                    <div class="d-flex justify-content-end align-items-center gap-2">
                        <div class="badge bg-primary-subtle text-primary border border-primary px-3 py-2 rounded-pill fw-bold">
                            <i class="bi bi-cart4 me-2"></i>عدد البنود: <span id="scanCount">0</span>
                        </div>
                        <button type="button" class="btn btn-outline-primary btn-sm rounded-pill px-3" onclick="PharmacyTransaction.addRow()">
                            <i class="bi bi-plus-lg me-1"></i> إضافة صنف يدوي
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @* ── POS Metadata Section ── *@
        <div class="container-fluid px-4 mb-4">
            <div class="pos-meta-row shadow-sm">
                <div class="pos-meta-group">
                    <label asp-for="SaleDate" class="pos-meta-label">تاريخ البيع</label>
                    <input asp-for="SaleDate" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local" class="pos-meta-input" />
                </div>
                <div class="pos-meta-group" style="flex: 2;">
                    <label asp-for="CustomerName" class="pos-meta-label">اسم العميل</label>
                    <input asp-for="CustomerName" class="pos-meta-input" placeholder="أدخل اسم العميل..." />
                </div>
                <div class="pos-meta-group" style="flex: 2;">
                    <label asp-for="Notes" class="pos-meta-label">ملاحظات</label>
                    <input asp-for="Notes" class="pos-meta-input" placeholder="ملاحظات اختيارية عن الفاتورة..." />
                </div>
            </div>
            
            <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-4 p-2 mt-3 small shadow-sm"></div>
        </div>

        @* ── POS Sales Lines ── *@
        <div class="container-fluid px-4">
            <div class="mb-3 d-flex align-items-center justify-content-between">
                <h6 class="text-primary fw-bolder mb-0"><i class="bi bi-list-task me-2"></i>بنود الصرف (FEFO)</h6>
                <div class="form-check form-switch pos-switch">
                    <input class="form-check-input" type="checkbox" id="fefoSwith" checked disabled>
                    <label class="form-check-label small fw-bold text-muted" for="fefoSwith">تفعيل FEFO التلقائي</label>
                </div>
            </div>

            <div id="linesBody" class="pos-lines-container">
                <!-- Lines will be injected here as pos-line-card -->
            </div>

            <div id="emptyContainer" class="erp-empty pos-fade-in py-5 rounded-5 border-2 shadow-inner" style="display:none; background: #fff;">
                <i class="bi bi-basket-fill fs-1 d-block mb-3 text-primary opacity-25"></i>
                <h5 class="fw-bold text-muted">لم يتم إضافة أي أصناف بعد</h5>
                <p class="small text-secondary">ابدأ بمسح الباركود أو الضغط على "إضافة صنف يدوي"</p>
                <div id="linesClientValidation" class="text-danger mt-3 fw-bold"></div>
            </div>
        </div>

        @* ── POS Action Footer (Sticky) ── *@
        <div class="pos-footer">
            <div class="pos-footer-summary">
                <div class="pos-grand-total">
                    <span class="pos-total-label"><i class="bi bi-wallet2 me-1"></i>الإجمالي التقديري</span>
                    <div class="d-flex align-items-baseline gap-2">
                        <span class="pos-total-amount" id="estimatedTotal">0.00</span>
                        <span class="pos-line-total-currency">ج.س</span>
                    </div>
                </div>
            </div>
            <div class="pos-actions">
                <a asp-action="Index" class="btn btn-pos btn-outline-secondary">
                    <i class="bi bi-arrow-right"></i> رجوع
                </a>
                <button type="submit" class="btn btn-pos btn-pos-primary btn-lg shadow">
                    <i class="bi bi-check2-all"></i> حفظ وصرف الفاتورة
                </button>
            </div>
        </div>
    </form>
</div>

@* ── Multi-Match Modal ── *@
<div class="modal fade" id="batchSelectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-primary text-white border-0 py-3">
                <h6 class="modal-title fw-bold">
                    <i class="bi bi-layers me-2"></i> تكرار باركود — اختر الباتش المطلوب
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4" id="batchSelectBody" style="background: #f8fafc;">
                <!-- populated dynamically -->
            </div>
        </div>
    </div>
</div>

<template id="rowTemplate">
    <partial name="_PharmacyLineItem" view-data='@new ViewDataDictionary(ViewData) { { "Mode", "sale" } }' />
</template>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pharmacy-transaction.js"></script>
    <script src="~/js/barcode-scanner.js"></script>
    <script>
        var itemLookup = @Html.Raw(Json.Serialize(Model.ItemLookup));
        var totalScans = 0;

        function setStatus(type, text) {
            var el = $('#scanStatus');
            var zone = $('#scannerZone');
            el.removeClass('success error');
            zone.removeClass('pos-flash-success pos-flash-error');

            if (type === 'ready') el.html('<i class="bi bi-wifi"></i> ' + (text || 'جاهز'));
            else if (type === 'success') {
                el.addClass('success').html('<i class="bi bi-check-circle-fill"></i> ' + (text || 'تمت الإضافة'));
                zone.addClass('pos-flash-success');
            } else if (type === 'error') {
                el.addClass('error').html('<i class="bi bi-exclamation-triangle-fill"></i> ' + (text || 'غير موجود'));
                zone.addClass('pos-flash-error');
            }

            if (type !== 'ready') {
                setTimeout(() => {
                    setStatus('ready');
                    zone.removeClass('pos-flash-success pos-flash-error');
                }, 2000);
            }
        }

        function updateScanCount() {
            var count = PharmacyTransaction.getLineCount();
            $('#scanCount').text(count);
        }

        function formatNumber(val, digits) {
            var num = parseFloat(val);
            if (isNaN(num)) return '0.00';
            return num.toLocaleString('en-US', { minimumFractionDigits: digits || 2, maximumFractionDigits: digits || 2 });
        }

        function normalizeDate(dateStr) {
            if (!dateStr) return '-';
            if (dateStr.length >= 10) return dateStr.substring(0, 10);
            return dateStr;
        }

        function updateEstimatedTotalQuick() {
            var total = 0;
            $('#linesBody .line-est-total').each(function () {
                var numeric = parseFloat(($(this).text() || '0').replace(/,/g, ''));
                if (!isNaN(numeric)) total += numeric;
            });
            $('#estimatedTotal').text(formatNumber(total));
        }

        function getItemDefaultPrice(itemId) {
            var id = parseInt(itemId);
            if (!id) return 0;
            var found = itemLookup.find(i => parseInt(i.id) === id);
            return found ? (parseFloat(found.defaultSellingPrice || found.DefaultSellingPrice) || 0) : 0;
        }

        function updateLineEstimatedTotal($row) {
            var qty = parseFloat($row.find('.qty-input').val()) || 0;
            var price = parseFloat($row.find('.sale-price-input').val()) || 0;
            var lineTotal = qty * price;
            $row.find('.line-est-total').text(formatNumber(lineTotal));
            updateEstimatedTotalQuick();
        }

        function highlightLine($row, type) {
            $row.addClass('is-scan-hit');
            setTimeout(() => $row.removeClass('is-scan-hit'), 800);
        }

        $(function () {
            PharmacyTransaction.init({
                mode: 'sale',
                formId: '#saleForm',
                tableBodyId: '#linesBody',
                rowTemplateId: '#rowTemplate',
                emptyContainerId: '#emptyContainer',
                grandTotalId: '#estimatedTotal',
                callbacks: {
                    calculateLineTotal: function ($row) {
                        refreshFefo($row);
                    },
                    onRowAdded: function ($newRow, prefillData) {
                        // DOM manipulation: inject options directly into the select element
                        // (cannot use string replacement — browser strips text nodes from <select>)
                        var $select = $newRow.find('.item-select');
                        var optionsHtml = itemLookup.map(i => `<option value="${i.id || i.Id}">${i.name || i.Name}</option>`).join('');
                        $select.append(optionsHtml);
                        
                        // Support both camelCase and PascalCase
                        var itemId = prefillData?.itemId || prefillData?.ItemId;
                        var qty = prefillData?.quantity || prefillData?.Quantity || 1;
                        var price = prefillData?.sellingPrice || prefillData?.SellingPrice || prefillData?.defaultSellingPrice || prefillData?.DefaultSellingPrice;

                        if (itemId) {
                            $select.val(itemId).trigger('change');
                            console.log('[Sales onRowAdded] Set itemId:', itemId, 'Actual val:', $select.val());
                        }
                        $newRow.find('.qty-input').val(qty);
                        if (price) {
                            $newRow.find('.sale-price-input').val(parseFloat(price).toFixed(2));
                        } else if (itemId) {
                            $newRow.find('.sale-price-input').val(getItemDefaultPrice(itemId).toFixed(2));
                        }

                        if (prefillData?.barcode || prefillData?.Barcode) {
                            var bc = prefillData?.barcode || prefillData?.Barcode;
                            $newRow.attr('data-barcode', bc);
                            $newRow.find('[data-field="Barcode"]').val(bc);
                        }

                        refreshFefo($newRow);
                        highlightLine($newRow);
                        updateScanCount();

                        setTimeout(() => $('#barcodeInput').focus(), 50);
                    },
                    onRowRemoved: function() {
                        updateScanCount();
                        updateEstimatedTotalQuick();
                    }
                }
            });

            if ($('#linesBody .pos-line-card').length === 0) {
                PharmacyTransaction.addRow({ quantity: 1 });
            }

            // Global Sticky Focus for Scanner
            $(document).on('click', function (e) {
                if (!$(e.target).is('input, select, textarea, .select2-search__field, button')) {
                    $('#barcodeInput').focus();
                }
            });

            $('#barcodeInput').focus().on('keydown', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    handleBarcodeScan();
                }
            });

            // Alias for naming standardization
            window.handleBarcodeScan = function() {
                lookupBarcodeForSale();
            };

            $('#linesBody').on('change', '.item-select', function() {
                var $row = $(this).closest('.erp-line-row');
                $row.find('.sale-price-input').val(getItemDefaultPrice($(this).val()).toFixed(2));
                refreshFefo($row);
            });
        });

        function refreshFefo($row) {
            const itemId = parseInt($row.find('.item-select').val());
            const qty = parseFloat($row.find('.qty-input').val()) || 0;
            const barcode = $row.attr('data-barcode');

            if (!itemId || qty <= 0) {
                $row.find('.specific-batch-text').html('<span class="text-muted">أدخل الكمية...</span>');
                updateLineEstimatedTotal($row);
                return;
            }

            // UI Label behavior
            if (barcode) {
                $row.find('.batch-label-text').text(`الباركود: ${barcode}`);
            } else {
                $row.find('.batch-label-text').text('تلقائي (FEFO)');
            }

            var fefoKey = itemId + '|' + qty;
            if ($row.data('fefoKey') === fefoKey) {
                updateLineEstimatedTotal($row);
                return;
            }
            $row.data('fefoKey', fefoKey);

            $row.find('.specific-batch-text').html('<div class="spinner-border spinner-border-sm text-primary" role="status"></div>');

            $.get('/PharmacySales/PreviewFefo', { itemId: itemId, quantity: qty }, function (res) {
                const chips = PharmacyTransaction.renderFefoChips(res.allocations);
                $row.find('.specific-batch-text').html(chips);
                updateLineEstimatedTotal($row);
            });
        }

        var isProcessingScan = false;

        function lookupBarcodeForSale() {
            const barcode = $('#barcodeInput').val()?.trim();
            if (!barcode || barcode.length < 3) {
                if (barcode) setStatus('error', 'باركود قصير جداً');
                return;
            }

            if (isProcessingScan) return;
            isProcessingScan = true;

            // Small delay to allow scanner input buffer to stabilize if needed
            setTimeout(() => {
                BarcodeScanner.processScan(barcode, {
                    lookupUrl: '/PharmacySales/LookupByBarcode',
                    findRowByBarcode: function (bc) {
                        var found = null;
                        $('#linesBody .erp-line-row').each(function() {
                            if (($(this).attr('data-barcode') || '').toLowerCase() === bc.toLowerCase()) {
                                found = $(this); return false;
                            }
                        });
                        return found;
                    },
                    findActiveOrEmptyRow: () => PharmacyTransaction.getActiveRow(),
                    createNewRow: () => PharmacyTransaction.addRow(),
                    fillRow: ($row, data, bc) => {
                        if (!$row || !$row.length) return;

                        var itemId = data.itemId || data.ItemId;
                        var price = data.sellingPrice || data.SellingPrice || data.defaultSellingPrice || data.DefaultSellingPrice;

                        $row.attr('data-barcode', bc);
                        $row.find('[data-field="Barcode"]').val(bc);
                        
                        if (itemId) {
                            $row.find('.item-select').val(itemId).trigger('change');
                        }
                        $row.find('.qty-input').val(1);
                        if (price) {
                            $row.find('.sale-price-input').val(parseFloat(price).toFixed(2));
                        } else if (itemId) {
                            $row.find('.sale-price-input').val(getItemDefaultPrice(itemId).toFixed(2));
                        }
                        
                        setTimeout(() => refreshFefo($row), 50);
                        highlightLine($row);
                    },
                    incrementQuantity: $row => {
                        var $qty = $row.find('.qty-input');
                        $qty.val((parseFloat($qty.val()) || 0) + 1).trigger('change');
                        highlightLine($row);
                    },
                    onMultiMatch: (matches, bc) => {
                        isProcessingScan = false;
                        showBatchSelectionModal(matches, bc);
                    },
                    onSuccess: (type, $row, bc, data) => {
                        isProcessingScan = false;
                        setStatus('success', data?.itemName || 'تم بنجاح');
                        setTimeout(() => $('#barcodeInput').val('').focus(), 100);
                    },
                    onError: () => {
                        isProcessingScan = false;
                        setStatus('error', 'الباركود غير موجود');
                        setTimeout(() => $('#barcodeInput').val('').focus(), 100);
                    }
                });
            }, 100);
        }

        function showBatchSelectionModal(matches, barcode) {
            var body = $('#batchSelectBody').empty();
            matches.forEach(m => {
                var row = $(`<div class="card border-0 shadow-sm mb-2 p-3" style="cursor:pointer; border-radius: 1rem;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fw-bold text-dark">${m.itemName}</div>
                            <small class="text-muted">باتش: ${m.batchNumber} | المتاح: ${m.availableQuantity}</small>
                        </div>
                        <div class="text-primary fw-bold">${m.defaultSellingPrice.toFixed(2)}</div>
                    </div>
                </div>`);
                row.click(() => {
                    PharmacyTransaction.addRow({ itemId: m.itemId, quantity: 1, barcode: barcode, sellingPrice: m.defaultSellingPrice });
                    bootstrap.Modal.getInstance(document.getElementById('batchSelectModal')).hide();
                });
                body.append(row);
            });
            new bootstrap.Modal('#batchSelectModal').show();
        }
    </script>
}
