@model NagmClinic.Models.PharmacySale

@{
    ViewData["Title"] = "تفاصيل فاتورة الصرف";
}

<link href="~/css/print-branding.css" rel="stylesheet" />

<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4 mb-3">
            <div class="card-body p-4">
                @await Html.PartialAsync("_PrintBrandingHeader", new PrintBrandingHeaderViewModel
                {
                    DocumentTitleAr = "فاتورة صرف",
                    DocumentTitleEn = "Dispensing Invoice",
                    DocumentNumber = $"SL-{Model.Id:D5}",
                    Compact = false
                })
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0 text-primary"><i class="bi bi-receipt me-2"></i> فاتورة صرف</h5>
                    <div class="d-flex gap-2 no-print">
                        <button type="button" onclick="window.print()" class="btn btn-outline-dark btn-sm rounded-pill px-3"><i class="bi bi-printer me-1"></i> طباعة A4</button>
                        <a asp-action="PrintThermalReceipt" asp-route-id="@Model.Id" target="_blank" class="btn btn-outline-primary btn-sm rounded-pill px-3"><i class="bi bi-receipt me-1"></i> طباعة إيصال</a>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3">العودة</a>
                    </div>
                </div>
                <div class="row g-3">
                    <div class="col-md-3"><div class="small text-muted">رقم الفاتورة</div><div class="fw-bold">SL-@Model.Id.ToString("D5")</div></div>
                    <div class="col-md-3"><div class="small text-muted">تاريخ الصرف</div><div class="fw-bold">@Model.SaleDate.ToString("yyyy-MM-dd HH:mm")</div></div>
                    <div class="col-md-3"><div class="small text-muted">العميل</div><div class="fw-bold">@(string.IsNullOrWhiteSpace(Model.CustomerName) ? "-" : Model.CustomerName)</div></div>
                    <div class="col-md-3"><div class="small text-muted">الإجمالي</div><div class="fw-bold text-primary">@Model.TotalAmount.ToString("N2") ج.س</div></div>
                    <div class="col-12"><div class="small text-muted">ملاحظات</div><div class="fw-bold">@(string.IsNullOrWhiteSpace(Model.Notes) ? "-" : Model.Notes)</div></div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-3">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-box-seam me-2"></i>بنود الفاتورة</h6>
                <div class="table-responsive">
                    <table class="table table-hover align-middle text-center small w-100">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-0">الصنف</th>
                                <th class="border-0">الوحدة</th>
                                <th class="border-0">الباتش</th>
                                <th class="border-0">الباركود</th>
                                <th class="border-0">الانتهاء</th>
                                <th class="border-0">الموقع</th>
                                <th class="border-0">الكمية</th>
                                <th class="border-0">سعر البيع</th>
                                <th class="border-0">الإجمالي</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in Model.Lines.OrderBy(l => l.ExpiryDateSnapshot))
                            {
                                <tr>
                                    <td class="fw-bold">@line.Item?.Name</td>
                                    <td>@line.Item?.Unit?.Name</td>
                                    <td><span class="badge bg-light text-dark border">@line.BatchNumberSnapshot</span></td>
                                    <td><span class="text-primary small fw-bold">@line.ItemBatch?.Barcode</span></td>
                                    <td>@line.ExpiryDateSnapshot.ToString("yyyy-MM-dd")</td>
                                    <td>@line.SlotCodeSnapshot</td>
                                    <td>@line.Quantity.ToString("N2")</td>
                                    <td>@line.UnitPrice.ToString("N2")</td>
                                    <td class="fw-bold text-primary">@line.LineTotal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @await Html.PartialAsync("_PrintBrandingFooter", new PrintBrandingFooterViewModel
                {
                    PrintedAt = DateTime.Now,
                    LeftTitle = "Invoice No:",
                    LeftValue = $"SL-{Model.Id:D5}",
                    Compact = false
                })
            </div>
        </div>
    </div>
</div>
