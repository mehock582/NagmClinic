@{
    ViewData["Title"] = "صرف الأدوية";
}

<div class="card border-0 shadow-sm rounded-3">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0 text-primary">
                <i class="bi bi-bag-check-fill me-2"></i> صرف الأدوية
            </h5>
            <a asp-action="Create" class="btn btn-primary btn-sm rounded-pill px-3">
                <i class="bi bi-plus-lg me-1"></i> فاتورة صرف جديدة
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle text-center small w-100">
                <thead class="bg-light">
                    <tr>
                        <th class="border-0">رقم الفاتورة</th>
                        <th class="border-0">التاريخ</th>
                        <th class="border-0">العميل</th>
                        <th class="border-0">عدد البنود</th>
                        <th class="border-0">الحالة</th>
                        <th class="border-0">الإجمالي</th>
                        <th class="border-0">الإجراءات</th>
                    </tr>
                </thead>
                <tbody id="salesTableBody">
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    
    
    
    <script>
        $(function () {
            var columns = [
                { 
                    "data": "id",
                    "render": function(data) {
                        return `<span class="fw-bold">SL-${String(data).padStart(5, '0')}</span>`;
                    }
                },
                { "data": "saleDate" },
                { "data": "customerName" },
                { 
                    "data": "linesCount",
                    "render": function(data) {
                        return `<span class="badge bg-light text-dark border">${data}</span>`;
                    }
                },
                { 
                    "data": "status",
                    "render": function(data) {
                        return `<span class="badge bg-success">${data}</span>`;
                    }
                },
                { 
                    "data": "totalAmount",
                    "render": function(data) {
                         return `<span class="fw-bold text-primary">${parseFloat(data).toFixed(2)}</span>`;
                    }
                },
                {
                    "data": "id",
                    "orderable": false,
                    "render": function (data) {
                        return renderPharmacyActionButtons(data, '/PharmacySales', 'sales');
                    }
                }
            ];

            initDataTable('.table', '/PharmacySales/GetSalesData', columns);
        });
    </script>
}


