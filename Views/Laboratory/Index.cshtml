@{
    ViewData["Title"] = "إدارة نتائج المختبر";
}

<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0 text-primary">
                        <i class="bi bi-microscope me-2"></i> طلبات المختبر
                    </h5>

                    <!-- Device integration is optional and status-driven -->
                    <button id="integrationStatusBtn" class="btn btn-outline-secondary btn-sm rounded-pill px-3 shadow-sm d-flex align-items-center gap-2" onclick="showLiveStatus()">
                        <span id="integrationStatusDot" class="spinner-grow spinner-grow-sm text-secondary" role="status" aria-hidden="true" style="width: 0.75rem; height: 0.75rem;"></span>
                        <span id="integrationStatusText" class="fw-bold">الربط الآلي اختياري</span>
                        <i class="bi bi-hdd-network ms-1"></i>
                    </button>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle text-center small w-100 nowrap" id="labIndexTable">
                        <thead class="table-dark">
                            <tr>
                                <th class="text-center align-middle text-nowrap" style="width:40px;"></th>
                                <th class="text-center align-middle text-nowrap"># حجز</th>
                                <th class="text-center align-middle text-nowrap">تاريخ الطلب</th>
                                <th class="text-center align-middle text-nowrap">المريض</th>
                                <th class="text-center align-middle text-nowrap">الطبيب</th>
                                <th class="text-center align-middle text-nowrap">الفحوصات</th>
                                <th class="text-center align-middle text-nowrap">الحالة</th>
                                <th class="text-center align-middle text-nowrap">الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal for Lab Result Entry (shared for all tests) -->
<div class="modal fade" id="labResultModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom-0 p-4">
                <h5 class="modal-title fw-bold text-primary"><i class="bi bi-pencil-square me-2"></i> <span id="modalTitleText">إدخال نتائج الفحص</span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 pt-0">
                <div class="bg-primary bg-opacity-10 rounded-3 p-3 mb-4">
                    <p class="mb-1 text-dark"><strong>المريض:</strong> <span id="modalPatientName"></span></p>
                    <p class="mb-0 text-dark"><strong>الفحص:</strong> <span id="modalTestName"></span></p>
                </div>

                <form id="labResultForm" class="needs-validation" novalidate>
                    <input type="hidden" id="modalResultId" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-bold">النتيجة</label>
                            <div id="resultInputContainer">
                                <input type="text" id="modalResultValue" class="form-control" required placeholder="سجل قيمة النتيجة هنا">
                            </div>
                            <div class="invalid-feedback text-danger fw-bold small mt-1"><i class="bi bi-exclamation-circle me-1"></i>يرجى إدخال النتيجة</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">الحالة</label>
                            <select id="modalStatus" class="form-select">
                                <option value="Pending">قيد الانتظار</option>
                                <option value="InProgress">قيد التنفيذ</option>
                                <option value="Completed">مكتمل</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">الفني المسؤول</label>
                            <input type="text" id="modalPerformedBy" class="form-control">
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold">ملاحظات المختبر</label>
                            <textarea id="modalLabNotes" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-top-0 p-4 pt-2">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" id="saveBtn" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm" onclick="saveLabResult()">حفظ النتائج</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- DataTables JS -->
    
    
    

    <script>
        // ─── State ───
        var expandedRows = {};     // track which appointment rows are expanded
        var integrationStatus = {
            hasRecentImports: false,
            recentImportedCount: 0,
            recentRejectedCount: 0,
            minutesWindow: 30,
            connectorApiConfigured: false,
            manualModeAvailable: true
        };

        $(document).ready(function () {
            var dt = initDataTable('#labIndexTable', '/Laboratory/GetLabResultsData', [
                    {
                        // Expand/collapse toggle
                        data: null, orderable: false, searchable: false,
                        render: function (d, t, row) {
                            var icon = expandedRows[row.appointmentId] ? 'bi-chevron-up' : 'bi-chevron-down';
                            return `<button class="btn btn-sm btn-link p-0 lab-expand-btn" data-id="${row.appointmentId}"><i class="bi ${icon}"></i></button>`;
                        }
                    },
                    {
                        data: 'dailyNumber',
                        render: function (d) { return `<span class="fw-bold">${d}</span>`; }
                    },
                    { data: 'requestDate' },
                    {
                        data: 'patientName',
                        render: function (d, t, row) {
                            return `<div class="fw-bold">${d}</div><small class="text-muted">${row.patientPhone || '-'}</small>`;
                        }
                    },
                    {
                        data: 'doctorName',
                        render: function (d) { return `<span class="text-muted">${d || '-'}</span>`; }
                    },
                    {
                        // Test summary counts
                        data: null, orderable: false,
                        render: function (d, t, row) {
                            return `<div class="lab-counts-cell">
                                <span class="badge bg-secondary-subtle text-dark rounded-pill" title="الإجمالي">${row.totalTests}</span>
                                <span class="badge bg-success-subtle text-success rounded-pill" title="مكتمل"><i class="bi bi-check-circle-fill me-1"></i>${row.completedTests}</span>
                                <span class="badge bg-warning-subtle text-warning rounded-pill" title="قيد الانتظار"><i class="bi bi-hourglass-split me-1"></i>${row.pendingTests}</span>
                            </div>`;
                        }
                    },
                    {
                        data: 'overallStatus',
                        render: function (d) {
                            if (d === 'Completed') return `<span class="badge bg-success rounded-pill px-3 shadow-sm"><i class="bi bi-check-circle me-1"></i>مكتمل</span>`;
                            if (d === 'Partial') return `<span class="badge bg-info text-dark rounded-pill px-3">جزئي</span>`;
                            return `<span class="badge bg-warning text-dark rounded-pill px-3">قيد الانتظار</span>`;
                        }
                    },
                    {
                        data: null, orderable: false,
                        render: function (d, t, row) {
                            var iconClass = expandedRows[row.appointmentId] ? 'lab-row-expanded' : '';
                            var html = `<div class="action-group">`;
                            html += `<button class="btn-action btn-action-primary lab-expand-btn ${iconClass}" data-id="${row.appointmentId}" data-label="عرض التفاصيل"><i class="bi bi-list-ul"></i></button>`;
                            if (row.overallStatus === 'Completed') {
                                var reportUrl = '/Laboratory/Report?appointmentId=' + encodeURIComponent(row.appointmentId) + '&autoPrint=true';
                                html += `<a class="btn-action btn-action-dark" href="${reportUrl}" target="_blank" data-label="طباعة التقرير"><i class="bi bi-printer-fill"></i></a>`;
                            }
                            html += `</div>`;
                            return html;
                        }
                    }
                ],
                {
                    drawCallback: function () {
                        bindExpandButtons();

                        // 🛠️ Stability Fix: Re-expand and refresh details from server (NO CACHE)
                        var dtApi = this.api();
                        dtApi.rows().every(function () {
                            var rowData = this.data();
                            if (rowData && expandedRows[rowData.appointmentId]) {
                                var tr = $(this.node());
                                tr.addClass('lab-row-expanded');
                                
                                var row = this;
                                $.getJSON('/Laboratory/GetLabTestDetails?appointmentId=' + rowData.appointmentId, function (tests) {
                                    if (expandedRows[rowData.appointmentId]) {
                                        row.child(buildDetailPanel(rowData.appointmentId, tests, tr)).show();
                                    }
                                });
                            }
                        });
                    }
                }
            );

            // 🟢 Live Poller
            setInterval(function () {
                if ($('.modal.show').length === 0) {
                    dt.ajax.reload(null, false);
                }
            }, 7000);

            refreshIntegrationStatus();
            setInterval(refreshIntegrationStatus, 30000);
        });

        // ─── Expand/Collapse Buttons ───
        function bindExpandButtons() {
            $('.lab-expand-btn').off('click').on('click', function (e) {
                e.preventDefault();
                var appointmentId = $(this).data('id');
                var tr = $(this).closest('tr');
                toggleDetailPanel(tr, appointmentId);
            });
        }

        function toggleDetailPanel(tr, appointmentId) {
            var dt = $('#labIndexTable').DataTable();
            var row = dt.row(tr);

            if (row.child.isShown()) {
                row.child.hide();
                tr.removeClass('lab-row-expanded');
                tr.find('.lab-expand-btn i').removeClass('bi-chevron-up').addClass('bi-chevron-down');
                delete expandedRows[appointmentId];
            } else {
                expandedRows[appointmentId] = true;
                tr.addClass('lab-row-expanded');
                tr.find('.lab-expand-btn i').removeClass('bi-chevron-down').addClass('bi-chevron-up');

                row.child('<div class="text-center py-3"><div class="spinner-border spinner-border-sm text-primary"></div> جاري التحميل...</div>').show();
                $.getJSON('/Laboratory/GetLabTestDetails?appointmentId=' + appointmentId, function (tests) {
                    if (expandedRows[appointmentId]) {
                        row.child(buildDetailPanel(appointmentId, tests, tr)).show();
                    }
                });
            }
        }

        // ─── Build Detail Panel HTML ───
        function buildDetailPanel(appointmentId, tests, parentRow) {
            var patientName = parentRow.find('td:eq(3) .fw-bold').text();
            var html = `<div class="lab-detail-panel">
                <table class="table table-sm table-borderless mb-0 small">
                    <thead><tr>
                        <th class="text-muted">الفحص</th>
                        <th class="text-muted text-center">الحالة</th>
                        <th class="text-muted text-center">النتيجة</th>
                        <th class="text-muted text-center">الوحدة</th>
                        <th class="text-muted text-center">المدى الطبيعي</th>
                        <th class="text-muted text-center">الإجراء</th>
                    </tr></thead><tbody>`;

            tests.forEach(function (t) {
                var statusBadge = t.status === 'Completed'
                    ? '<span class="badge bg-success rounded-pill">مكتمل</span>'
                    : (t.status === 'InProgress'
                        ? '<span class="badge bg-info text-dark rounded-pill">قيد التنفيذ</span>'
                        : '<span class="badge bg-warning text-dark rounded-pill">قيد الانتظار</span>');

                var resultDisplay = t.resultValue || '<span class="text-muted">—</span>';
                var isCompleted = t.status === 'Completed';

                html += `<tr>
                    <td class="text-start">
                        <div class="fw-bold text-primary">${safe(t.testName)}</div>
                        <small class="text-muted">${safe(t.testNameAr)}</small>
                    </td>
                    <td class="text-center">${statusBadge}</td>
                    <td class="text-center fw-bold">${resultDisplay}</td>
                    <td class="text-center text-muted">${t.unit || '-'}</td>
                    <td class="text-center text-muted">${t.normalRange || '-'}</td>
                    <td class="text-center">
                        <button class="btn btn-sm btn-outline-primary rounded-pill px-3"
                            onclick="openManageResultModal('${t.labResultId}', '${safe(patientName)}', '${safe(t.testName)}', '${safe(t.resultValue)}', '${safe(t.unit)}', '${safe(t.normalRange)}', '${t.status}', '${safe(t.labNotes)}', '${safe(t.performedBy)}', '${t.resultType}', '${safe(t.predefinedValues)}')">
                            <i class="bi bi-pencil-square me-1"></i>${isCompleted ? 'تعديل' : 'إدخال'}
                        </button>
                    </td>
                </tr>`;
            });

            html += `</tbody></table></div>`;
            return html;
        }

        function safe(v) { return (v || '').replace(/'/g, "\\'").replace(/"/g, '&quot;'); }

        // ─── Result Modal ───
        function openManageResultModal(id, patientName, testName, val, unit, range, status, notes, performedBy, resultType, predefined) {
            $('#modalResultId').val(id);
            $('#modalPatientName').text(patientName);
            $('#modalTestName').text(testName);
            $('#modalStatus').val(status);
            $('#modalLabNotes').val(notes || '');
            $('#modalPerformedBy').val(performedBy || '');

            let inputHtml = "";
            if ((resultType == "3" || resultType == "4") && predefined) {
                const options = predefined.split(',');
                inputHtml = `<select id="modalResultValue" class="form-select" required><option value="">-- اختر النتيجة --</option>`;
                options.forEach(opt => {
                    const selected = (val && val.trim() == opt.trim()) ? "selected" : "";
                    inputHtml += `<option value="${opt.trim()}" ${selected}>${opt.trim()}</option>`;
                });
                inputHtml += `</select>`;
            } else if (resultType == "2") {
                inputHtml = `<input type="number" id="modalResultValue" class="form-control" step="any" required placeholder="0.00" value="${val || ''}">`;
            } else {
                inputHtml = `<input type="text" id="modalResultValue" class="form-control ${status === 'Completed' ? 'is-valid bg-success bg-opacity-10' : ''}" required placeholder="سجل النتيجة هنا" value="${val || ''}">`;
            }
            $('#resultInputContainer').html(inputHtml);

            const isCompleted = (status === 'Completed');
            $('#labResultForm').removeClass('was-validated');
            $('#labResultForm input, #labResultForm select, #labResultForm textarea').prop('disabled', false);
            $('#saveBtn').show();
            $('#modalTitleText').text(isCompleted ? 'تعديل نتيجة الفحص' : 'إدخال نتائج الفحص');

            new bootstrap.Modal(document.getElementById('labResultModal')).show();
        }

        function refreshIntegrationStatus() {
            $.getJSON('/Laboratory/GetIntegrationStatus', function (status) {
                integrationStatus = status || integrationStatus;
                renderIntegrationStatus();
            }).fail(function () {
                integrationStatus.hasRecentImports = false;
                integrationStatus.recentImportedCount = 0;
                integrationStatus.recentRejectedCount = 0;
                integrationStatus.connectorApiConfigured = false;
                renderIntegrationStatus();
            });
        }

        function renderIntegrationStatus() {
            var $btn = $('#integrationStatusBtn');
            var $dot = $('#integrationStatusDot');
            var $text = $('#integrationStatusText');

            $btn.removeClass('btn-success btn-warning btn-outline-secondary');
            $dot.removeClass('text-success text-warning text-secondary');

            if (integrationStatus.hasRecentImports) {
                $btn.addClass('btn-success');
                $dot.addClass('text-success');
                $text.text('الربط الآلي نشط');
                return;
            }

            if (integrationStatus.connectorApiConfigured) {
                $btn.addClass('btn-warning');
                $dot.addClass('text-warning');
                $text.text('الربط الآلي غير نشط حالياً');
                return;
            }

            $btn.addClass('btn-outline-secondary');
            $dot.addClass('text-secondary');
            $text.text('الوضع اليدوي (بدون ربط)');
        }

        function showLiveStatus() {
            var statusIcon = integrationStatus.hasRecentImports ? 'success' : 'info';
            var statusTitle = integrationStatus.hasRecentImports
                ? 'الربط الآلي متاح'
                : 'الوضع اليدوي يعمل';

            var integrationHint = integrationStatus.connectorApiConfigured
                ? 'يمكن استقبال نتائج الأجهزة عند توفر Connector، ولكن النظام يعمل أيضاً بدون أي ربط.'
                : 'لا يوجد تكامل أجهزة مفعّل حالياً، ويمكن إدخال النتائج يدوياً بشكل كامل.';

            Swal.fire({
                icon: statusIcon,
                title: statusTitle,
                html: '<div class="text-start mt-3">' +
                      '<b>نتائج مستوردة آخر ' + integrationStatus.minutesWindow + ' دقيقة:</b> <span class="fw-bold">' + integrationStatus.recentImportedCount + '</span><br/>' +
                      '<b>محاولات مرفوضة/فاشلة:</b> <span class="fw-bold">' + integrationStatus.recentRejectedCount + '</span><br/><br/>' +
                      '<div class="alert alert-info bg-opacity-10 border-info"><i class="bi bi-info-circle me-1"></i>' + integrationHint + '</div></div>',
                confirmButtonText: 'إغلاق',
                confirmButtonColor: '#198754'
            });
        }

        function saveLabResult() {
            const form = document.getElementById('labResultForm');
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            var id = $('#modalResultId').val();
            var data = {
                id: id,
                resultValue: $('#modalResultValue').val(),
                unit: null,
                normalRange: null,
                status: $('#modalStatus').val(),
                labNotes: $('#modalLabNotes').val(),
                performedBy: $('#modalPerformedBy').val()
            };

            $.post('/Laboratory/UpdateResult', data, function (response) {
                if (response.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'تم الحفظ بنجاح',
                        showConfirmButton: false,
                        timer: 1500
                    }).then(() => {
                        bootstrap.Modal.getInstance(document.getElementById('labResultModal')).hide();
                        $('#labIndexTable').DataTable().ajax.reload(null, false);
                    });
                } else {
                    Swal.fire('خطأ', response.message, 'error');
                }
            });
        }
    </script>
}

