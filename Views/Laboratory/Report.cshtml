@model NagmClinic.ViewModels.LabReportPrintViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lab Report - @Model.Meta.LabNumber</title>
    <link href="~/css/cairo-font.css" rel="stylesheet" />
    <link href="~/css/print-branding.css" rel="stylesheet" />
    <link href="~/css/lab-report-print.css" rel="stylesheet" />
</head>
<body class="lab-report-page">
    <div class="lab-report-print-controls">
        <button type="button" onclick="window.print()">Print Report</button>
    </div>

    <article class="lab-report-sheet">
        <header class="report-header-section">
            <div class="report-header-top">
                <div class="header-img-left">
                </div>
                <div class="header-text-center" style="font-size: 1.25rem; font-weight: bold;">
                    @(string.IsNullOrWhiteSpace(Model.Header.CenterNameEn) ? Model.Header.CenterNameAr : Model.Header.CenterNameEn)
                </div>
                <div class="header-img-right">
                    @if (!string.IsNullOrWhiteSpace(Model.Header.LogoUrl))
                    {
                        <img src="@Model.Header.LogoUrl" alt="Logo" class="main-logo" />
                    }
                </div>
            </div>
            
            <div class="report-title-centered">
                <h2><u>Laboratory Report</u></h2>
            </div>
        </header>

        <section class="patient-info-section">
            <div class="patient-info-col-left">
                <div class="info-line"><span class="lbl-col">Name</span><span class="colon">:</span><strong class="val-col">@((Model.Patient.GenderEn == "Female" ? "Miss" : "Mr.") + " " + Model.Patient.PatientName)</strong></div>
                <div class="info-line"><span class="lbl-col">Referral Doctor</span><span class="colon">:</span><strong class="val-col">@(string.IsNullOrWhiteSpace(Model.Patient.AttendingPhysician) || Model.Patient.AttendingPhysician == "-" ? "Self Request" : Model.Patient.AttendingPhysician)</strong></div>
                <div class="info-line"><span class="lbl-col">Age/Gender</span><span class="colon">:</span><strong class="val-col">@Model.Patient.Age Y - @Model.Patient.GenderEn</strong></div>
                <div class="info-line"><span class="lbl-col">Report Status</span><span class="colon">:</span><strong class="val-col">Final report</strong></div>
            </div>
            <div class="patient-info-col-right">
                <div class="info-line"><span class="lbl-col">Patient ID</span><span class="colon">:</span><strong class="val-col">@Model.Patient.PatientId</strong></div>
                <div class="info-line"><span class="lbl-col">Mobile No.</span><span class="colon">:</span><strong class="val-col">@Model.Patient.Phone</strong></div>
                <div class="info-line"><span class="lbl-col">Accession No.</span><span class="colon">:</span><strong class="val-col">@Model.Meta.LabNumber</strong></div>
            </div>
        </section>

        <section class="lab-results-container">
            <table class="lab-results-table">
                <colgroup>
                    <col class="col-test-name" />
                    <col class="col-reading" />
                    <col class="col-flag" />
                    <col class="col-unit" />
                    <col class="col-range" />
                </colgroup>
                <thead>
                    <tr>
                        <th class="col-test-name text-left">Test</th>
                        <th class="col-reading text-left">Result</th>
                        <th class="col-flag text-center"></th>
                        <th class="col-unit text-left">Unit</th>
                        <th class="col-range text-left">Reference Range</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var group in Model.ResultGroups)
                    {
                        <tr class="lab-group-row">
                            <td colspan="5" class="text-center group-header-td">
                                <span class="group-title-en">@(string.IsNullOrWhiteSpace(group.GroupNameEn) ? group.GroupNameAr : group.GroupNameEn)</span>
                            </td>
                        </tr>

                        @foreach (var row in group.Rows)
                        {
                            var flagCss = row.Flag == "H" ? "row-val-h" : row.Flag == "L" ? "row-val-l" : "row-val-n";
                            var arrow = row.Flag == "H" ? "&#8673;" : row.Flag == "L" ? "&#8675;" : string.Empty;
                            <tr class="@flagCss">
                                <td class="lab-test-col text-left test-name-val">
                                    @(string.IsNullOrWhiteSpace(row.TestNameEn) ? row.TestNameAr : row.TestNameEn)
                                </td>
                                <td class="lab-reading-col text-left reading-val">@row.Reading</td>
                                <td class="lab-flag-col text-center flag-icon">@Html.Raw(arrow)</td>
                                <td class="lab-unit-col text-left unit-val">@row.Unit</td>
                                <td class="lab-range-col text-left range-val">@row.ReferenceRange</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </section>

        <div class="lab-results-divider"></div>

        <footer class="lab-classic-footer">
            <div class="footer-left">
                <div><strong>Address:</strong> @Model.Footer.AddressAr</div>
                <div><strong>Phone:</strong> @Model.Footer.Phone</div>
            </div>
            <div class="footer-center">
                <div><strong>Print Date:</strong> @Model.Meta.PrintedAt.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
            <div class="footer-right">
                <strong>Signature:</strong> ________________
            </div>
        </footer>
    </article>

    <script>
        (function () {
            var autoPrint = (new URLSearchParams(window.location.search).get('autoPrint') || '').toLowerCase();
            if (autoPrint === 'true' || autoPrint === '1') {
                window.print();
            }
        })();
    </script>
</body>
</html>
