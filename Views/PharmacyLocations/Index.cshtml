@{
    ViewData["Title"] = "مواقع التخزين";
}

<div class="card border-0 shadow-sm rounded-3">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0 text-primary">
                <i class="bi bi-grid-3x3-gap-fill me-2"></i> مواقع التخزين
            </h5>
            <button type="button" class="btn btn-primary btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#quickCreateLocationModal">
                <i class="bi bi-plus-lg me-1"></i> إضافة موقع
            </button>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle text-center small w-100">
                <thead class="bg-light">
                    <tr>
                        <th class="border-0">الكود</th>
                        <th class="border-0">الوصف</th>
                        <th class="border-0">الحالة</th>
                        <th class="border-0">الإجراءات</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="quickCreateLocationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle-fill text-primary me-2"></i> إضافة موقع</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="quickCreateLocationForm" class="needs-validation" novalidate>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-bold">الكود *</label>
                            <input type="text" id="locationCode" class="form-control form-control-sm text-uppercase" required placeholder="A-2-05">
                            <div class="invalid-feedback">يرجى إدخال كود الموقع</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold">الوصف *</label>
                            <input type="text" id="locationDescription" class="form-control form-control-sm" required placeholder="Rack A Shelf 2 Slot 05">
                            <div class="invalid-feedback">يرجى إدخال وصف الموقع</div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light btn-sm rounded-pill px-3" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary btn-sm rounded-pill px-4 fw-bold" onclick="saveLocation()">حفظ</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="quickEditLocationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-pencil-square text-primary me-2"></i> تعديل موقع</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="quickEditLocationForm" class="needs-validation" novalidate>
                    <input type="hidden" id="editLocationId">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-bold">الكود *</label>
                            <input type="text" id="editLocationCode" class="form-control form-control-sm text-uppercase" required>
                            <div class="invalid-feedback">يرجى إدخال الكود</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold">الوصف *</label>
                            <input type="text" id="editLocationDescription" class="form-control form-control-sm" required>
                            <div class="invalid-feedback">يرجى إدخال الوصف</div>
                        </div>
                        <div class="col-12 mt-3">
                            <div class="form-check form-switch p-3 bg-light rounded-3 d-flex justify-content-between align-items-center">
                                <label class="form-check-label fw-bold mb-0" for="editLocationActive">حالة الموقع</label>
                                <input class="form-check-input ms-0 me-2" type="checkbox" role="switch" id="editLocationActive">
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light btn-sm rounded-pill px-3" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary btn-sm rounded-pill px-4 fw-bold" onclick="updateLocation()">حفظ التغييرات</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(function () {
            var columns = [
                { "data": "code", "render": function(d) { return `<span class="fw-bold text-primary">${d}</span>`; } },
                { "data": "description" },
                { "data": "isActive", "render": function(d, t, row) { return `<div class="form-check form-switch d-flex justify-content-center"><input class="form-check-input" type="checkbox" role="switch" ${d ? 'checked' : ''} onchange="toggleStatus(${row.id})"></div>`; } },
                { "data": "id", "orderable": false, "render": function(d, t, row) { return `<div class="action-group"><button type="button" class="btn-action btn-action-primary" data-label="تعديل" data-id="${d}" data-code="${row.code}" data-description="${row.description || ''}" data-active="${row.isActive}" onclick="openEditLocation(this)"><i class="bi bi-pencil-fill"></i></button></div>`; } }
            ];
            initDataTable('.table', '/PharmacyLocations/GetLocationsData', columns, { "pageLength": 10 });
        });

        function toggleStatus(id) {
            $.post('/PharmacyLocations/ToggleStatus/' + id, function (res) {
                if (!res.success) Swal.fire('خطأ', res.message || 'تعذر تغيير الحالة', 'error');
            });
        }

        function saveLocation() {
            const form = document.getElementById('quickCreateLocationForm');
            if (!form.checkValidity()) { form.classList.add('was-validated'); return; }

            const data = {
                code: $('#locationCode').val().toUpperCase(),
                description: $('#locationDescription').val()
            };
            $.ajax({
                url: '/PharmacyLocations/QuickCreate',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (res) {
                    if (res.success) location.reload();
                    else Swal.fire('خطأ', res.message, 'error');
                }
            });
        }

        function openEditLocation(btn) {
            const $btn = $(btn);
            $('#editLocationId').val($btn.data('id'));
            $('#editLocationCode').val($btn.data('code'));
            $('#editLocationDescription').val($btn.data('description'));
            $('#editLocationActive').prop('checked', $btn.data('active') === true);
            $('#quickEditLocationForm').removeClass('was-validated');
            new bootstrap.Modal(document.getElementById('quickEditLocationModal')).show();
        }

        function updateLocation() {
            const form = document.getElementById('quickEditLocationForm');
            if (!form.checkValidity()) { form.classList.add('was-validated'); return; }

            const data = {
                id: parseInt($('#editLocationId').val()),
                code: $('#editLocationCode').val().toUpperCase(),
                description: $('#editLocationDescription').val(),
                isActive: $('#editLocationActive').is(':checked')
            };
            $.ajax({
                url: '/PharmacyLocations/QuickEdit',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (res) {
                    if (res.success) location.reload();
                    else Swal.fire('خطأ', res.message, 'error');
                }
            });
        }
    </script>
}
