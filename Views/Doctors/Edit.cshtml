@model NagmClinic.ViewModels.DoctorViewModel

@{
    ViewData["Title"] = "تعديل بيانات الطبيب";
}

<!-- Auto-open Edit Modal -->
<div class="modal fade" id="editDoctorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0 px-4 pt-4">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-person-fill-gear text-primary me-2"></i> تعديل بيانات الطبيب
                </h5>
                <a asp-action="Index" class="btn-close" aria-label="Close"></a>
            </div>
            <div class="modal-body px-4">
                <form asp-action="Edit" method="post" id="editDoctorForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="NameAr" class="form-label small fw-bold">الاسم (عربي) *</label>
                            <span asp-validation-for="NameAr" class="text-danger small d-block mb-1"></span>
                            <input asp-for="NameAr" class="form-control form-control-sm" required placeholder="اسم الطبيب كاملاً">
                        </div>

                        <div class="col-12">
                            <label asp-for="Specialty" class="form-label small fw-bold">التخصص *</label>
                            <span asp-validation-for="Specialty" class="text-danger small d-block mb-1"></span>
                            <input asp-for="Specialty" class="form-control form-control-sm" required placeholder="مثال: باطنية، أطفال...">
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label small fw-bold">رقم الهاتف</label>
                            <span asp-validation-for="PhoneNumber" class="text-danger small d-block mb-1"></span>
                            <input asp-for="PhoneNumber" class="form-control form-control-sm" placeholder="09xxxxxxx">
                        </div>

                        <div class="col-md-6">
                            <label asp-for="RoomNumber" class="form-label small fw-bold">رقم الغرفة</label>
                            <span asp-validation-for="RoomNumber" class="text-danger small d-block mb-1"></span>
                            <input asp-for="RoomNumber" class="form-control form-control-sm" placeholder="101">
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ConsultationFee" class="form-label small fw-bold">سعر الكشف *</label>
                            <span asp-validation-for="ConsultationFee" class="text-danger small d-block mb-1"></span>
                            <input asp-for="ConsultationFee" class="form-control form-control-sm" required placeholder="0.00">
                        </div>

                        <div class="col-12">
                            <div class="form-check form-switch p-3 bg-light rounded-3 d-flex justify-content-between align-items-center">
                                <label class="form-check-label fw-bold mb-0" asp-for="IsActive">الحالة الوظيفية (نشط/غير نشط)</label>
                                <input class="form-check-input ms-0 me-2" type="checkbox" role="switch" asp-for="IsActive">
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 pt-0 px-4 pb-4">
                <a asp-action="Index" class="btn btn-light btn-sm rounded-pill px-3">إلغاء</a>
                <button type="submit" form="editDoctorForm" class="btn btn-primary btn-sm rounded-pill px-4">
                    <i class="bi bi-save me-1"></i> حفظ التغييرات
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function () {
            var modal = new bootstrap.Modal(document.getElementById('editDoctorModal'), { backdrop: 'static' });
            modal.show();
            document.getElementById('editDoctorModal').addEventListener('hidden.bs.modal', function () {
                window.location.href = '@Url.Action("Index")';
            });
        });
    </script>
}
