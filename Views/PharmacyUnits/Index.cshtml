@{
    ViewData["Title"] = "وحدات الصيدلية";
}

<div class="card border-0 shadow-sm rounded-3">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0 text-primary">
                <i class="bi bi-rulers me-2"></i> وحدات الصيدلية
            </h5>
            <button type="button" class="btn btn-primary btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#quickCreateUnitModal">
                <i class="bi bi-plus-lg me-1"></i> إضافة وحدة
            </button>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle text-center small w-100">
                <thead class="bg-light">
                    <tr>
                        <th class="border-0">اسم الوحدة</th>
                        <th class="border-0">الاسم الإنجليزي</th>
                        <th class="border-0">الحالة</th>
                        <th class="border-0">الإجراءات</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="quickCreateUnitModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle-fill text-primary me-2"></i> إضافة وحدة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="quickCreateUnitForm" class="needs-validation" novalidate>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-bold">اسم الوحدة *</label>
                            <input type="text" id="unitName" class="form-control form-control-sm" required>
                            <div class="invalid-feedback">يرجى إدخال اسم الوحدة</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold">الاسم الإنجليزي</label>
                            <input type="text" id="unitNameEn" class="form-control form-control-sm">
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light btn-sm rounded-pill px-3" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary btn-sm rounded-pill px-4 fw-bold" onclick="saveUnit()">حفظ</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="quickEditUnitModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-pencil-square text-primary me-2"></i> تعديل وحدة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="quickEditUnitForm" class="needs-validation" novalidate>
                    <input type="hidden" id="editUnitId">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-bold">اسم الوحدة *</label>
                            <input type="text" id="editUnitName" class="form-control form-control-sm" required>
                            <div class="invalid-feedback">يرجى إدخال اسم الوحدة</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold">الاسم الإنجليزي</label>
                            <input type="text" id="editUnitNameEn" class="form-control form-control-sm">
                        </div>
                        <div class="col-12 mt-3">
                            <div class="form-check form-switch p-3 bg-light rounded-3 d-flex justify-content-between align-items-center">
                                <label class="form-check-label fw-bold mb-0" for="editUnitActive">حالة الوحدة</label>
                                <input class="form-check-input ms-0 me-2" type="checkbox" role="switch" id="editUnitActive">
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light btn-sm rounded-pill px-3" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary btn-sm rounded-pill px-4 fw-bold" onclick="updateUnit()">حفظ التغييرات</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(function () {
            var columns = [
                { "data": "name", "render": function(d) { return `<span class="fw-bold">${d}</span>`; } },
                { "data": "nameEn", "render": function(d) { return d || '-'; } },
                { "data": "isActive", "render": function(d, t, row) { return `<div class="form-check form-switch d-flex justify-content-center"><input class="form-check-input" type="checkbox" role="switch" ${d ? 'checked' : ''} onchange="toggleStatus(${row.id})"></div>`; } },
                { "data": "id", "orderable": false, "render": function(d, t, row) { return `<div class="action-group"><button type="button" class="btn-action btn-action-primary" data-label="تعديل" data-id="${d}" data-name="${row.name}" data-nameen="${row.nameEn || ''}" data-active="${row.isActive}" onclick="openEditUnit(this)"><i class="bi bi-pencil-fill"></i></button></div>`; } }
            ];
            initDataTable('.table', '/PharmacyUnits/GetUnitsData', columns, { "pageLength": 10 });
        });

        function toggleStatus(id) {
            $.post('/PharmacyUnits/ToggleStatus/' + id, function (res) {
                if (!res.success) Swal.fire('خطأ', res.message || 'تعذر تغيير الحالة', 'error');
            });
        }

        function saveUnit() {
            const form = document.getElementById('quickCreateUnitForm');
            if (!form.checkValidity()) { form.classList.add('was-validated'); return; }

            const data = { name: $('#unitName').val(), nameEn: $('#unitNameEn').val() };
            $.ajax({
                url: '/PharmacyUnits/QuickCreate',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (res) {
                    if (res.success) location.reload();
                    else Swal.fire('خطأ', res.message, 'error');
                }
            });
        }

        function openEditUnit(btn) {
            const $btn = $(btn);
            $('#editUnitId').val($btn.data('id'));
            $('#editUnitName').val($btn.data('name'));
            $('#editUnitNameEn').val($btn.data('nameen'));
            $('#editUnitActive').prop('checked', $btn.data('active') === true);
            $('#quickEditUnitForm').removeClass('was-validated');
            new bootstrap.Modal(document.getElementById('quickEditUnitModal')).show();
        }

        function updateUnit() {
            const form = document.getElementById('quickEditUnitForm');
            if (!form.checkValidity()) { form.classList.add('was-validated'); return; }

            const data = {
                id: parseInt($('#editUnitId').val()),
                name: $('#editUnitName').val(),
                nameEn: $('#editUnitNameEn').val(),
                isActive: $('#editUnitActive').is(':checked')
            };

            $.ajax({
                url: '/PharmacyUnits/QuickEdit',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (res) {
                    if (res.success) location.reload();
                    else Swal.fire('خطأ', res.message, 'error');
                }
            });
        }
    </script>
}
