@* Shared row component for Pharmacy Sales/Purchases *@
@{
    var mode = ViewData["Mode"]?.ToString() ?? "sale";
    var idx = ViewData["Index"]?.ToString() ?? "{idx}";
}

<div class="pos-line-card pos-fade-in erp-line-row service-row @(mode == "sale" ? "sale-service-row" : "purchase-service-row") pos-specific-batch" id="line_row_@idx" data-line-index="@idx">
    <div class="pos-line-item">
        <span class="pos-field-label">الصنف <span class="text-danger">*</span></span>
        @if (mode == "sale")
        {
            <input type="hidden" id="Lines_@(idx)__Barcode" name="Lines[@(idx)].Barcode" data-field="Barcode" />
        }
        <select id="Lines_@(idx)__ItemId" name="Lines[@(idx)].ItemId" data-field="ItemId" class="form-select erp-input item-select @(mode == "sale" ? "sale-item-select" : "purchase-item-select")" required data-val="true" data-val-range="يرجى اختيار الصنف" data-val-range-min="1">
            <option value="">-- اختر الصنف --</option>
        </select>
        <span class="text-danger small field-validation-valid field-validation-inline" data-valmsg-for="Lines[@idx].ItemId" data-valmsg-replace="true" data-valmsg-field="ItemId"></span>
    </div>
    
    <div class="pos-line-qty">
        <span class="pos-field-label">الكمية</span>
        <input id="Lines_@(idx)__Quantity" name="Lines[@(idx)].Quantity" data-field="Quantity" type="number" class="form-control pos-qty-input qty-input @(mode == "sale" ? "sale-qty-input" : "purchase-qty-input")" value="1" min="0.01" step="0.01" required />
        <span class="text-danger small field-validation-valid field-validation-inline" data-valmsg-for="Lines[@idx].Quantity" data-valmsg-replace="true" data-valmsg-field="Quantity"></span>
    </div>

    @if (mode == "sale")
    {
        <div class="pos-line-price">
            <span class="pos-field-label">سعر البيع</span>
            <input id="Lines_@(idx)__SellingPrice" name="Lines[@(idx)].SellingPrice" data-field="SellingPrice" type="number" class="form-control pos-price-input sale-price-input" value="0.00" min="0.01" step="0.01" required />
            <span class="text-danger small field-validation-valid field-validation-inline" data-valmsg-for="Lines[@idx].SellingPrice" data-valmsg-replace="true" data-valmsg-field="SellingPrice"></span>
        </div>
    }
    else
    {
        <div class="pos-line-price">
            <span class="pos-field-label">سعر الشراء</span>
            <input id="Lines_@(idx)__PurchasePrice" name="Lines[@(idx)].PurchasePrice" data-field="PurchasePrice" type="number" class="form-control pos-price-input purchase-price-input" value="0.00" min="0.01" step="0.01" required />
        </div>
    }

    <div class="pos-line-fefo">
        @if (mode == "sale")
        {
            <span class="pos-field-label text-primary py-1"><i class="bi bi-info-circle-fill me-1"></i> تفاصيل المخزن</span>
            
            <div class="pos-specific-batch-indicator d-flex">
                <i class="bi bi-patch-check-fill text-info fs-5"></i>
                <div>
                   <div class="fw-bold batch-label-text">Auto (FEFO)</div>
                   <div class="small opacity-75 specific-batch-text" id="batch_chips_@idx">
                      <!-- Chips will be rendered here -->
                      <span class="text-muted">جاري التخصيص...</span>
                   </div>
                </div>
            </div>
        }
        
        @if (mode == "purchase")
        {
            <div class="mt-2 row g-1">
                <div class="col-12">
                    <input id="Lines_@(idx)__ExpiryDate" name="Lines[@(idx)].ExpiryDate" data-field="ExpiryDate" type="date" class="form-control form-control-sm" />
                </div>
                <div class="col-12 mt-1">
                    <div class="input-group input-group-sm">
                        <input id="Lines_@(idx)__Barcode" name="Lines[@(idx)].Barcode" data-field="Barcode" type="text" class="form-control line-barcode-input" placeholder="الباركود" />
                        <button type="button" class="btn btn-outline-primary btn-generate-barcode"><i class="bi bi-magic"></i></button>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="pos-line-total-wrap">
        <span class="pos-field-label">الإجمالي</span>
        <div class="pos-line-total-amount @(mode == "sale" ? "line-est-total" : "") line-total-display">0.00</div>
        <span class="pos-line-total-currency">ج.س</span>
    </div>

    <div class="pos-line-actions">
        <button type="button" class="btn btn-remove-pos btn-remove-line" title="حذف">
            <i class="bi bi-trash3-fill"></i>
        </button>
    </div>
</div>
