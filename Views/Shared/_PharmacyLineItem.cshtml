@* Shared row component for Pharmacy Sales/Purchases *@
@{
    var mode = ViewData["Mode"]?.ToString() ?? "sale";
    var idx = ViewData["Index"]?.ToString() ?? "{idx}";
}

<div class="pos-line-card pos-fade-in erp-line-row service-row @(mode == "sale" ? "sale-service-row pos-line-card--sale" : "purchase-service-row pos-line-card--purchase") pos-specific-batch row align-items-center g-2" 
     id="line_row_@idx" 
     data-line-index="@idx"
     data-item-id=""
     data-batch-id=""
     data-barcode="">
    <div class="pos-line-item pos-col-item col-12 col-lg-3">
        <span class="pos-field-label d-lg-none">الصنف <span class="text-danger">*</span></span>
        @if (mode == "sale")
        {
            <input type="hidden" id="Lines_@(idx)__Barcode" name="Lines[@(idx)].Barcode" data-field="Barcode" />
            <input type="hidden" id="Lines_@(idx)__ItemBatchId" name="Lines[@(idx)].ItemBatchId" data-field="ItemBatchId" />
        }
        <select id="Lines_@(idx)__ItemId" name="Lines[@(idx)].ItemId" data-field="ItemId" class="form-select erp-input item-select @(mode == "sale" ? "sale-item-select" : "purchase-item-select")" required data-val="true" data-val-required="يرجى اختيار الصنف لإتمام العملية." data-val-range="يرجى اختيار الصنف" data-val-range-min="1">
            <option value="">-- اختر الصنف --</option>
        </select>
    </div>
    
    <div class="pos-line-qty pos-col-qty col-6 text-center col-lg-2">
        <span class="pos-field-label d-lg-none">الكمية</span>
        @if (mode == "sale")
        {
            <div class="specific-batch-text mb-1"></div>
        }
        <input id="Lines_@(idx)__Quantity" name="Lines[@(idx)].Quantity" data-field="Quantity" type="number" class="form-control pos-qty-input qty-input px-1 text-center @(mode == "sale" ? "sale-qty-input" : "purchase-qty-input")" value="1" min="0.01" step="0.01" data-max="" required />
    </div>

    @if (mode == "sale")
    {
        <div class="pos-line-price pos-col-price col-6 text-center col-lg-2">
            <span class="pos-field-label d-lg-none">سعر البيع</span>
            <input id="Lines_@(idx)__SellingPrice" name="Lines[@(idx)].SellingPrice" data-field="SellingPrice" type="number" class="form-control pos-price-input sale-price-input" value="0" min="0.01" step="0.01" required />
        </div>
    }
    else
    {
        <div class="pos-line-price pos-col-price col-6 text-center col-lg-2">
            <span class="pos-field-label d-lg-none">سعر الشراء</span>
            <input id="Lines_@(idx)__PurchasePrice" name="Lines[@(idx)].PurchasePrice" data-field="PurchasePrice" type="number" class="form-control pos-price-input purchase-price-input" value="0" min="0.01" step="0.01" required />
        </div>
    }

    <div class="pos-line-fefo pos-col-details col-12 col-lg-2">
        @if (mode == "sale")
        {
            <div class="row g-1 align-items-center">
                <div class="col-12">
                    <div class="input-group input-group-sm flex-nowrap">
                        <input id="Lines_@(idx)__Barcode" name="Lines[@(idx)].Barcode" data-field="Barcode" type="text" class="form-control line-barcode-input text-center px-1" placeholder="الباركود..." style="min-width: 0;" />
                        <button type="button" class="btn btn-outline-primary btn-generate-barcode px-2" style="flex-shrink: 0;"><i class="bi bi-magic"></i></button>
                    </div>
                </div>
            </div>
        }
        
        @if (mode == "purchase")
        {
            <div class="d-flex flex-column gap-1">
                <input id="Lines_@(idx)__ExpiryDate" name="Lines[@(idx)].ExpiryDate" data-field="ExpiryDate" type="date" class="form-control form-control-sm text-center px-1" title="تاريخ الصلاحية" />
                <div class="input-group input-group-sm flex-nowrap">
                    <input id="Lines_@(idx)__Barcode" name="Lines[@(idx)].Barcode" data-field="Barcode" type="text" class="form-control line-barcode-input text-center px-1" placeholder="الباركود..." style="min-width: 0;" />
                    <button type="button" class="btn btn-outline-primary btn-generate-barcode px-2" style="flex-shrink: 0;"><i class="bi bi-magic"></i></button>
                </div>
            </div>
        }
    </div>

    <div class="pos-line-total-wrap pos-col-total col-6 text-center col-lg-2">
        <span class="pos-field-label d-lg-none">الإجمالي</span>
        <div class="pos-line-total-amount @(mode == "sale" ? "line-est-total" : "") line-total-display">0.00</div>
        <span class="pos-line-total-currency">ج.س</span>
    </div>

    <div class="pos-line-actions pos-col-actions col-6 text-end col-lg-1">
        <button type="button" class="btn btn-remove-pos btn-remove-line" title="حذف">
            <i class="bi bi-trash3-fill"></i>
        </button>
    </div>
</div>
