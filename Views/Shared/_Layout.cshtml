<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @BrandingService.GetBranding().CenterNameAr</title>

    <!-- Cairo Font -->
    <link rel="stylesheet" href="~/css/cairo-font.css" asp-append-version="true" />

    <!-- Bootstrap 5 RTL -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- SweetAlert2 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />

    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />

    <!-- Custom Clinic Styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @if (TempData["AlertMessage"] != null)
    {
        <meta name="alert-message" content="@TempData["AlertMessage"]" />
        <meta name="alert-type" content="@TempData["AlertType"]" />
    }
</head>
<body>

    <!-- Sidebar -->
    <partial name="_Sidebar" />

    <!-- Overlay for mobile -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <!-- Main Content -->
    <div class="main-wrapper">
        <!-- Topbar -->
        <header class="topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-link d-lg-none p-0 text-dark fs-5" onclick="toggleSidebar()">
                    <i class="bi bi-list"></i>
                </button>
                <button class="btn btn-sm btn-light d-none d-lg-inline-flex align-items-center justify-content-center sidebar-mini-toggle"
                        type="button"
                        onclick="toggleSidebarMini()"
                        aria-label="تصغير القائمة الجانبية"
                        title="تصغير القائمة الجانبية">
                    <i class="bi bi-layout-sidebar-inset"></i>
                </button>
                <div class="d-none d-md-block">
                    <partial name="_Breadcrumbs" />
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <div class="dropdown">
                    <button class="btn btn-light btn-sm rounded-pill d-flex align-items-center gap-2 px-3" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle fs-5"></i>
                        <span class="d-none d-sm-inline">@(User.Identity?.Name ?? "زائر")</span>
                        <i class="bi bi-chevron-down small"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-start shadow-sm border-0">
                        <partial name="_LoginPartial" />
                    </ul>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <main class="page-content">
            @RenderBody()
        </main>

        <!-- Global Modal -->
        <div class="modal fade" id="appModal" tabindex="-1" aria-labelledby="appModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg rounded-4">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold" id="appModalLabel"></h5>
                        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body pt-2" id="appModalBody">
                        <!-- Content loaded via AJAX -->
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-2 text-muted">جاري تحميل البيانات...</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <footer class="app-footer">
            <p class="mb-0">@DateTime.Now.Year © @BrandingService.GetBranding().CenterNameAr - <span class="small">Designed by Elharith Elsiidiq</span></p>
        </footer>
    </div>

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>

    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script src="~/js/shared-datatable.js" asp-append-version="true"></script>
    
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        $(function () {
            var alertMsg = $('meta[name="alert-message"]').attr('content');
            var alertType = $('meta[name="alert-type"]').attr('content') || 'success';
            if (alertMsg) {
                Swal.fire({
                    icon: alertType,
                    title: alertType === 'success' ? 'نجاح' : 'تنبيه',
                    text: alertMsg,
                    confirmButtonColor: '#4361ee'
                });
            }
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

