@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index"><i class="bi bi-gear me-2"></i> إدارة الحساب</a></li>
    <li><hr class="dropdown-divider"></li>
    <li>
        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i> تسجيل الخروج</button>
        </form>
    </li>
}
else
{
    <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Login"><i class="bi bi-box-arrow-in-left me-2"></i> تسجيل الدخول</a></li>
    <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Register"><i class="bi bi-person-plus me-2"></i> تسجيل جديد</a></li>
}
