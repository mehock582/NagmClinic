@model NagmClinic.Models.Appointment
@using NagmClinic.Models.Enums

@{
    ViewData["Title"] = "تفاصيل الحجز وفاتورة الخدمات";

    string GetPrintItemName(NagmClinic.Models.AppointmentItem item)
    {
        if (item.Service == null)
        {
            return "-";
        }

        if (item.Service.Type == ServiceType.LabTest)
        {
            if (!string.IsNullOrWhiteSpace(item.Service.NameEn))
            {
                return item.Service.NameEn;
            }

            if (!string.IsNullOrWhiteSpace(item.Service.Code))
            {
                return item.Service.Code;
            }

            return "-";
        }

        if (!string.IsNullOrWhiteSpace(item.Service.NameAr))
        {
            return item.Service.NameAr;
        }

        if (!string.IsNullOrWhiteSpace(item.Service.NameEn))
        {
            return item.Service.NameEn;
        }

        return "-";
    }
}

<div class="row justify-content-center">
    <div class="col-12" style="max-width: 900px;">
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">
                        <i class="bi bi-receipt text-primary me-2"></i> تفاصيل الحجز رقم: <span class="badge bg-primary rounded-pill">@Model.DailyNumber</span>
                    </h5>
                    <div class="d-flex gap-2 no-print">
                        <button onclick="window.print()" class="btn btn-outline-dark btn-sm rounded-pill px-3"><i class="bi bi-printer me-1"></i> طباعة</button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3">العودة</a>
                    </div>
                </div>

                <div class="row g-4 mb-4">
                    @if (Model.Status == AppointmentStatus.Cancelled)
                    {
                        <div class="col-12">
                            <div class="alert alert-danger border-0 rounded-3 d-flex align-items-center gap-2 mb-0 py-2">
                                <i class="bi bi-x-octagon-fill fs-5"></i>
                                <div>
                                    <strong>هذا الحجز ملغي</strong> — جميع المبالغ المالية المرتبطة به تم إلغاؤها ولن تدخل في الحسابات المالية.
                                </div>
                            </div>
                        </div>
                    }
                    <div class="col-md-6">
                        <div class="bg-light rounded-3 p-3">
                            <h6 class="text-primary fw-bold mb-2"><i class="bi bi-person me-1"></i> بيانات المريض</h6>
                            <p class="mb-1"><strong>الاسم:</strong> @(Model.Patient?.FullName ?? "مريض غير معروف")</p>
                            <p class="mb-1"><strong>الهاتف:</strong> @(Model.Patient?.PhoneNumber ?? "-")</p>
                            <p class="mb-0"><strong>النوع:</strong> @(Model.Patient?.Gender == Gender.Male ? "ذكر" : "أنثى")</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="bg-light rounded-3 p-3">
                            <h6 class="text-primary fw-bold mb-2"><i class="bi bi-clipboard2-pulse me-1"></i> بيانات الكشف</h6>
                            <p class="mb-1"><strong>التاريخ:</strong> @Model.AppointmentDate.ToString("dd/MM/yyyy - hh:mm tt")</p>
                            <p class="mb-1"><strong>الطبيب:</strong> @(Model.Doctor?.NameAr ?? "غير محدد")</p>
                            <p class="mb-1"><strong>سعر الكشف:</strong>
                                @if (Model.Status == AppointmentStatus.Cancelled)
                                {
                                    <span class="text-danger text-decoration-line-through">@Model.ConsultationFee.ToString("N2")</span>
                                    <span class="badge bg-danger ms-1">ملغي</span>
                                }
                                else
                                {
                                    @Model.ConsultationFee.ToString("N2") <text>ج.س</text>
                                }
                            </p>
                            @if (Model.ConsultationFee == 0 && !string.IsNullOrEmpty(Model.ZeroFeeReason) && Model.Status != AppointmentStatus.Cancelled)
                            {
                                <p class="mb-1"><strong>سبب الإعفاء:</strong> <span class="text-warning fw-bold">@Model.ZeroFeeReason</span></p>
                            }
                            <p class="mb-0"><strong>الحالة:</strong>
                                @switch (Model.Status)
                                {
                                    case AppointmentStatus.Confirmed: <span class="badge bg-success rounded-pill">مؤكد</span> break;
                                    case AppointmentStatus.Cancelled: <span class="badge bg-danger rounded-pill">ملغي</span> break;
                                }
                            </p>
                        </div>
                    </div>
                </div>

                <h6 class="text-primary fw-bold mb-3"><i class="bi bi-list-check me-1"></i> الخدمات والفحوصات</h6>
                <div class="table-responsive">
                    <table class="table table-hover align-middle text-center">
                        <thead class="table-light">
                            <tr>
                                <th>الخدمة / الفحص</th>
                                <th>الكمية</th>
                                <th>السعر الأفردي</th>
                                <th>المجموع</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.AppointmentItems != null)
                            {
                                @foreach (var item in Model.AppointmentItems)
                                {
                                    bool isRefunded = item.Status == PaymentStatus.Refunded;
                                    var rowClass = isRefunded ? "text-muted text-decoration-line-through bg-light" : "";
                                    <tr>
                                        <td class="@rowClass">@GetPrintItemName(item) @(isRefunded ? "(مسترجع)" : "")</td>
                                        <td class="@rowClass">@item.Quantity</td>
                                        <td class="@rowClass">@item.UnitPrice.ToString("N2")</td>
                                        <td class="fw-bold @rowClass">@item.TotalPrice.ToString("N2")</td>
                                        <td>
                                            <button onclick="printSingleItem('@item.Id', '@item.TotalPrice.ToString("N2")')" class="btn btn-sm btn-outline-dark me-1" title="طباعة فاتورة منفصلة"><i class="bi bi-printer"></i></button>
                                            @if (!isRefunded)
                                            {
                                                <button onclick="refundItem(@item.Id)" class="btn btn-sm btn-outline-danger" title="استرجاع"><i class="bi bi-arrow-counterclockwise"></i></button>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot>
                            @{
                                var billableTotal = Model.Status == AppointmentStatus.Cancelled 
                                    ? 0m 
                                    : (Model.ConsultationFee + (Model.AppointmentItems?.Sum(i => i.TotalPrice) ?? 0));
                            }
                            <tr class="@(Model.Status == AppointmentStatus.Cancelled ? "table-danger" : "table-dark")">
                                <th colspan="3" class="text-end">
                                    @(Model.Status == AppointmentStatus.Cancelled ? "الإجمالي (ملغي):" : "الإجمالي المستحق:")
                                </th>
                                <th>
                                    @if (Model.Status == AppointmentStatus.Cancelled)
                                    {
                                        <span class="text-decoration-line-through">@billableTotal.ToString("N2")</span> <text>ج.س</text>
                                    }
                                    else
                                    {
                                        @billableTotal.ToString("N2") <text>ج.س</text>
                                    }
                                </th>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div class="mt-3 p-3 bg-light rounded-3">
                        <strong><i class="bi bi-chat-left-text me-1"></i> ملاحظات:</strong> @Model.Notes
                    </div>
                }
                @if (Model.ConsultationFee == 0 && !string.IsNullOrEmpty(Model.ZeroFeeReason) && Model.Status != AppointmentStatus.Cancelled)
                {
                    <div class="mt-2 p-3 bg-warning bg-opacity-10 rounded-3 border border-warning border-opacity-25">
                        <strong><i class="bi bi-exclamation-triangle me-1 text-warning"></i> سبب الإعفاء من الرسوم:</strong> @Model.ZeroFeeReason
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Receipt for Thermal Printing (Hidden on screen) -->
<!-- Receipt for Thermal Printing (Consistent with Laboratory layout) -->
<div id="thermalReceipt" class="receipt d-none">
    <div style="text-align:center; margin-bottom: 15px; border-bottom: 1px dashed #ccc; padding-bottom: 10px;">
        <h3 style="margin: 0; font-size: 16px;">@BrandingService.GetBranding().CenterNameAr</h3>
        <p style="margin: 5px 0; font-size: 12px;">فاتورة خدمات طبية</p>
    </div>

    <div style="margin-bottom: 10px; font-size: 13px; border-bottom: 2px solid #000; padding-bottom: 5px;">
        <table style="width: 100%; border-collapse: collapse; table-layout: fixed;">
            <tr>
                <td style="width: 35%; font-weight: bold; padding: 2px 0;">رقم الحجز:</td>
                <td style="text-align: left;">@Model.DailyNumber</td>
            </tr>
            <tr>
                <td style="font-weight: bold; padding: 2px 0;">التاريخ:</td>
                <td style="text-align: left;">@Model.AppointmentDate.ToString("dd/MM/yyyy HH:mm")</td>
            </tr>
            <tr>
                <td style="font-weight: bold; padding: 2px 0;">المريض:</td>
                <td style="text-align: left; font-weight: bold;">@(Model.Patient?.FullName)</td>
            </tr>
            <tr>
                <td style="font-weight: bold; padding: 2px 0;">الطبيب:</td>
                <td style="text-align: left;">@(Model.Doctor?.NameAr)</td>
            </tr>
        </table>
    </div>

    <div style="border-bottom: 1px dashed #ccc; margin-bottom: 10px; padding-bottom: 10px;">
        <table style="width: 100%; font-size: 13px; border-collapse: collapse; table-layout: fixed; direction: rtl;">
            <thead>
                <tr style="border-bottom: 1px solid #000;">
                    <th style="padding: 5px 0; text-align: right; width: 68%;">الخدمة</th>
                    <th style="padding: 5px 0; text-align: left; width: 32%;">السعر</th>
                </tr>
            </thead>
            <tbody>
                <tr class="thermal-item-row" data-id="consultation">
                    <td style="padding: 8px 0;">كشف طبي</td>
                    <td style="padding: 8px 0; text-align: left;">@Model.ConsultationFee.ToString("N2")</td>
                </tr>
                @if (Model.AppointmentItems != null)
                {
                    @foreach (var item in Model.AppointmentItems)
                    {
                        if (item.Status != PaymentStatus.Refunded)
                        {
                            <tr class="thermal-item-row" data-id="@item.Id">
                                <td style="padding: 5px 0;">@GetPrintItemName(item)</td>
                                <td style="padding: 5px 0; text-align: left;">@item.TotalPrice.ToString("N2")</td>
                            </tr>
                        }
                    }
                }
            </tbody>
        </table>
    </div>

    <div style="margin-top: 10px;">
        @{
            var receiptTotal = Model.Status == AppointmentStatus.Cancelled 
                ? 0m 
                : (Model.ConsultationFee + (Model.AppointmentItems?.Sum(i => i.TotalPrice) ?? 0));
        }
        <div style="display: flex; justify-content: space-between; align-items: center; padding: 5px 0;">
            <h4 style="margin: 0; font-size: 16px;">الإجمالي:</h4>
            <h4 style="margin: 0; font-size: 16px;" id="receiptTotalValue">@receiptTotal.ToString("N2") ج.س</h4>
        </div>

        @if (Model.Status == AppointmentStatus.Cancelled)
        {
            <div style="text-align: center; margin: 5px 0; border: 1px solid #000; padding: 5px; font-weight: bold; font-size: 12px;">
                هذا الحجز ملغي - لا يستحق الدفع
            </div>
        }
        @if (Model.ConsultationFee == 0 && !string.IsNullOrEmpty(Model.ZeroFeeReason) && Model.Status != AppointmentStatus.Cancelled)
        {
            <p style="font-size: 11px; margin: 5px 0; font-style: italic;">سبب الإعفاء: @Model.ZeroFeeReason</p>
        }
    </div>

    <div style="text-align:center; margin-top: 15px; border-top: 1px dashed #ccc; padding-top: 10px; font-size: 11px;">
        <p style="margin: 2px 0;">نتمنى لكم دوام الصحة والعافية</p>
        <p style="margin: 0; font-size: 10px;">شكراً لزيارتكم</p>
        <p style="margin: 5px 0; font-size: 9px; opacity: 0.8;">Designed by Elharith Elsiidiq</p>
    </div>
</div>

<style>
    @@media print {
        /* UI Resets */
        body { margin: 0 !important; padding: 0 !important; background: #fff !important; }
        .sidebar, .topbar, .app-footer, .no-print, .card, .btn, .alert, .row { display: none !important; }
        .main-wrapper, .page-content { margin: 0 !important; padding: 0 !important; width: 100% !important; overflow: hidden !important; }
        
        @@page { 
            size: 80mm auto; 
            margin: 0; 
        }
        
        #thermalReceipt { 
            display: block !important;
            width: 68mm; /* Narrow enough to never touch edges of 80mm roll */
            margin: 0 auto;
            direction: rtl;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding: 5mm 6mm; /* Safety horizontal padding */
            color: #000;
            line-height: 1.4;
            overflow: hidden;
            word-wrap: break-word;
            overflow-wrap: break-word;
            box-sizing: border-box;
        }

        #thermalReceipt > div {
            width: 100% !important;
            box-sizing: border-box;
            overflow: hidden;
        }

        #thermalReceipt table { 
            table-layout: fixed !important;
            width: 100% !important;
            border-collapse: collapse;
        }

        #thermalReceipt td, #thermalReceipt th {
            overflow: hidden;
            word-wrap: break-word;
            overflow-wrap: break-word;
            word-break: normal;
            padding: 4px 0;
            vertical-align: top;
        }

    }
</style>

@section Scripts {
    <script>
        function printSingleItem(id, priceStr) {
            $('.thermal-item-row').hide();
            $('.thermal-item-row[data-id="' + id + '"]').show();
            
            let $totalEl = $('#receiptTotalValue');
            let originalTotal = $totalEl.text();
            $totalEl.text(priceStr + ' ج.س');
            
            window.print();
            
            setTimeout(function() {
                $('.thermal-item-row').show();
                $totalEl.text(originalTotal);
            }, 500);
        }

        function refundItem(id) {
            Swal.fire({
                title: 'تأكيد الاسترجاع',
                text: 'هل أنت متأكد من رغبتك في استرجاع هذه الخدمة؟ (سيتم تصفير المبلغ المالي)',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'نعم، تأكيد الاسترجاع',
                cancelButtonText: 'إلغاء',
                reverseButtons: true // Consistent with RTL
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("RefundItem", "Appointments")', { id: id }, function(res) {
                        if (res.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'تم الاسترجاع',
                                text: res.message,
                                showConfirmButton: false,
                                timer: 1500
                            }).then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'خطأ',
                                text: res.message || 'حدث خطأ أثناء الاسترجاع'
                            });
                        }
                    }).fail(function() {
                        Swal.fire({
                            icon: 'error',
                            title: 'خطأ في الاتصال',
                            text: 'تعذر الاتصال بالخادم.'
                        });
                    });
                }
            });
        }

        $(document).ready(function() {
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('print') === 'true') {
                window.print();
            }
        });
    </script>
}

