@model NagmClinic.ViewModels.AppointmentCreateViewModel

@{
    ViewData["Title"] = "حجز جديد (استقبال)";
}

<div class="row justify-content-center">
    <div class="col-12 reception-container">
        <form asp-action="Create" id="appointmentForm">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 p-2 small border-0 mb-3"></div>

            <!-- 1) Patient Section -->
            <div class="card border-0 shadow-sm rounded-3 mb-3">
                <div class="card-header text-primary">
                    <i class="bi bi-person-fill me-2"></i> بيانات المريض
                </div>
                <div class="card-body p-3">

                    <div id="patientSearchContainer">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted small"></i></span>
                            <input type="text" id="patientSearch" class="form-control" placeholder="ابحث بالاسم أو رقم الهاتف..." autocomplete="off">
                            <button type="button" class="btn btn-primary fw-bold" data-bs-toggle="modal" data-bs-target="#newPatientModal">
                                <i class="bi bi-person-plus me-1"></i> مريض جديد
                            </button>
                        </div>
                        <div class="position-relative">
                            <div id="patientResults" class="list-group position-absolute w-100 shadow-lg rounded-3 border-0 mt-1" style="display:none; z-index:1050;"></div>
                        </div>
                    </div>

                    <div id="selectedPatientInfo" class="mt-2 p-2 bg-success-light rounded-3 border border-success border-opacity-25" style="display:none;">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-success text-white rounded-circle p-1 d-flex align-items-center justify-content-center" style="width:32px; height:32px;">
                                    <i class="bi bi-check-lg"></i>
                                </div>
                                <div class="lh-sm">
                                    <div class="fw-bold text-dark fs-6" id="displayName"></div>
                                    <div class="text-muted small" id="displayPhone"></div>
                                </div>
                            </div>
                            <button type="button" class="btn btn-outline-danger btn-sm rounded-pill px-3 py-1 fw-bold small" onclick="clearPatientSelection()">
                                <i class="bi bi-arrow-repeat me-1"></i> تغيير المريض
                            </button>
                        </div>
                    </div>

                    <input type="hidden" asp-for="PatientId" id="selectedPatientId" />
                    <span asp-validation-for="PatientId" class="text-danger small fw-bold d-block mt-1"></span>
                </div>
            </div>

            <!-- 2) Doctor & Appointment Info -->
            <div class="card border-0 shadow-sm rounded-3 mb-3">
                <div class="card-header text-primary">
                    <i class="bi bi-clipboard2-pulse me-2"></i> بيانات الكشف
                </div>
                <div class="card-body p-3">
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label asp-for="DoctorId" class="form-label small mb-1">الطبيب المختص</label>
                            <select asp-for="DoctorId" class="form-select" asp-items="Model.AvailableDoctors" id="doctorSelect" onchange="updateDoctorFee()">
                                <option value="">-- يرجى اختيار الطبيب --</option>
                            </select>
                            <span asp-validation-for="DoctorId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small mb-1">سعر الكشف</label>
                            <input asp-for="ConsultationFee" id="consultationFee" class="form-control" oninput="onFeeChanged()" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="AppointmentDate" class="form-label small mb-1">موعد الحجز</label>
                            <input asp-for="AppointmentDate" asp-format="{0:yyyy-MM-ddTHH:mm}" class="form-control" type="datetime-local" step="60" />
                            <span asp-validation-for="AppointmentDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Zero-fee reason (shown only when fee = 0) -->
                    <div id="zeroFeeReasonContainer" class="mt-2" style="display:none;">
                        <div class="alert alert-warning border-0 rounded-3 p-2 mb-0 d-flex align-items-start gap-2">
                            <i class="bi bi-exclamation-triangle-fill text-warning mt-1"></i>
                            <div class="flex-grow-1">
                                <label class="form-label small fw-bold mb-1">سبب الإعفاء من الرسوم <span class="text-danger">*</span></label>
                                <input asp-for="ZeroFeeReason" id="zeroFeeReason" class="form-control form-control-sm" placeholder="مثال: حالة طوارئ / كشف مجاني / حالة داخلية..." />
                            </div>
                        </div>
                    </div>
                </div>
            </div>


            <!-- 4) Notes & Total -->
            <div class="row g-2 mb-3">
                <div class="col-lg-7">
                    <div class="card border-0 shadow-sm rounded-3 h-100">
                        <div class="card-body p-3">
                            <h6 class="text-primary fw-bold mb-2 small"><i class="bi bi-pencil-square me-2"></i> ملاحظات</h6>
                            <textarea asp-for="Notes" class="form-control small" rows="2" placeholder="أضف ملاحظات (اختياري)..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="card border-0 shadow-sm rounded-3 total-box text-white h-100">
                        <div class="card-body p-3 d-flex justify-content-between align-items-center">
                            <div class="text-white-50 fw-bold small"><i class="bi bi-cash-coin me-2"></i> الإجمالي</div>
                            <div class="text-end">
                                <h2 class="mb-0 fw-bolder"><span id="grandTotal">0.00</span> <small class="fs-6 fw-normal op-70">ج.س</small></h2>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <input type="hidden" asp-for="PrintReceipt" id="printReceiptFlag" value="false" />

            <!-- 5) Action Buttons -->
            <div class="d-flex justify-content-center gap-3 mb-4 mt-2 pt-2">
                <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold px-4 shadow-sm" onclick="$('#printReceiptFlag').val('false')">
                    <i class="bi bi-check-lg me-1"></i> حفظ الحجز
                </button>
                <button type="submit" class="btn btn-success btn-lg rounded-pill fw-bold px-4 shadow-sm" onclick="$('#printReceiptFlag').val('true')">
                    <i class="bi bi-printer-fill me-1"></i> حفظ وطباعة
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill fw-bold px-4">
                    إلغاء
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Quick Create Patient Modal (Shared Partial) -->
<partial name="_QuickCreatePatientModal" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var doctorFees = @Html.Raw(Json.Serialize(Model.DoctorFees));

        $(document).ready(function () {
            // Set callback for the shared Quick-Create Patient modal
            window.onPatientCreated = function(id, name, phone) {
                selectPatient(id, name, phone);
            };

            $('#patientSearch').on('input', function () {
                var query = $(this).val();
                if (query.length < 2) { $('#patientResults').hide(); return; }

                $.get('/Patients/Search?query=' + query, function (data) {
                    var html = '';
                    if (data.length > 0) {
                        data.forEach(function (item) {
                            html += '<a href="javascript:void(0)" class="list-group-item list-group-item-action py-2" onclick="selectPatient(' + item.id + ', \'' + item.fullName + '\', \'' + item.phoneNumber + '\')">' +
                                '<div class="fw-bold">' + item.fullName + '</div>' +
                                '<small class="text-muted"><i class="bi bi-phone me-1"></i>' + item.phoneNumber + '</small></a>';
                        });
                    } else {
                        html = '<div class="list-group-item text-muted text-center py-3">لم يتم العثور على نتائج</div>';
                    }
                    $('#patientResults').html(html).show();
                });
            });

            $(document).click(function (e) {
                if (!$(e.target).closest('#patientSearchContainer').length) {
                    $('#patientResults').hide();
                }
            });

            $('#patientSearch').keypress(function (e) { if (e.keyCode == 13) e.preventDefault(); });

            var validator = $('#appointmentForm').data('validator');
            if (validator) {
                validator.settings.ignore = ':hidden:not(#selectedPatientId)';
            }

            // Check initial fee value
            onFeeChanged();
        });

        function validatePatientSelection() {
            var patientIdInput = $('#selectedPatientId');
            var patientSearchInput = $('#patientSearch');
            var validator = $('#appointmentForm').data('validator');

            if (validator) {
                validator.settings.ignore = ':hidden:not(#selectedPatientId)';
            }

            var isValid = $.isFunction(patientIdInput.valid)
                ? patientIdInput.valid()
                : (parseInt(patientIdInput.val(), 10) || 0) > 0;

            patientSearchInput.toggleClass('is-invalid', !isValid);
            return isValid;
        }

        function selectPatient(id, name, phone) {
            $('#selectedPatientId').val(id);
            $('#displayName').text(name);
            $('#displayPhone').text(phone);
            $('#patientSearchContainer').hide();
            $('#selectedPatientInfo').fadeIn(200);
            $('#patientResults').hide();
            validatePatientSelection();
        }

        function clearPatientSelection() {
            $('#selectedPatientId').val('');
            $('#selectedPatientInfo').hide();
            $('#patientSearchContainer').fadeIn(200);
            $('#patientSearch').val('').focus();
            $('#patientSearch').removeClass('is-invalid');
            $('[data-valmsg-for="PatientId"]').text('').removeClass('field-validation-error').addClass('field-validation-valid');
        }

        function updateDoctorFee() {
            var selectedDoctorId = $('#doctorSelect').val();
            var fee = parseDecimal(selectedDoctorId && doctorFees[selectedDoctorId] ? doctorFees[selectedDoctorId] : 0);
            $('#consultationFee').val(fee.toFixed(2));
            onFeeChanged();
        }

        function onFeeChanged() {
            var fee = parseDecimal($('#consultationFee').val());
            $('#grandTotal').text(fee.toFixed(2));

            if (fee === 0) {
                $('#zeroFeeReasonContainer').slideDown(200);
            } else {
                $('#zeroFeeReasonContainer').slideUp(200);
                $('#zeroFeeReason').val('');
            }
        }

        function parseDecimal(value) {
            if (value === undefined || value === null) {
                return 0;
            }

            if (typeof value === 'number') {
                return value;
            }

            var normalized = value.toString().trim();
            if (!normalized) {
                return 0;
            }

            if (normalized.indexOf(',') > -1 && normalized.indexOf('.') > -1) {
                normalized = normalized.replace(/,/g, '');
            } else if (normalized.indexOf(',') > -1) {
                normalized = normalized.replace(',', '.');
            }

            var parsed = parseFloat(normalized);
            return isNaN(parsed) ? 0 : parsed;
        }

        // Form submission validation: require reason if fee is 0
        $('#appointmentForm').on('submit', function (e) {
            if (!validatePatientSelection()) {
                e.preventDefault();
                $('#patientSearch').focus();
                return false;
            }

            var fee = parseDecimal($('#consultationFee').val());
            if (fee === 0 && !$('#zeroFeeReason').val().trim()) {
                e.preventDefault();
                Swal.fire({
                    icon: 'warning',
                    title: 'سبب الإعفاء مطلوب',
                    text: 'يرجى إدخال سبب الإعفاء من الرسوم عند تسجيل موعد بقيمة صفر.',
                    confirmButtonColor: '#4361ee'
                });
                return false;
            }
        });
    </script>
}

