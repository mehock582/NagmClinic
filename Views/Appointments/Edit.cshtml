@model NagmClinic.ViewModels.AppointmentCreateViewModel

@{
    ViewData["Title"] = "تعديل الحجز ومتابعة الخدمات";
    var patientName = Model.PatientName;
    var doctorName = Model.DoctorName;
    var dailyNumber = Model.DailyNumber;
}

<div class="row justify-content-center">
    <div class="col-12 reception-container">
        <form asp-action="Edit" id="appointmentForm">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 p-2 small border-0 mb-3"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="PatientId" />
            <input type="hidden" asp-for="DoctorId" />
            <input type="hidden" asp-for="AppointmentDate" />

            <!-- 1) Patient & Doctor Info (Read-only in Edit) -->
            <div class="card border-0 shadow-sm rounded-3 mb-3">
                <div class="card-body p-3">
                    <div class="row g-2 align-items-center">
                        <div class="col-md-4">
                            <h6 class="text-primary mb-1 small fw-bold">رقم الحجز: <span class="text-dark">@dailyNumber</span></h6>
                            <div class="fw-bold fs-5">@patientName</div>
                            <div class="text-muted small">@Model.AppointmentDate.ToString("dd/MM/yyyy - hh:mm tt")</div>
                        </div>
                        <div class="col-md-3 text-center border-start border-end">
                            <h6 class="text-muted small mb-1">الطبيب المختص</h6>
                            <div class="fw-bold text-dark">د. @doctorName</div>
                        </div>
                        <div class="col-md-2 text-center border-end">
                            <label class="form-label small mb-1">سعر الكشف</label>
                            <input asp-for="ConsultationFee" id="consultationFee" class="form-control form-control-sm" oninput="calculateGrandTotal()" />
                        </div>
                        <div class="col-md-3 text-end">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3">العودة للقائمة</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 2) Services / Lab Tests -->
            <div class="card border-0 shadow-sm rounded-3 mb-3">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="text-primary fw-bold mb-0"><i class="bi bi-list-check me-2"></i> الخدمات والفحوصات</h6>
                        <button type="button" class="btn btn-outline-primary rounded-pill fw-bold px-3 py-1 small" onclick="addRow()">
                            <i class="bi bi-plus-lg me-1 small"></i> إضافة خدمة/فحص
                        </button>
                    </div>

                    <div id="itemsBody">
                        @for (int i = 0; i < Model.Items.Count; i++)
                        {
                            <div class="row g-2 p-2 align-items-center bg-light rounded-2 border service-row mb-1" id="row_@i">
                                <div class="col-md-5 col-12">
                                    <select name="Items[@i].ServiceId" class="form-select form-select-sm service-select" required onchange="updatePrice(@i)">
                                        <option value="">-- اختر الخدمة --</option>
                                        @foreach (var s in Model.ServicesData)
                                        {
                                            <option value="@s.Id" data-price="@s.Price" selected="@(s.Id == Model.Items[i].ServiceId)">@s.NameAr</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2 col-4">
                                    <input type="number" name="Items[@i].Quantity" class="form-control form-control-sm qty-input text-center" value="@Model.Items[i].Quantity" min="1" onchange="updateRowTotal(@i)">
                                </div>
                                <div class="col-md-2 col-4">
                                    <input type="number" name="Items[@i].UnitPrice" class="form-control form-control-sm price-input text-center" value="@Model.Items[i].UnitPrice" step="0.01" onchange="updateRowTotal(@i)">
                                </div>
                                <div class="col-md-2 col-4 text-center fw-bold text-primary">
                                    <span class="row-total">@((Model.Items[i].Quantity * Model.Items[i].UnitPrice).ToString("N2"))</span>
                                </div>
                                <div class="col-md-1 col-12 text-end">
                                    <button type="button" class="btn btn-link link-danger p-0 border-0" onclick="removeRow(@i)"><i class="bi bi-x-circle-fill fs-5"></i></button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- 3) Notes & Total -->
            <div class="row g-2 mb-3">
                <div class="col-lg-7">
                    <div class="card border-0 shadow-sm rounded-3 h-100">
                        <div class="card-body p-3">
                            <h6 class="text-primary fw-bold mb-2 small"><i class="bi bi-pencil-square me-2"></i> ملاحظات</h6>
                            <textarea asp-for="Notes" class="form-control small" rows="2" placeholder="أضف ملاحظات الطبيب أو الاستقبال..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="card border-0 shadow-sm rounded-3 total-box text-white h-100">
                        <div class="card-body p-3 d-flex justify-content-between align-items-center">
                            <div class="text-white-50 fw-bold small"><i class="bi bi-cash-coin me-2"></i> الإجمالي</div>
                            <div class="text-end">
                                <h2 class="mb-0 fw-bolder"><span id="grandTotal">0.00</span> <small class="fs-6 fw-normal op-70">ج.س</small></h2>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 4) Final Action -->
            <div class="text-center mt-4">
                <button type="submit" class="btn btn-success btn-lg rounded-pill fw-bold px-5 shadow-sm">
                    <i class="bi bi-cloud-arrow-up me-2"></i> تحديث الحجز والخدمات
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var rowCount = @Model.Items.Count;
        var availableServices = @Html.Raw(Json.Serialize(Model.ServicesData));

        $(document).ready(function () {
            calculateGrandTotal();
        });

        function addRow() {
            var row = `
                <div class="row g-2 p-2 align-items-center bg-light rounded-2 border service-row mb-1" id="row_${rowCount}">
                    <div class="col-md-5 col-12">
                        <select name="Items[${rowCount}].ServiceId" class="form-select form-select-sm service-select" required onchange="updatePrice(${rowCount})">
                            <option value="">-- اختر الخدمة --</option>
                            ${availableServices.map(s => `<option value="${s.id}" data-price="${s.price}">${s.nameAr}</option>`).join('')}
                        </select>
                    </div>
                    <div class="col-md-2 col-4">
                        <input type="number" name="Items[${rowCount}].Quantity" class="form-control form-control-sm qty-input text-center" value="1" min="1" onchange="updateRowTotal(${rowCount})">
                    </div>
                    <div class="col-md-2 col-4">
                        <input type="number" name="Items[${rowCount}].UnitPrice" class="form-control form-control-sm price-input text-center" value="0" step="0.01" onchange="updateRowTotal(${rowCount})">
                    </div>
                    <div class="col-md-2 col-4 text-center fw-bold text-primary">
                        <span class="row-total">0.00</span>
                    </div>
                    <div class="col-md-1 col-12 text-end">
                        <button type="button" class="btn btn-link link-danger p-0 border-0" onclick="removeRow(${rowCount})"><i class="bi bi-x-circle-fill fs-5"></i></button>
                    </div>
                </div>
            `;
            $('#itemsBody').append(row);
            rowCount++;
        }

        function removeRow(id) {
            $('#row_' + id).fadeOut(150, function () { $(this).remove(); calculateGrandTotal(); });
        }

        function updatePrice(id) {
            var price = $('#row_' + id + ' .service-select option:selected').data('price') || 0;
            $('#row_' + id + ' .price-input').val(price);
            updateRowTotal(id);
        }

        function updateRowTotal(id) {
            var total = ($('#row_' + id + ' .qty-input').val() || 0) * ($('#row_' + id + ' .price-input').val() || 0);
            $('#row_' + id + ' .row-total').text(total.toFixed(2));
            calculateGrandTotal();
        }

        function calculateGrandTotal() {
            var consultationFee = parseFloat($('#consultationFee').val()) || 0;
            var servicesTotal = 0;
            $('.row-total').each(function () { servicesTotal += parseFloat($(this).text().replace(/,/g, '')) || 0; });
            var finalTotal = consultationFee + servicesTotal;
            $('#grandTotal').text(finalTotal.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }));
        }
    </script>
}
