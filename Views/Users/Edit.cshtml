@model NagmClinic.ViewModels.EditUserRoleViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "تعديل التخويل";
}

<div class="row align-items-center mb-4">
    <div class="col-12">
        <h2 class="fw-bold mb-0">تعديل صلاحيات المستخدم</h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">الرئيسية</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">إدارة المستخدمين</a></li>
                <li class="breadcrumb-item active">تعديل الصلاحيات</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 rounded-4 mt-4">
            <div class="card-body p-4 p-md-5 text-center">
                <div class="mb-4">
                    <div class="mx-auto bg-primary-subtle text-primary fw-bold shadow-sm mb-3 d-flex align-items-center justify-content-center" 
                         style="width: 80px; height: 80px; font-size: 2.2rem; border-radius: 50%;">
                        @Model.Email[0].ToString().ToUpper()
                    </div>
                </div>

                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger small mb-4"></div>
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="Email" />

                    <div class="mb-4 text-start">
                        <label asp-for="Email" class="form-label fw-bold"></label>
                        <input asp-for="Email" class="form-control bg-light" disabled />
                    </div>

                    <div class="mb-5 text-start">
                        <label asp-for="SelectedRole" class="form-label fw-bold">الدور الوظيفي الحالي:</label>
                        <select asp-for="SelectedRole" asp-items="ViewBag.Roles" class="form-select">
                            <option value="">-- اختر الدور الصلاحي --</option>
                        </select>
                        <span asp-validation-for="SelectedRole" class="text-danger small mt-2 d-block"></span>
                    </div>

                    <hr class="my-4 opacity-25" />

                    <div class="d-flex justify-content-center gap-3">
                        <button type="submit" class="btn btn-primary rounded-pill px-5">
                            <i class="bi bi-shield-check me-1"></i> حفظ التعديلات
                        </button>
                        <a asp-action="Index" class="btn btn-secondary rounded-pill px-5">إلغاء</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
