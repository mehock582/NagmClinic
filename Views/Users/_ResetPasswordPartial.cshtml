@model NagmClinic.ViewModels.ResetPasswordViewModel

<form asp-action="ResetPassword" method="post" id="resetPasswordForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="UserId" />
    <input type="hidden" asp-for="Email" />

    <div class="alert alert-warning border-0 small py-2 mb-4">
        <i class="bi bi-exclamation-triangle-fill me-1"></i>
        أنت الآن بصدد تغيير كلمة مرور المستخدم: <strong>@Model.Email</strong>
    </div>

    <div class="mb-3">
        <label asp-for="NewPassword" class="form-label fw-bold small"></label>
        <div class="input-group">
            <span class="input-group-text bg-light border-end-0"><i class="bi bi-key-fill text-primary"></i></span>
            <input asp-for="NewPassword" class="form-control bg-light border-start-0" />
        </div>
        <span asp-validation-for="NewPassword" class="text-danger small"></span>
    </div>

    <div class="mb-4">
        <label asp-for="ConfirmPassword" class="form-label fw-bold small"></label>
        <div class="input-group">
            <span class="input-group-text bg-light border-end-0"><i class="bi bi-shield-lock-fill text-primary"></i></span>
            <input asp-for="ConfirmPassword" class="form-control bg-light border-start-0" />
        </div>
        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
    </div>

    <div class="modal-footer border-0 px-0 pb-0">
        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">إلغاء</button>
        <button type="submit" class="btn btn-warning rounded-pill px-4 fw-bold">
            <i class="bi bi-key-fill me-1"></i> إعادة تعيين كلمة المرور
        </button>
    </div>
</form>
