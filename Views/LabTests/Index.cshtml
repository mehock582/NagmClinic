@model NagmClinic.ViewModels.LabTestsIndexViewModel

@{
    ViewData["Title"] = "الفحوصات المعملية";
    var createPrefix = string.Empty;
    const string editPrefix = "edit";
}

<div class="card border-0 shadow-sm rounded-3 transition-hover">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
            <h5 class="fw-bold mb-0 text-info">
                <i class="bi bi-microscope me-2"></i> إعدادات دليل الفحوصات المعملية
            </h5>
            <div class="d-flex gap-2 flex-wrap">
                <button type="button" class="btn btn-outline-success btn-sm rounded-pill px-3" onclick="seedEc38Catalog()">
                    <i class="bi bi-cpu me-1"></i> تحميل فحوصات EC-38
                </button>
                <button type="button" class="btn btn-info text-white btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#quickCreateTestModal">
                    <i class="bi bi-plus-lg me-1"></i> إضافة فحص معملي
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle text-center small w-100 nowrap">
                <thead class="bg-light">
                    <tr>
                        <th class="text-center align-middle text-nowrap border-0">الكود</th>
                        <th class="text-center align-middle text-nowrap border-0">الفحص</th>
                        <th class="text-center align-middle text-nowrap border-0">التصنيف</th>
                        <th class="text-center align-middle text-nowrap border-0">المصدر</th>
                        <th class="text-center align-middle text-nowrap border-0">نوع النتيجة</th>
                        <th class="text-center align-middle text-nowrap border-0">الحالة</th>
                        <th class="text-center align-middle text-nowrap border-0">الإجراءات</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="quickCreateTestModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-info"><i class="bi bi-plus-circle-fill me-2"></i> إضافة فحص معملي جديد</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="quickCreateTestForm" class="needs-validation" novalidate>
                    <partial name="_LabTestFormFields" model="createPrefix" />
                </form>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light btn-sm rounded-pill px-3" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-info text-white btn-sm rounded-pill px-4 fw-bold" onclick="saveTest()">حفظ الفحص</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="quickEditTestModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-info"><i class="bi bi-pencil-square me-2"></i> تعديل بيانات الفحص</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="quickEditTestForm" class="needs-validation" novalidate>
                    <input type="hidden" id="editTestId">
                    <partial name="_LabTestFormFields" model="editPrefix" />
                    <div class="col-12 mt-3">
                        <div class="form-check form-switch p-3 bg-light rounded-3 d-flex justify-content-between align-items-center">
                            <label class="form-check-label fw-bold mb-0" for="editTestActive">حالة الفحص (مفعل/معطل)</label>
                            <input class="form-check-input ms-0 me-2" type="checkbox" role="switch" id="editTestActive">
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light btn-sm rounded-pill px-3" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-info text-white btn-sm rounded-pill px-4 fw-bold" onclick="updateTest()">حفظ التغييرات</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="testDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom-0 p-4">
                <h5 class="modal-title fw-bold text-info"><i class="bi bi-info-circle me-2"></i> تفاصيل الفحص المعملي</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 pt-0">
                <div class="row g-3">
                    <div class="col-md-6"><div class="border rounded-3 p-3 h-100"><div class="text-muted small">الكود</div><div id="detailCode" class="fw-bold"></div></div></div>
                    <div class="col-md-6"><div class="border rounded-3 p-3 h-100"><div class="text-muted small">اسم الفحص</div><div id="detailName" class="fw-bold"></div></div></div>
                    <div class="col-md-6"><div class="border rounded-3 p-3 h-100"><div class="text-muted small">الاسم الإنجليزي</div><div id="detailNameEn" class="fw-bold"></div></div></div>
                    <div class="col-md-6"><div class="border rounded-3 p-3 h-100"><div class="text-muted small">اسم الطباعة</div><div id="detailPrintName" class="fw-bold"></div></div></div>
                    <div class="col-md-6"><div class="border rounded-3 p-3 h-100"><div class="text-muted small">التصنيف</div><div id="detailCategory" class="fw-bold"></div></div></div>
                    <div class="col-md-6"><div class="border rounded-3 p-3 h-100"><div class="text-muted small">المحلل / الجهاز</div><div id="detailAnalyzer" class="fw-bold"></div></div></div>
                    <div class="col-md-6"><div class="border rounded-3 p-3 h-100"><div class="text-muted small">مصدر النتيجة</div><div id="detailSourceType" class="fw-bold"></div></div></div>
                    <div class="col-md-6"><div class="border rounded-3 p-3 h-100"><div class="text-muted small">نوع النتيجة</div><div id="detailResultType" class="fw-bold"></div></div></div>
                    <div class="col-md-4"><div class="border rounded-3 p-3 h-100"><div class="text-muted small">الوحدة</div><div id="detailUnit" class="fw-bold"></div></div></div>
                    <div class="col-md-4"><div class="border rounded-3 p-3 h-100"><div class="text-muted small">نوع العينة</div><div id="detailSampleType" class="fw-bold"></div></div></div>
                    <div class="col-md-4"><div class="border rounded-3 p-3 h-100"><div class="text-muted small">كود الجهاز</div><div id="detailDeviceCode" class="fw-bold"></div></div></div>
                    <div class="col-md-6"><div class="border rounded-3 p-3 h-100"><div class="text-muted small">المدى الطبيعي</div><div id="detailNormalRange" class="fw-bold"></div></div></div>
                    <div class="col-md-6"><div class="border rounded-3 p-3 h-100"><div class="text-muted small">المدى المرجعي</div><div id="detailReferenceRange" class="fw-bold"></div></div></div>
                    <div class="col-md-6"><div class="border rounded-3 p-3 h-100"><div class="text-muted small">المدى الحرج</div><div id="detailCriticalRange" class="fw-bold"></div></div></div>
                    <div class="col-md-6"><div class="border rounded-3 p-3 h-100"><div class="text-muted small">الخيارات المحددة</div><div id="detailPredefined" class="fw-bold"></div></div></div>
                    <div class="col-12"><div class="border rounded-3 p-3 h-100"><div class="text-muted small">ملاحظات</div><div id="detailNotes" class="fw-bold"></div></div></div>
                </div>
            </div>
            <div class="modal-footer border-top-0 p-4 pt-0">
                <button type="button" class="btn btn-info text-white rounded-pill px-5 fw-bold shadow-sm" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    
    
    

    <script>
        $(document).ready(function () {
            var columns = [
                {
                    "data": "code",
                    "render": function (d, t, row) {
                        return `<div class="fw-bold">${d || '-'}</div><small class="text-muted">${row.deviceCode || '-'}</small>`;
                    }
                },
                {
                    "data": "nameAr",
                    "render": function (d, t, row) {
                        return `<div class="fw-bold">${d}</div><small class="text-muted">${row.nameEn || '-'}</small>`;
                    }
                },
                { "data": "categoryName" },
                {
                    "data": "sourceType",
                    "render": function (d, t, row) {
                        if (d == 2) return `<span class="badge bg-light text-success border">جهاز</span>`;
                        if (d == 3) return `<span class="badge bg-light text-warning border">مختلط</span>`;
                        return `<span class="badge bg-light text-secondary border">يدوي</span>`;
                    }
                },
                {
                    "data": "resultType",
                    "render": function (d) {
                        return `<span class="badge bg-light text-info border">${getResultTypeText(d)}</span>`;
                    }
                },
                {
                    "data": "isActive",
                    "render": function (d, t, row) {
                        return `<div class="form-check form-switch d-flex justify-content-center"><input class="form-check-input" type="checkbox" role="switch" ${d ? 'checked' : ''} onchange="toggleStatus(${row.id})"></div>`;
                    }
                },
                {
                    "data": "id",
                    "orderable": false,
                    "render": function (d, t, row) {
                        var attrs = buildDataAttributes(row);
                        return `<div class="action-group">
                            <button type="button" class="btn-action btn-action-info" onclick="viewTestDetails(this)" ${attrs} data-label="تفاصيل"><i class="bi bi-eye-fill"></i></button>
                            <button type="button" class="btn-action btn-action-primary" onclick="openEditTest(this)" ${attrs} data-label="تعديل"><i class="bi bi-pencil-fill"></i></button>
                        </div>`;
                    }
                }
            ];

            initDataTable('.table', '/LabTests/GetLabTestsData', columns);
            bindSourceTypeBehavior('');
            bindSourceTypeBehavior('edit');
            bindResultTypeBehavior('');
            bindResultTypeBehavior('edit');
        });

        function buildDataAttributes(row) {
            var attrs = [];
            Object.keys(row).forEach(function (key) {
                var value = row[key];
                if (value === null || value === undefined) {
                    value = '';
                }

                var safe = value.toString()
                    .replace(/&/g, '&amp;')
                    .replace(/"/g, '&quot;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;');

                attrs.push(`data-${toKebabCase(key)}="${safe}"`);
            });

            return attrs.join(' ');
        }

        function toKebabCase(value) {
            return value.replace(/([a-z0-9])([A-Z])/g, '$1-$2').toLowerCase();
        }

        function getResultTypeText(type) {
            if (type == 2) return 'رقمي';
            if (type == 3) return 'قائمة';
            if (type == 4) return 'إيجابي / سلبي';
            if (type == 5) return 'محسوب';
            return 'نصي';
        }

        function getSourceTypeText(type) {
            if (type == 2) return 'جهاز';
            if (type == 3) return 'مختلط';
            return 'يدوي';
        }

        function toggleStatus(id) {
            $.post('/LabTests/ToggleStatus/' + id, function (res) {
                if (!res.success) {
                    Swal.fire('خطأ', 'تعذر تغيير الحالة', 'error');
                }
            });
        }

        function bindSourceTypeBehavior(prefix) {
            var selector = prefix ? '#' + prefix + 'TestSourceType' : '#testSourceType';
            $(document).on('change', selector, function () {
                updateSourceFields(prefix);
            });
            updateSourceFields(prefix);
        }

        function bindResultTypeBehavior(prefix) {
            var selector = prefix ? '#' + prefix + 'TestResultType' : '#testResultType';
            $(document).on('change', selector, function () {
                updateResultFields(prefix);
            });
            updateResultFields(prefix);
        }

        function updateSourceFields(prefix) {
            var sourceValue = getField(prefix, 'SourceType').val();
            var isManual = sourceValue === '1';
            getField(prefix, 'Analyzer').prop('disabled', isManual);
            getField(prefix, 'DeviceCode').prop('disabled', isManual);

            if (isManual) {
                getField(prefix, 'Analyzer').val('');
                getField(prefix, 'DeviceCode').val('');
            }
        }

        function updateResultFields(prefix) {
            var resultType = getField(prefix, 'ResultType').val();
            var predefinedField = getField(prefix, 'Predefined');
            var isPredefined = resultType === '3' || resultType === '4';
            predefinedField.prop('disabled', !isPredefined);

            if (resultType === '4') {
                predefinedField.val('Positive,Negative');
            } else if (!isPredefined) {
                predefinedField.val('');
            }
        }

        function getField(prefix, suffix) {
            var name = prefix ? '#' + prefix + 'Test' + suffix : '#test' + suffix;
            return $(name);
        }

        function collectFormData(prefix) {
            var resultType = parseInt(getField(prefix, 'ResultType').val());
            var sourceType = parseInt(getField(prefix, 'SourceType').val());

            return {
                id: prefix ? $('#editTestId').val() : 0,
                nameAr: getField(prefix, 'NameAr').val(),
                nameEn: getField(prefix, 'NameEn').val(),
                code: getField(prefix, 'Code').val(),
                printName: getField(prefix, 'PrintName').val(),
                price: parseFloat(getField(prefix, 'Price').val() || '0'),
                unit: getField(prefix, 'Unit').val(),
                normalRange: getField(prefix, 'Range').val(),
                referenceRange: getField(prefix, 'ReferenceRange').val(),
                criticalRange: getField(prefix, 'CriticalRange').val(),
                sampleType: getField(prefix, 'SampleType').val(),
                resultType: resultType,
                sourceType: sourceType,
                deviceCode: sourceType === 1 ? '' : getField(prefix, 'DeviceCode').val(),
                predefinedValues: resultType === 4 ? 'Positive,Negative' : getField(prefix, 'Predefined').val(),
                sortOrder: parseInt(getField(prefix, 'SortOrder').val() || '0'),
                labCategoryId: parseInt(getField(prefix, 'Category').val() || '0') || null,
                labAnalyzerId: sourceType === 1 ? null : parseInt(getField(prefix, 'Analyzer').val() || '0') || null,
                notes: getField(prefix, 'Notes').val(),
                isActive: prefix ? $('#editTestActive').is(':checked') : true
            };
        }

        function saveTest() {
            const form = document.getElementById('quickCreateTestForm');
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            $.ajax({
                url: '/LabTests/QuickCreate',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(collectFormData('')),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        Swal.fire('خطأ', res.message, 'error');
                    }
                }
            });
        }

        function openEditTest(btn) {
            const $btn = $(btn);
            $('#editTestId').val($btn.data('id'));
            $('#editTestNameAr').val($btn.data('name-ar'));
            $('#editTestNameEn').val($btn.data('name-en'));
            $('#editTestCode').val($btn.data('code'));
            $('#editTestPrintName').val($btn.data('print-name'));
            $('#editTestPrice').val($btn.data('price'));
            $('#editTestUnit').val($btn.data('unit'));
            $('#editTestRange').val($btn.data('normal-range'));
            $('#editTestReferenceRange').val($btn.data('reference-range'));
            $('#editTestCriticalRange').val($btn.data('critical-range'));
            $('#editTestSampleType').val($btn.data('sample-type'));
            $('#editTestResultType').val($btn.data('result-type'));
            $('#editTestSourceType').val($btn.data('source-type'));
            $('#editTestDeviceCode').val($btn.data('device-code'));
            $('#editTestPredefined').val($btn.data('predefined-values'));
            $('#editTestSortOrder').val($btn.data('sort-order'));
            $('#editTestCategory').val($btn.data('category-id'));
            $('#editTestAnalyzer').val($btn.data('analyzer-id'));
            $('#editTestNotes').val($btn.data('notes'));
            $('#editTestActive').prop('checked', $btn.data('is-active') === true || $btn.data('is-active') === 'true');

            updateSourceFields('edit');
            updateResultFields('edit');
            $('#quickEditTestForm').removeClass('was-validated');
            new bootstrap.Modal(document.getElementById('quickEditTestModal')).show();
        }

        function viewTestDetails(btn) {
            const $btn = $(btn);
            $('#detailCode').text($btn.data('code') || '-');
            $('#detailName').text($btn.data('name-ar') || '-');
            $('#detailNameEn').text($btn.data('name-en') || '-');
            $('#detailPrintName').text($btn.data('print-name') || '-');
            $('#detailCategory').text($btn.data('category-name') || '-');
            $('#detailAnalyzer').text($btn.data('analyzer-name') || '-');
            $('#detailSourceType').text(getSourceTypeText($btn.data('source-type')));
            $('#detailResultType').text(getResultTypeText($btn.data('result-type')));
            $('#detailUnit').text($btn.data('unit') || '-');
            $('#detailSampleType').text($btn.data('sample-type') || '-');
            $('#detailDeviceCode').text($btn.data('device-code') || '-');
            $('#detailNormalRange').text($btn.data('normal-range') || '-');
            $('#detailReferenceRange').text($btn.data('reference-range') || '-');
            $('#detailCriticalRange').text($btn.data('critical-range') || '-');
            $('#detailPredefined').text($btn.data('predefined-values') || '-');
            $('#detailNotes').text($btn.data('notes') || '-');

            new bootstrap.Modal(document.getElementById('testDetailsModal')).show();
        }

        function updateTest() {
            const form = document.getElementById('quickEditTestForm');
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            $.ajax({
                url: '/LabTests/QuickEdit',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(collectFormData('edit')),
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        Swal.fire('خطأ', res.message, 'error');
                    }
                }
            });
        }

        function seedEc38Catalog() {
            $.post('/LabTests/SeedEc38Catalog', function (res) {
                if (res.success) {
                    Swal.fire('تم', res.message, 'success').then(function () {
                        location.reload();
                    });
                } else {
                    Swal.fire('خطأ', res.message || 'تعذر تحميل فحوصات EC-38', 'error');
                }
            });
        }
    </script>
}


