@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid px-0">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-5 mt-2">
        <div>
            <h2 class="fw-bold text-dark mb-0">نظرة عامة على النظام</h2>
            <p class="text-muted small mb-0">أهلاً بك، إليك ملخص لأداء المركز اليوم</p>
        </div>
        <div class="d-flex gap-2">
            <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                <button class="btn btn-white btn-sm px-3 active">اليوم</button>
                <button class="btn btn-white btn-sm px-3">الأسبوع</button>
                <button class="btn btn-white btn-sm px-3">الشهر</button>
            </div>
            <button class="btn btn-primary btn-sm rounded-pill px-4 shadow-sm">
                <i class="bi bi-download me-1"></i> تصدير
            </button>
        </div>
    </div>

    <!-- Metrics Row -->
    <div class="row g-4 mb-5">
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 h-100 p-2">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="bg-indigo-light p-3 rounded-4">
                            <i class="bi bi-people-fill text-indigo fs-4"></i>
                        </div>
                        <span class="text-success small fw-bold">+12% <i class="bi bi-arrow-up"></i></span>
                    </div>
                    <h3 class="fw-bold mb-1" id="dashTotalPatients">--</h3>
                    <p class="text-muted small mb-0">إجمالي المرضى</p>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 h-100 p-2">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="bg-orange-light p-3 rounded-4">
                            <i class="bi bi-calendar2-check-fill text-orange fs-4"></i>
                        </div>
                        <span class="text-indigo small fw-bold">نشط</span>
                    </div>
                    <h3 class="fw-bold mb-1" id="dashAppointmentsToday">--</h3>
                    <p class="text-muted small mb-0">مواعيد اليوم</p>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 h-100 p-2">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="bg-green-light p-3 rounded-4">
                            <i class="bi bi-currency-dollar text-green fs-4"></i>
                        </div>
                        <span class="text-success small fw-bold">+8% <i class="bi bi-arrow-up"></i></span>
                    </div>
                    <h3 class="fw-bold mb-1" id="dashMonthlyRevenue">--</h3>
                    <p class="text-muted small mb-0">إيرادات الشهر</p>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 h-100 p-2">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="bg-red-light p-3 rounded-4">
                            <i class="bi bi-exclamation-triangle-fill text-red fs-4"></i>
                        </div>
                        <span class="text-red small fw-bold">تنبيه</span>
                    </div>
                    <h3 class="fw-bold mb-1" id="dashLowStock">--</h3>
                    <p class="text-muted small mb-0">نقص المخزون</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row g-4 mb-5">
        <div class="col-xl-8">
            <div class="card border-0 h-100">
                <div class="card-header border-0 bg-transparent p-4 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0">تحليل الإيرادات</h5>
                    <div class="text-muted small"><i class="bi bi-circle-fill text-indigo me-1" style="font-size: 8px;"></i> المبيعات والكشوفات</div>
                </div>
                <div class="card-body p-4">
                    <div style="height: 350px;">
                        <canvas id="mainTrendChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4">
            <div class="card border-0 h-100">
                <div class="card-header border-0 bg-transparent p-4 pb-0">
                    <h5 class="fw-bold mb-0">حالات الحجز اليوم</h5>
                </div>
                <div class="card-body p-4 d-flex flex-column align-items-center justify-content-center">
                    <div style="height: 240px; width: 100%;">
                        <canvas id="statusDonutChart"></canvas>
                    </div>
                    <div id="donutLegend" class="mt-4 w-100">
                        <!-- Legend will be populated by JS -->
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Row: Quick Actions & Alerts -->
    <div class="row g-4 mb-4">
        <div class="col-xl-6">
            <div class="card border-0 h-100">
                <div class="card-header border-0 bg-transparent p-4 pb-0">
                    <h5 class="fw-bold mb-0">إجراءات سريعة</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <a asp-controller="Appointments" asp-action="Create" class="quick-action-item bg-light p-3 rounded-4 d-flex align-items-center gap-3 transition-all">
                                <div class="bg-white p-2 rounded-3 shadow-sm text-indigo"><i class="bi bi-plus-circle-fill fs-5"></i></div>
                                <div>
                                    <h6 class="fw-bold mb-0 text-dark">حجز جديد</h6>
                                    <p class="mb-0 x-small text-muted">إضافة موعد لمريض</p>
                                </div>
                            </a>
                        </div>
                        <div class="col-sm-6">
                            <a asp-controller="PharmacySales" asp-action="Create" class="quick-action-item bg-light p-3 rounded-4 d-flex align-items-center gap-3 transition-all">
                                <div class="bg-white p-2 rounded-3 shadow-sm text-green"><i class="bi bi-cart-plus-fill fs-5"></i></div>
                                <div>
                                    <h6 class="fw-bold mb-0 text-dark">فاتورة صيدلية</h6>
                                    <p class="mb-0 x-small text-muted">بيع صنف دوائي</p>
                                </div>
                            </a>
                        </div>
                        <div class="col-sm-6">
                            <a asp-controller="Patients" asp-action="Index" class="quick-action-item bg-light p-3 rounded-4 d-flex align-items-center gap-3 transition-all">
                                <div class="bg-white p-2 rounded-3 shadow-sm text-orange"><i class="bi bi-people-fill fs-5"></i></div>
                                <div>
                                    <h6 class="fw-bold mb-0 text-dark">إدارة المرضى</h6>
                                    <p class="mb-0 x-small text-muted">البحث والتعديل</p>
                                </div>
                            </a>
                        </div>
                        <div class="col-sm-6">
                            <a asp-controller="PharmacyInventory" asp-action="Index" class="quick-action-item bg-light p-3 rounded-4 d-flex align-items-center gap-3 transition-all">
                                <div class="bg-white p-2 rounded-3 shadow-sm text-red"><i class="bi bi-box-seam-fill fs-5"></i></div>
                                <div>
                                    <h6 class="fw-bold mb-0 text-dark">المخزون</h6>
                                    <p class="mb-0 x-small text-muted">مراقبة الكميات</p>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-6">
            <div class="card border-0 h-100 bg-indigo text-white p-4 position-relative overflow-hidden">
                <div class="position-absolute top-0 end-0 p-4 opacity-10">
                    <i class="bi bi-lightning-charge-fill" style="font-size: 150px;"></i>
                </div>
                <div class="position-relative z-1">
                    <h4 class="fw-bold mb-3">النظام يعمل بكفاءة</h4>
                    <p class="mb-4 text-white text-opacity-75">جميع العمليات في الصيدلية والاستقبال تعمل بشكل طبيعي دون تأخير. تم تحديث البيانات قبل لحظات.</p>
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-white bg-opacity-20 p-3 rounded-4 border border-white border-opacity-25">
                            <h2 class="fw-bold mb-0">100%</h2>
                            <p class="mb-0 x-small fw-bold">استقرار النظام</p>
                        </div>
                        <div class="bg-white bg-opacity-20 p-3 rounded-4 border border-white border-opacity-25">
                            <h2 class="fw-bold mb-0" id="dashUptimeLabel">24h</h2>
                            <p class="mb-0 x-small fw-bold">وقت التشغيل</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Dribbble Style Tokens */
    :root {
        --indigo: #6366f1;
        --indigo-light: #eef2ff;
        --orange: #f59e0b;
        --orange-light: #fff7ed;
        --green: #10b981;
        --green-light: #ecfdf5;
        --red: #ef4444;
        --red-light: #fef2f2;
    }

    .bg-indigo { background-color: var(--indigo) !important; }
    .text-indigo { color: var(--indigo) !important; }
    .bg-indigo-light { background-color: var(--indigo-light) !important; }

    .text-orange { color: var(--orange) !important; }
    .bg-orange-light { background-color: var(--orange-light) !important; }

    .text-green { color: var(--green) !important; }
    .bg-green-light { background-color: var(--green-light) !important; }

    .text-red { color: var(--red) !important; }
    .bg-red-light { background-color: var(--red-light) !important; }

    .btn-white {
        background: #fff;
        border: 1px solid #e5e7eb;
        color: #4b5563;
    }
    .btn-white.active {
        background: #f3f4f6;
        color: #111827;
        font-weight: 700;
    }

    .quick-action-item {
        border: 1px solid transparent;
        text-decoration: none;
    }
    .quick-action-item:hover {
        background-color: #fff !important;
        border-color: #e5e7eb;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        transform: translateY(-2px);
    }

    .x-small { font-size: 0.75rem; }
    .transition-all { transition: all 0.2s ease; }

    canvas { width: 100% !important; }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let trendChart = null;
        let donutChart = null;

        function initCharts() {
            // Main Trend Chart
            const trendCtx = document.getElementById('mainTrendChart').getContext('2d');
            const gradient = trendCtx.createLinearGradient(0, 0, 0, 350);
            gradient.addColorStop(0, 'rgba(99, 102, 241, 0.15)');
            gradient.addColorStop(1, 'rgba(99, 102, 241, 0)');

            trendChart = new Chart(trendCtx, {
                type: 'line',
                data: {
                    labels: [],
                    datasets: [{
                        label: 'الإيرادات',
                        data: [],
                        borderColor: '#6366f1',
                        borderWidth: 3,
                        pointRadius: 0,
                        pointHoverRadius: 6,
                        pointHoverBackgroundColor: '#6366f1',
                        pointHoverBorderColor: '#fff',
                        pointHoverBorderWidth: 3,
                        fill: true,
                        backgroundColor: gradient,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { borderDash: [5, 5], color: '#f3f4f6', drawBorder: false },
                            ticks: { color: '#9ca3af', font: { size: 11 }, callback: v => v >= 1000 ? (v/1000)+'k' : v }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { color: '#9ca3af', font: { size: 11 } }
                        }
                    }
                }
            });

            // Donut Chart
            const donutCtx = document.getElementById('statusDonutChart').getContext('2d');
            donutChart = new Chart(donutCtx, {
                type: 'doughnut',
                data: {
                    labels: [],
                    datasets: [{
                        data: [],
                        backgroundColor: ['#6366f1', '#f59e0b', '#10b981', '#ef4444', '#8b5cf6'],
                        borderWidth: 0,
                        cutout: '80%'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } }
                }
            });
        }

        function updateLegend(labels, data, colors) {
            const legend = document.getElementById('donutLegend');
            legend.innerHTML = '';
            labels.forEach((label, i) => {
                const item = document.createElement('div');
                item.className = 'd-flex align-items-center justify-content-between mb-2 small';
                item.innerHTML = `
                    <div class="d-flex align-items-center gap-2">
                        <div style="width: 8px; height: 8px; border-radius: 50%; background: ${colors[i]}"></div>
                        <span class="text-muted">${label}</span>
                    </div>
                    <span class="fw-bold">${data[i]}</span>
                `;
                legend.appendChild(item);
            });
        }

        function loadDashboardData() {
            $.get('/Home/GetDashboardStats', function(res) {
                if(res.success) {
                    $('#dashTotalPatients').text(res.totalPatients);
                    $('#dashAppointmentsToday').text(res.appointmentsToday);
                    $('#dashMonthlyRevenue').text(res.monthlyRevenue + ' ج.س');
                    $('#dashLowStock').text(res.lowStockCount);

                    // Update Trend Chart
                    trendChart.data.labels = res.trendLabels;
                    trendChart.data.datasets[0].data = res.trendData;
                    trendChart.update();

                    // Update Donut Chart
                    donutChart.data.labels = res.statusLabels;
                    donutChart.data.datasets[0].data = res.statusData;
                    donutChart.update();

                    updateLegend(res.statusLabels, res.statusData, ['#6366f1', '#f59e0b', '#10b981', '#ef4444', '#8b5cf6']);
                }
            });
        }

        $(document).ready(function() {
            initCharts();
            loadDashboardData();
            setInterval(loadDashboardData, 60000); // Every minute
        });
    </script>
}
