@{
    ViewData["Title"] = "لوحة التحكم";
}

<div class="row g-4 mb-4">
    <!-- Welcome Card -->
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width: 56px; height: 56px;">
                        <i class="bi bi-heart-pulse-fill text-primary fs-3"></i>
                    </div>
                    <div>
                        <h4 class="fw-bold mb-1">مرحباً بك في @BrandingService.GetBranding().CenterNameAr</h4>
                        <p class="text-muted mb-0">نظام إدارة العيادة والاستقبال - <span class="small">Designed by Elharith Elsiidiq</span></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Stats Cards -->
    <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-4 text-center">
                <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-people-fill text-primary fs-3"></i>
                </div>
                <h2 class="fw-bolder text-dark mb-1" id="dashTotalPatients">--</h2>
                <p class="text-muted mb-2">إجمالي المرضى</p>
                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3"><i class="bi bi-arrow-up me-1"></i> مباشر</span>
            </div>
        </div>
    </div>

    <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-4 text-center">
                <div class="bg-info bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-calendar2-check text-info fs-3"></i>
                </div>
                <h2 class="fw-bolder text-dark mb-1" id="dashAppointmentsToday">--</h2>
                <p class="text-muted mb-2">مواعيد اليوم</p>
                <div class="progress mx-auto" style="height: 6px; max-width: 150px;">
                    <div class="progress-bar bg-info progress-bar-striped progress-bar-animated" style="width: 100%"></div>
                </div>
                <small class="text-muted mt-1 d-block" id="dashApptLabel">تحديث تلقائي...</small>
            </div>
        </div>
    </div>

    <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-4 text-center">
                <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-cash-stack text-success fs-3"></i>
                </div>
                <h2 class="fw-bolder text-success mb-1" id="dashMonthlyRevenue">--</h2>
                <p class="text-muted mb-2">الإيرادات الشهرية</p>
                <a href="#" class="btn btn-outline-success btn-sm rounded-pill px-3">عرض التقارير</a>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-lightning-fill text-warning me-2"></i> إجراءات سريعة</h5>
                <div class="row g-3">
                    <div class="col-md-3 col-6">
                        <a asp-controller="Appointments" asp-action="Create" class="btn btn-primary w-100 rounded-3 py-3 fw-bold">
                            <i class="bi bi-plus-circle d-block fs-3 mb-1"></i> حجز جديد
                        </a>
                    </div>
                    <div class="col-md-3 col-6">
                        <a asp-controller="Appointments" asp-action="Index" class="btn btn-outline-primary w-100 rounded-3 py-3 fw-bold">
                            <i class="bi bi-calendar2-week d-block fs-3 mb-1"></i> الحجوزات
                        </a>
                    </div>
                    <div class="col-md-3 col-6">
                        <a asp-controller="Patients" asp-action="Index" class="btn btn-outline-primary w-100 rounded-3 py-3 fw-bold">
                            <i class="bi bi-people d-block fs-3 mb-1"></i> المرضى
                        </a>
                    </div>
                    <div class="col-md-3 col-6">
                        <a asp-controller="Doctors" asp-action="Index" class="btn btn-outline-primary w-100 rounded-3 py-3 fw-bold">
                            <i class="bi bi-person-badge d-block fs-3 mb-1"></i> الأطباء
                        </a>
                    </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function loadDashboardData() {
            $.get('/Home/GetDashboardStats', function(data) {
                if(data) {
                    $('#dashTotalPatients').text(data.totalPatients);
                    $('#dashAppointmentsToday').text(data.appointmentsToday);
                    $('#dashMonthlyRevenue').text(data.monthlyRevenue + ' ج.س');
                }
            }).fail(function() {
                // Silently ignore network failures to avoid spam
            });
        }

        $(document).ready(function() {
            // Load immediately
            loadDashboardData();
            
            // Auto refresh every 5 seconds
            setInterval(loadDashboardData, 5000);
        });
    </script>
}
