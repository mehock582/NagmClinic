@{
    ViewData["Title"] = "غير مصرح بالوصول";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/cairo-font.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            font-family: 'Cairo', sans-serif;
        }
        .denied-card {
            border: none;
            border-radius: 1.5rem;
            box-shadow: 0 20px 60px rgba(0,0,0,0.2);
            overflow: hidden;
        }
        .denied-brand {
            background: linear-gradient(135deg, #e74c3c, #c0392b);
            padding: 2.5rem;
            text-align: center;
            color: white;
        }
        .denied-brand .brand-icon { font-size: 3rem; margin-bottom: 0.5rem; }
        .denied-body { padding: 2.5rem; text-align: center; }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="denied-card card">
                    <div class="denied-brand">
                        <div class="brand-icon"><i class="bi bi-shield-lock-fill"></i></div>
                        <h4 class="fw-bold mb-1">403 - غير مصرح</h4>
                        <p class="mb-0 opacity-75 small">ليس لديك صلاحية للوصول</p>
                    </div>
                    <div class="denied-body">
                        <p class="text-muted mb-1">ليس لديك صلاحية للوصول إلى هذه الصفحة.</p>
                        <p class="text-muted small mb-4">إذا كنت تعتقد أن هذا خطأ، يرجى التواصل مع مسؤول النظام.</p>

                        <div class="d-flex gap-2 justify-content-center">
                            <a href="/" class="btn btn-primary rounded-pill px-4">
                                <i class="bi bi-house-fill me-2"></i>العودة للرئيسية
                            </a>
                            <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill px-4">
                                <i class="bi bi-arrow-right me-2"></i>رجوع
                            </a>
                        </div>
                    </div>
                </div>
                <p class="text-center text-white mt-3 small opacity-75">
                    &copy; @DateTime.Now.Year - جميع الحقوق محفوظة
                </p>
            </div>
        </div>
    </div>
</body>
</html>
