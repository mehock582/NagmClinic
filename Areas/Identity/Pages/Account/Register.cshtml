@page
@using NagmClinic.Areas.Identity.Pages.Account
@model RegisterModel
@{
    ViewData["Title"] = "تسجيل حساب جديد";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/cairo-font.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            font-family: 'Cairo', sans-serif;
        }
        .register-card { border: none; border-radius: 1.5rem; box-shadow: 0 20px 60px rgba(0,0,0,0.2); overflow: hidden; }
        .register-brand { background: linear-gradient(135deg, #4361ee, #3a0ca3); padding: 2rem; text-align: center; color: white; }
        .register-brand .brand-icon { font-size: 2.5rem; }
        .register-body { padding: 2rem; }
        .form-control:focus { border-color: #4361ee; box-shadow: 0 0 0 0.2rem rgba(67,97,238,.2); }
        .btn-register { background: linear-gradient(135deg, #4361ee, #3a0ca3); border: none; border-radius: 0.75rem; padding: 0.65rem; font-weight: 700; }
        .input-group-text { background: #f8f9ff; }
    </style>
</head>
<body>
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="register-card card">
                    <div class="register-brand">
                        <div class="brand-icon mb-2"><i class="bi bi-person-plus-fill"></i></div>
                        <h5 class="fw-bold mb-0">إنشاء حساب جديد</h5>
                        <p class="small mb-0 opacity-75">نظام إدارة العيادة</p>
                    </div>
                    <div class="register-body">
                        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2" role="alert"></div>

                            <div class="mb-3">
                                <label asp-for="Input.Email" class="form-label fw-semibold small"></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-envelope-fill text-primary"></i></span>
                                    <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="example@clinic.com" />
                                </div>
                                <span asp-validation-for="Input.Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.Password" class="form-label fw-semibold small"></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-lock-fill text-primary"></i></span>
                                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" placeholder="••••••••" />
                                </div>
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold small"></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-lock-check-fill text-primary"></i></span>
                                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="••••••••" />
                                </div>
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <button id="registerSubmit" type="submit" class="btn btn-primary btn-register w-100 text-white">
                                <i class="bi bi-person-check-fill me-2"></i> إنشاء الحساب
                            </button>
                        </form>

                        <div class="text-center mt-3">
                            <a asp-page="./Login" class="text-primary small text-decoration-none">
                                <i class="bi bi-arrow-right me-1"></i> لديك حساب؟ سجّل دخولك
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @section Scripts { <partial name="_ValidationScriptsPartial" /> }
</body>
</html>
