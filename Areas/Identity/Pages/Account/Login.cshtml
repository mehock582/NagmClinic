@page
@using NagmClinic.Areas.Identity.Pages.Account
@model LoginModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/cairo-font.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            font-family: 'Cairo', sans-serif;
        }
        .login-card {
            border: none;
            border-radius: 1.5rem;
            box-shadow: 0 20px 60px rgba(0,0,0,0.2);
            overflow: hidden;
        }
        .login-brand {
            background: linear-gradient(135deg, #4361ee, #3a0ca3);
            padding: 2.5rem;
            text-align: center;
            color: white;
        }
        .login-brand .brand-icon {
            font-size: 3rem;
            margin-bottom: 0.5rem;
        }
        .login-body { padding: 2.5rem; }
        .form-control:focus { border-color: #4361ee; box-shadow: 0 0 0 0.2rem rgba(67,97,238,.2); }
        .btn-login {
            background: linear-gradient(135deg, #4361ee, #3a0ca3);
            border: none;
            border-radius: 0.75rem;
            padding: 0.75rem;
            font-weight: 700;
            font-size: 1.05rem;
            letter-spacing: 0.5px;
        }
        .btn-login:hover { opacity: 0.9; transform: translateY(-1px); }
        .input-group-text { background: #f8f9ff; border-color: #dee2e6; }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="login-card card">
                    <div class="login-brand">
                        <div class="brand-icon"><i class="bi bi-heart-pulse-fill"></i></div>
                        <h4 class="fw-bold mb-1">نظام إدارة العيادة</h4>
                        <p class="mb-0 opacity-75 small">سجّل دخولك للمتابعة</p>
                    </div>
                    <div class="login-body">
                        <form id="account" method="post">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2" role="alert"></div>

                            <div class="mb-3">
                                <label asp-for="Input.Email" class="form-label fw-semibold small">البريد الإلكتروني</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-envelope-fill text-primary"></i></span>
                                    <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="example@clinic.com" />
                                </div>
                                <span asp-validation-for="Input.Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Input.Password" class="form-label fw-semibold small">كلمة المرور</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-lock-fill text-primary"></i></span>
                                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="••••••••" />
                                </div>
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>

                            <div class="mb-4 d-flex justify-content-between align-items-center">
                                <div class="form-check">
                                    <input asp-for="Input.RememberMe" class="form-check-input" type="checkbox" />
                                    <label asp-for="Input.RememberMe" class="form-check-label small">تذكرني</label>
                                </div>
                                <a asp-page="./ForgotPassword" class="small text-primary text-decoration-none">نسيت كلمة المرور؟</a>
                            </div>

                            <button id="login-submit" type="submit" class="btn btn-primary btn-login w-100 text-white">
                                <i class="bi bi-box-arrow-in-left me-2"></i> دخول
                            </button>
                        </form>
                    </div>
                </div>
                <p class="text-center text-white mt-3 small opacity-75">
                    &copy; @DateTime.Now.Year - جميع الحقوق محفوظة
                </p>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @section Scripts { <partial name="_ValidationScriptsPartial" /> }
</body>
</html>
